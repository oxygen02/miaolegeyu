.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  pointer-events: none;
  overflow: hidden;
}

.poster-modal.show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}



.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10rpx);
  z-index: 1;
}

.modal-content {
  position: relative;
  width: 680rpx;
  max-height: 95vh;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  transform: scale(0.9) translateY(50rpx);
  transition: transform 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  pointer-events: auto;
  z-index: 2;
  /* 关键：确保内容区不会穿透 */
  overflow: hidden;
  overflow-y: hidden;
}

.content-show {
  transform: scale(1) translateY(0);
}

/* 关闭按钮 */
.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-text {
  font-size: 24rpx;
  color: #999999;
}

/* 标题 */
.modal-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3D3D;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #8A8A8A;
}

/* 画布容器 - 适配 750x1250 画布比例 */
.canvas-wrapper {
  position: relative;
  width: 600rpx;
  height: 1000rpx; /* 按比例缩放：1250 * (600/750) = 1000 */
  margin: 0 auto 30rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.poster-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

/* 生成的海报图片（覆盖在canvas上） */
.poster-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 5;
}

/* 加载状态 */
.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.loading-mask text {
  font-size: 28rpx;
  color: #8A8A8A;
  margin-top: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FFE4CC;
  border-top-color: #FF9F43;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.action-btn {
  height: 68rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 40rpx;
  transition: all 0.1s ease;
  flex: none;
}

.action-btn::after {
  display: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FFB347, #FF8C42);
  color: #FFFFFF;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.action-btn.primary:active {
  background: linear-gradient(135deg, #FFA726, #F57C00);
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateY(2rpx);
}

.action-btn.secondary {
  background: #F5F5F5;
  color: #666666;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.action-btn.secondary:active {
  background: #EEEEEE;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateY(2rpx);
}

.action-btn text {
  font-size: 28rpx;
}
