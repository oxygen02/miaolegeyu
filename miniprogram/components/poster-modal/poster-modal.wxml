<view class="poster-modal {{visible ? 'show' : ''}}">
  <!-- 遮罩层：点击关闭 -->
  <view class="modal-mask" catchtap="onClose" wx:if="{{visible}}"></view>
  
  <!-- 内容区：阻止冒泡到mask -->
  <view class="modal-content {{visible ? 'content-show' : ''}}" catchtap="onContentTap" wx:if="{{visible}}">
    <!-- 关闭按钮 -->
    <view class="close-btn" catchtap="onClose">
      <text class="close-text">关闭</text>
    </view>
    
    <!-- 标题 -->
    <view class="modal-header">
      <text class="title">{{title}}</text>
      <text class="subtitle">保存图片分享到朋友圈</text>
    </view>
    
    <!-- 海报画布 -->
    <view class="canvas-wrapper">
      <canvas 
        type="2d" 
        id="posterCanvas" 
        class="poster-canvas"
      ></canvas>
      
      <!-- 加载状态 -->
      <view class="loading-mask" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text>生成海报中...</text>
      </view>

      <!-- 生成的海报图片（加载完成后显示） -->
      <image 
        wx:if="{{!isLoading && posterImagePath}}"
        class="poster-image"
        src="{{posterImagePath}}"
        mode="aspectFit"
      />
    </view>
    
    <!-- 操作按钮 -->
    <view class="modal-actions">
      <button class="action-btn primary" bindtap="onSave">
        <text>保存到相册</text>
      </button>
      <button class="action-btn secondary" bindtap="onShareFriend">
        <text>分享给好友</text>
      </button>
    </view>
  </view>
</view>
