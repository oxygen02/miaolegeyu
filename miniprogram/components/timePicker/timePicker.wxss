/* 自定义时间选择器 */
.time-picker-custom {
  width: 100%;
}

/* 触发区域 - 参考拼个单样式 */
.picker-trigger {
  height: 72rpx;
  background: var(--color-bg-warm, #FFF8F0);
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 26rpx;
  color: var(--color-text-secondary, #8A8A8A);
}

.picker-value.has-value {
  color: var(--color-text, #333);
  font-weight: 600;
}

.picker-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid #999;
  border-bottom: 3rpx solid #999;
  transform: rotate(45deg);
}

/* 弹窗遮罩 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

/* 选择器容器 */
.picker-container {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

/* 头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 32rpx;
  color: #999;
}

.picker-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.picker-confirm {
  font-size: 32rpx;
  color: #07C160;
  font-weight: 600;
}

/* 选择区域 */
.picker-body {
  display: flex;
  height: 600rpx;
  padding: 20rpx 0 40rpx;
}

.picker-column {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.column-title {
  font-size: 30rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
  font-weight: 500;
}

.column-scroll {
  flex: 1;
  height: 500rpx;
}

.column-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 40rpx;
  color: #333;
  transition: all 0.2s;
}

.column-item.active {
  color: #07C160;
  font-weight: 600;
  font-size: 48rpx;
}
