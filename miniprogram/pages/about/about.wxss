.about-page {
  height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-header {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 2rpx solid #E0E0E0;
  flex-shrink: 0;
}

.back-btn {
  font-size: 48rpx;
  color: #333;
  padding: 0 20rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-right: 88rpx;
}

/* 应用信息 */
.app-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 40rpx;
  background: #fff;
  flex-shrink: 0;
}

.app-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.app-version {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #666;
}

/* 功能特色 */
.features-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 20rpx 40rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.feature-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #666;
}

/* 联系我们 */
.contact-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 20rpx 40rpx;
  flex-shrink: 0;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: #666;
}

.contact-value {
  font-size: 28rpx;
  color: #FF9F43;
  max-width: 400rpx;
  text-align: right;
  word-break: break-all;
}

/* 版权信息 */
.footer {
  padding: 16rpx;
  text-align: center;
  flex-shrink: 0;
}

.copyright {
  font-size: 24rpx;
  color: #999;
}
