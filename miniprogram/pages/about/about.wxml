<view class="about-page">
  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">关于</text>
  </view>

  <!-- 应用信息 -->
  <view class="app-info">
    <image class="app-logo" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFit"/>
    <text class="app-name">{{appName}}</text>
    <text class="app-version">版本 {{version}}</text>
    <text class="app-desc">{{description}}</text>
  </view>

  <!-- 功能特色 -->
  <view class="features-section">
    <view class="section-title">功能特色</view>
    <view class="features-list">
      <view class="feature-item" wx:for="{{features}}" wx:key="title">
        <image class="feature-icon" src="{{item.icon}}" mode="aspectFit"/>
        <view class="feature-content">
          <text class="feature-title">{{item.title}}</text>
          <text class="feature-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系我们 -->
  <view class="contact-section">
    <view class="section-title">联系我们</view>
    <view class="contact-item" bindtap="copyEmail">
      <text class="contact-label">邮箱</text>
      <text class="contact-value">{{contact.email}}</text>
    </view>
    <view class="contact-item">
      <text class="contact-label">微信号</text>
      <text class="contact-value">{{contact.wechat}}</text>
    </view>
  </view>

  <!-- 版权信息 -->
  <view class="footer">
    <text class="copyright">© 2026 喵了个鱼 版权所有</text>
  </view>
</view>
