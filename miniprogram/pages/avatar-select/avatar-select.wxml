<view class="container">
  <!-- 登录模式：昵称输入区 -->
  <view class="nickname-section" wx:if="{{isLoginMode}}">
    <view class="section-title">设置昵称</view>
    <input
      class="nickname-input"
      placeholder="请输入您的昵称"
      value="{{nickName}}"
      bindinput="onNickNameInput"
      maxlength="20"
    />
    <view class="section-subtitle">选择头像</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar" wx:if="{{!isLoginMode}}">
    <input
      class="search-input"
      placeholder="搜索头像..."
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <image class="search-btn" src="{{imagePaths.icons.search || '/assets/images/search.png'}}" mode="aspectFit" bindtap="onSearch" />
  </view>

  <!-- 头像网格 -->
  <scroll-view
    class="avatar-grid {{isLoginMode ? 'login-mode' : ''}}"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="false"
    bindscrolltolower="loadMore"
  >
    <view class="grid-content">
      <view 
        class="avatar-item {{selectedAvatar === item._id ? 'selected' : ''}}" 
        wx:for="{{avatars}}" 
        wx:key="_id"
        bindtap="selectAvatar"
        data-id="{{item._id}}"
        data-url="{{item.imageUrl}}"
      >
        <image class="avatar-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true"/>
        <view class="avatar-name">{{item.name}}</view>
        <view class="selected-icon" wx:if="{{selectedAvatar === item._id}}">✓</view>
      </view>
    </view>
    
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && avatars.length === 0}}">
      <text>暂无头像</text>
    </view>
    
    <!-- 到底提示 -->
    <view class="no-more" wx:if="{{!hasMore && avatars.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn btn-secondary" bindtap="goBack">取消</button>
    <button class="btn btn-primary {{!selectedAvatar ? 'disabled' : ''}}" bindtap="confirmSelect">确认选择</button>
  </view>
</view>
