.container {
  height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* 昵称输入区（登录模式） */
.nickname-section {
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #E0E0E0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #E0E0E0;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #E0E0E0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  border: 2rpx solid #E0E0E0;
}

.search-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

/* 头像网格 */
.avatar-grid {
  flex: 1;
  height: 0;
  padding: 12rpx 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.avatar-grid.login-mode {
  height: calc(100vh - 480rpx);
}

.grid-content {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.avatar-item {
  position: relative;
  background: #fff;
  border-radius: 10rpx;
  padding: 8rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.avatar-item.selected {
  border-color: #FF9F43;
  background: #FFF8F0;
}

.avatar-image {
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.avatar-name {
  font-size: 16rpx;
  color: #666;
  text-align: center;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-icon {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF9F43;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  border: 2rpx solid #fff;
}

/* 加载状态 */
.loading-state, .empty-state, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部按钮 */
.bottom-bar {
  padding: 20rpx 0 60rpx 0;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  gap: 32rpx;
  background: transparent;
  border-top: none;
}

.btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  text-align: center;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 12rpx 32rpx !important;
  margin: 0 !important;
}

.btn::after {
  display: none !important;
}

.btn-secondary {
  background: #fff !important;
  color: #3D3D3D !important;
}

.btn-primary {
  background: #FF9F43 !important;
  color: #fff !important;
}

.btn-primary.disabled {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}
