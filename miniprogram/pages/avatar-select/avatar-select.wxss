.container {
  height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #E0E0E0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  border: 2rpx solid #E0E0E0;
}

.search-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 16rpx;
}

/* 头像网格 */
.avatar-grid {
  height: calc(100vh - 320rpx);
  padding: 12rpx 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.grid-content {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.avatar-item {
  position: relative;
  background: #fff;
  border-radius: 10rpx;
  padding: 8rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.avatar-item.selected {
  border-color: #FF9F43;
  background: #FFF8F0;
}

.avatar-image {
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.avatar-name {
  font-size: 16rpx;
  color: #666;
  text-align: center;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-icon {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF9F43;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  border: 2rpx solid #fff;
}

/* 加载状态 */
.loading-state, .empty-state, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部按钮 */
.bottom-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 12rpx 24rpx 24rpx;
  background: #fff;
  border-top: 2rpx solid #E0E0E0;
}

.btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.btn-secondary {
  background: #fff;
  color: #3D3D3D;
}

.btn-primary {
  background: #FF9F43;
  color: #fff;
}

.btn-primary.disabled {
  background: #CCC;
  color: #888;
  border-color: #999;
  box-shadow: 4rpx 4rpx 0 #999;
}
