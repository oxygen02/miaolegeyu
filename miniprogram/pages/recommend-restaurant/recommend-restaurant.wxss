@import "../../styles/variables.wxss";

/* ==================== 推荐餐厅页面 ==================== */

page {
  background: #F5F0E8;
  font-family: var(--font-family);
}

.recommend-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ---------- 加载状态 ---------- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 24rpx;
}

.loading-icon {
  width: 200rpx;
  height: 200rpx;
  animation: fishBounce 2s ease-in-out infinite;
}

@keyframes fishBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ---------- 顶部提示 ---------- */
.header-section {
  margin-bottom: 32rpx;
}

.cat-hint {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.cat-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #3D3D3D;
}

.speech-bubble {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
  position: relative;
}

.speech-bubble::before {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-right-color: #3D3D3D;
}

.bubble-text {
  font-size: 28rpx;
  color: #3D3D3D;
  font-weight: 600;
}

.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 100rpx;
}

.location-icon {
  width: 28rpx;
  height: 28rpx;
}

.location-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ---------- 口味偏好 ---------- */
.preference-section {
  margin-bottom: 32rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 16rpx;
}

.preference-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preference-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.preference-tag.top {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-color: #D4652A;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.tag-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ---------- 餐厅列表 ---------- */
.restaurant-section {
  margin-bottom: 32rpx;
}

.refresh-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  font-size: 24rpx;
  color: #3D3D3D;
}

.refresh-icon {
  font-size: 24rpx;
}

.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.restaurant-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.card-main {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.restaurant-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.restaurant-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3D3D;
  flex: 1;
}

.distance-tag {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid #4CAF50;
  flex-shrink: 0;
}

.distance-tag text {
  font-size: 22rpx;
  color: #2E7D32;
  font-weight: 600;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.rating-text {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 600;
}

.price-text {
  font-size: 26rpx;
  color: #E91E63;
  font-weight: 600;
}

.cuisine-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.address-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 3rpx solid #3D3D3D;
}

.navigate-btn {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.call-btn {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3D3D;
}

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  gap: 16rpx;
}

.empty-img {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3D3D;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.manual-search-btn {
  margin-top: 24rpx;
  background: #FF9F43;
  padding: 20rpx 48rpx;
  border-radius: 36rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.manual-search-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ---------- 底部提示 ---------- */
.footer-hint {
  text-align: center;
  padding: 32rpx 0;
}

.footer-hint text {
  font-size: 22rpx;
  color: #999;
}