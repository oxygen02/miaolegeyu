<view class="history-page">
  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">历史记录</text>
    <view class="clear-btn" bindtap="clearHistory" wx:if="{{historyList.length > 0}}">清空</view>
  </view>

  <!-- 历史列表 -->
  <scroll-view class="history-list" scroll-y="true" bindscrolltolower="loadMore">
    <view class="history-item" wx:for="{{historyList}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}" data-type="{{item.type}}">
      <image class="item-icon" src="../../assets/images/history.png" mode="aspectFit"/>
      <view class="item-content">
        <text class="item-title">{{item.title}}</text>
        <text class="item-time">{{item.time}}</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && historyList.length === 0}}">
      <image class="empty-icon" src="../../assets/images/history.png" mode="aspectFit"/>
      <text class="empty-text">暂无历史记录</text>
    </view>

    <!-- 到底提示 -->
    <view class="no-more" wx:if="{{!hasMore && historyList.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
