/* 页面容器 */
.modeb-page {
  height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFE4CC 100%);
  padding: 0;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  position: relative;
}

/* 顶部橘色背景区域 */
.modeb-header-bg {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  padding: 40rpx 32rpx;
  margin: 0;
  border-radius: 0;
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 猫尾巴 - 右下角 */
.modeb-header-bg::after {
  content: '';
  position: absolute;
  right: 0;
  bottom: -10rpx;
  width: 100rpx;
  height: 100rpx;
  background-image: url('https://636c-cloud1-d5ggnf5wh2d872f3c-1423896909.tcb.qcloud.la/banners/maoweiba.png');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: right bottom;
  opacity: 1;
  pointer-events: none;
  z-index: 2;
  transform: rotate(-10deg);
}

/* 头部 */
.modeb-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.cat-hint {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #666666;
  box-sizing: border-box;
}

.speech-bubble {
  background: var(--card);
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(212, 101, 42, 0.15);
  box-shadow: var(--shadow-card);
  position: relative;
}

.speech-bubble::before {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-right-color: var(--card);
}

.bubble-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF9F43;
}

.header-sub {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 页面内容区域 */
.modeb-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 0;
  overflow-y: auto;
}

/* 表单卡片 */
.form-card {
  padding: 32rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
  overflow-x: hidden;
}

.form-card:last-child {
  margin-bottom: 0;
}

.form-group {
  margin-bottom: 16rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text);
}

.location-picker,
.time-picker {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.picker-value.has-value {
  color: var(--text);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--soft);
  border-bottom: 3rpx solid var(--soft);
  transform: rotate(-45deg);
}

/* 字段行 - 聚餐标题和聚餐地点范围在同一行 */
.combined-fields {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 8rpx;
  padding: 12rpx 0;
}

.field-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.field-section .section-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.field-input {
  height: 72rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.location-content-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.location-input-compact {
  flex: 1;
  min-width: 0;
}

.location-map-btn-compact {
  width: 64rpx;
  height: 64rpx;
  background: var(--bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 日期行 - 聚餐时间和投票截止时间在同一行 */
.combined-dates {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 8rpx;
  padding: 12rpx 0;
}

.date-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.date-section .section-label {
font-size: 28rpx;
color: var(--text-secondary);
font-weight: 500;
}

/* 通用 section-label 样式 */
.section-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.date-inputs {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-inputs .input.small {
  flex: 1;
  min-width: 120rpx;
  max-width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 26rpx;
  padding: 0 4rpx;
  text-align: center;
  background: var(--bg);
  border-radius: 8rpx;
}

.separator {
  font-size: 28rpx;
  color: #8A8A8A;
}

.divider {
  width: 1rpx;
  background: rgba(0,0,0,0.1);
  margin: 0 8rpx;
}

/* 地点输入组件 */
.location-group {
  display: flex;
  flex-direction: column;
}

.location-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-input {
  flex: 1;
}

.location-map-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.location-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 房间密码输入框 */
.password-input-section {
  margin-top: -8rpx;
  margin-bottom: 16rpx;
}

.password-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.password-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding-left: 8rpx;
}

/* 决策说明 - 合并结果生效规则和流程说明 */
.decision-section {
  background: rgba(255, 159, 67, 0.2);
  border-radius: var(--radius-card);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.decision-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #D4652A;
  margin-bottom: 16rpx;
}

.decision-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.decision-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.decision-dot {
  width: 12rpx;
  height: 12rpx;
  background: #D4652A;
  border-radius: 50%;
  flex-shrink: 0;
}

.decision-text {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

/* 品类选择 - 紧凑布局，强制两行显示 */
.cuisine-options {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx 12rpx;
}

.cuisine-tag {
  padding: 16rpx 8rpx;
  background: var(--bg);
  border-radius: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  text-align: center;
  min-width: 0;
}

.cuisine-tag.selected {
  background: rgba(255, 159, 67, 0.2);
  border-color: #D4652A;
}

.cuisine-tag .tag-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.cuisine-tag.selected .tag-text {
  color: #D4652A;
  font-weight: 500;
}

/* 匿名投票和房间密码 - 同一行对齐 */
.switch-row-combined {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.switch-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.switch-control {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.switch-status {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.switch-divider {
width: 1rpx;
height: 60rpx;
background: rgba(0,0,0,0.1);
align-self: center;
}

/* 餐厅推荐开关 */
.recommend-switch-section {
  margin-top: 8rpx;
}

.recommend-switch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recommend-switch-title {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.recommend-switch-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.payment-options-compact {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.payment-options-compact .payment-option {
  flex: 1;
  padding: 16rpx 8rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  text-align: center;
  white-space: nowrap;
  min-width: 0;
}

.payment-options-compact .option-text {
  font-size: 24rpx;
  white-space: nowrap;
}

.switch-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 56rpx;
}

.switch-hint-compact {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 付费方式 */
.payment-options {
  display: flex;
  gap: 24rpx;
}

.payment-option {
  flex: 1;
  padding: 24rpx;
  background: var(--bg);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  text-align: center;
  transition: all 0.2s;
}

.payment-option.selected {
  background: rgba(255, 159, 67, 0.2);
  border-color: #D4652A;
}

.payment-option .option-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.payment-option.selected .option-text {
  color: #D4652A;
  font-weight: 500;
}

/* 开关样式 */
.switch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  display: block;
}

/* 底部按钮 - 粗边框风格 */
.bottom-panel {
  padding: 32rpx 0;
  flex-shrink: 0;
  margin-top: auto;
  margin-bottom: 0;
}

.submit-btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 20rpx 56rpx !important;
  margin: 0 auto !important;
}

.submit-btn.btn-disabled {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

.submit-btn::after {
  display: none !important;
}
