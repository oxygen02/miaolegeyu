.modeb-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.modeb-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.cat-hint {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.speech-bubble {
  background: var(--card);
  padding: 20rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(212, 101, 42, 0.15);
  box-shadow: var(--shadow-card);
  position: relative;
}

.speech-bubble::before {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-right-color: var(--card);
}

.bubble-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary);
}

.header-sub {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  padding: 40rpx;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text);
}

.location-picker,
.time-picker {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.picker-value.has-value {
  color: var(--text);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--soft);
  border-bottom: 3rpx solid var(--soft);
  transform: rotate(-45deg);
}

/* 流程说明 */
.flow-section {
  background: rgba(168, 216, 234, 0.15);
  border-radius: var(--radius-card);
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.flow-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--secondary);
  margin-bottom: 24rpx;
}

.flow-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.flow-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.flow-num {
  width: 44rpx;
  height: 44rpx;
  background: var(--secondary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.flow-text {
  font-size: 28rpx;
  color: var(--text);
}

/* 底部按钮 */
.bottom-panel {
  margin-top: auto;
  padding-top: 32rpx;
}

.submit-btn {
  width: 100%;
}
