/* 上传店铺页面 */
.upload-shop-page {
  height: 100vh;
  background: #FFF8F0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部标题 */
.header-section {
  background: linear-gradient(180deg, #FF9F43 0%, #FFB347 100%);
  padding: 16rpx 32rpx;
  flex-shrink: 0;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

/* 表单区域 */
.form-section {
  padding: 16rpx 24rpx;
  flex: 1;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-item.required .form-label::before {
  content: '* ';
  color: #FF6B6B;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

/* 合并行 */
.form-row {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.form-row .form-item {
  flex: 1;
  margin-bottom: 16rpx;
}

.flex-1 {
  flex: 1 !important;
}

.flex-2 {
  flex: 2 !important;
}

/* 输入框 - 统一高度 72rpx */
.form-input {
  background: #fff;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #f0f0f0;
  height: 72rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

/* 价格输入 - 统一高度 72rpx */
.price-input-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 8rpx;
  padding: 0 16rpx;
  border: 2rpx solid #f0f0f0;
  height: 72rpx;
  box-sizing: border-box;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-input {
  flex: 1;
  border: none;
  padding-left: 8rpx;
  font-size: 28rpx;
  height: 100%;
}

/* 文本域 */
.form-textarea {
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #f0f0f0;
  width: 100%;
  min-height: 80rpx;
  box-sizing: border-box;
}

.form-textarea.small {
  min-height: 72rpx;
  height: 72rpx;
  line-height: 36rpx;
  padding: 10rpx 16rpx;
}

/* 图片上传区域 */
.image-upload-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  border: 2rpx dashed #FF9F43;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  display: block;
}

.delete-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #FF6B6B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

/* 添加图片按钮 */
.add-image-item {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #FF9F43;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,159,67,0.05);
}

.add-icon {
  font-size: 56rpx;
  color: #FF9F43;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #FF9F43;
  margin-top: 4rpx;
}

.image-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
  text-align: center;
}

/* 菜系标签 */
.cuisine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cuisine-tag-item {
  padding: 10rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s;
  white-space: nowrap;
}

.cuisine-tag-item.active {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  color: #fff;
  font-weight: 600;
  border-color: #FF9F43;
}

.cuisine-tag-item.custom {
  border-style: dashed;
  color: #FF9F43;
}

/* 装饰Logo - 喵了个鱼 */
.decoration-logo {
  display: flex;
  justify-content: flex-end;
  margin: -30rpx 0 -50rpx 0;
  padding-right: 60rpx;
  position: relative;
  z-index: 1;
  pointer-events: none;
}

.logo-image {
  width: 140rpx;
  height: 140rpx;
  animation: float 3s ease-in-out infinite;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% {
    transform: translateY(0rpx) rotate(0deg);
  }
  25% {
    transform: translateY(-8rpx) rotate(2deg);
  }
  50% {
    transform: translateY(0rpx) rotate(0deg);
  }
  75% {
    transform: translateY(-4rpx) rotate(-2deg);
  }
}

/* 推荐指数 */
.rating-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating-header .form-label {
  margin-bottom: 0;
}

.rating-text {
  font-size: 26rpx;
  color: #FF9F43;
  font-weight: 600;
}

.paw-rating {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  border: 2rpx solid #f0f0f0;
}

/* 紧凑版推荐指数（用于并列布局） */
.paw-rating.compact {
  gap: 8rpx;
  padding: 0 12rpx;
  height: 72rpx;
  align-items: center;
  justify-content: center;
}

.paw-item {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paw-rating.compact .paw-item {
  width: 44rpx;
  height: 44rpx;
}

.paw-image {
  width: 52rpx;
  height: 52rpx;
  opacity: 0.3;
  filter: grayscale(100%);
  transition: all 0.2s;
}

.paw-rating.compact .paw-image {
  width: 40rpx;
  height: 40rpx;
}

.paw-item.active .paw-image {
  opacity: 1;
  filter: grayscale(0%);
}

/* 匿名选项 */
.anonymous-item {
  background: #fff;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
}

.anonymous-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.anonymous-wrapper .form-label {
  margin-bottom: 0;
}

.anonymous-switch {
  transform: scale(0.85);
}

/* 底部按钮 */
.button-section {
  padding: 32rpx 0;
  flex-shrink: 0;
  margin-top: auto;
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.cancel-btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #f5f5f5 !important;
  color: #666 !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 20rpx 48rpx !important;
  margin: 0 !important;
}

.cancel-btn::after {
  display: none !important;
}

.submit-btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 20rpx 56rpx !important;
  margin: 0 !important;
}

.submit-btn::after {
  display: none !important;
}

.submit-btn.disabled {
  background: #ccc !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

/* 地点输入组件 - 支持文字输入和地图选择 */
.location-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-group .form-label {
  flex-shrink: 0;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.location-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.location-input {
  flex: 1;
  text-align: left;
  min-width: 200rpx;
}

.location-map-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.location-icon {
  width: 48rpx;
  height: 48rpx;
}
