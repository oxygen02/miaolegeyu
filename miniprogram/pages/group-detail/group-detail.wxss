.container {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 24rpx;
  box-sizing: border-box;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

/* 标题区域 */
.header-section {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  position: relative;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 20rpx;
}

.participants-count {
  display: inline-flex;
  align-items: baseline;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.count-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.count-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 选项区域 */
.options-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 20rpx;
  display: block;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  transition: all 0.2s ease;
}

.option-card.selected {
  border-color: #FF9F43;
  background: #FFF8F0;
}

.option-card.joined {
  border-color: #4CAF50;
  background: #F1F8E9;
}

.option-image-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #3D3D3D;
  flex-shrink: 0;
}

.option-image {
  width: 100%;
  height: 100%;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.option-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.option-badge {
  background: #4CAF50;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.option-platform {
  font-size: 26rpx;
  color: #666;
}

.option-deadline {
  font-size: 24rpx;
  color: #999;
}

.option-stats {
  margin-top: 8rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #FF9F43;
  font-weight: 500;
}

.progress-bar {
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #FF9F43;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 操作区域 */
.action-section {
  padding: 32rpx 0;
  flex-shrink: 0;
  margin-top: auto;
}

.btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  text-align: center;
  padding: 20rpx 56rpx !important;
  margin: 0 auto !important;
}

.btn::after {
  display: none !important;
}

.btn-primary {
  background: #FF9F43 !important;
  color: #fff !important;
}

.btn-primary[disabled] {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

.btn-success {
  background: #4CAF50;
  color: #fff;
}

.btn-success[disabled] {
  background: #81C784;
  color: #fff;
  border-color: #4CAF50;
  box-shadow: 4rpx 4rpx 0 #4CAF50;
}

.btn-loading {
  opacity: 0.8;
}

/* 提示信息 */
.tips-section {
  margin-top: 24rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
}
