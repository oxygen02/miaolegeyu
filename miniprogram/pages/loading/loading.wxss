.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFF8F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF9F43;
  letter-spacing: 8rpx;
}
