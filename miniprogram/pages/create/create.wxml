<view class="create-page">
  <!-- 顶部渐变区域 -->
  <view class="header-section">
    <view class="header-content">
      <text class="page-title">聚餐发起</text>
      <text class="page-subtitle">选择一种方式开始</text>
    </view>

    <!-- 猫尾巴装饰 -->
    <image class="header-tail" src="{{imagePaths.banners.maoweiba}}" mode="aspectFit" />
  </view>

  <!-- 模式选择卡片 - 蜡笔风格 -->
  <view class="mode-list">
    <!-- 约个时间 -->
    <view class="mode-card crayon-card anim-fade-in-up delay-50" bindtap="goScheduleVote">
      <view class="card-bg icon-schedule"></view>
      <view class="mode-icon">
        <image class="mode-icon-image" src="{{imagePaths.banners.jucanfaqi1}}" mode="aspectFit" />
      </view>
      <view class="mode-content">
        <text class="mode-title">约个时间</text>
        <view class="mode-desc">
          <text class="mode-desc-line">大家时间不确定？</text>
          <text class="mode-desc-line">先投票选出公共时间</text>
        </view>
      </view>
      <image class="mode-arrow" src="{{imagePaths.icons.daohang}}" mode="aspectFit"/>
      <view class="crayon-border"></view>
    </view>

    <!-- 模式A -->
    <view class="mode-card crayon-card anim-fade-in-up delay-100" bindtap="goModeA">
      <view class="card-bg icon-a"></view>
      <view class="mode-icon">
        <image class="mode-icon-image" src="{{imagePaths.banners.jucanfaqi2}}" mode="aspectFit" />
      </view>
      <view class="mode-content">
        <text class="mode-title">我选好了</text>
        <view class="mode-desc">
          <text class="mode-desc-line">已看好2-6家店，</text>
          <text class="mode-desc-line">大家直接投票选</text>
        </view>
      </view>
      <image class="mode-arrow" src="{{imagePaths.icons.daohang}}" mode="aspectFit"/>
      <view class="crayon-border"></view>
    </view>

    <!-- 模式B -->
    <view class="mode-card crayon-card anim-fade-in-up delay-200" bindtap="goModeB">
      <view class="card-bg icon-b"></view>
      <view class="mode-icon">
        <image class="mode-icon-image" src="{{imagePaths.banners.jucanfaqi3}}" mode="aspectFit" />
      </view>
      <view class="mode-content">
        <text class="mode-title">你们来定</text>
        <view class="mode-desc">
          <text class="mode-desc-line">不确定去哪，</text>
          <text class="mode-desc-line">大家先选口味偏好</text>
        </view>
      </view>
      <image class="mode-arrow" src="{{imagePaths.icons.daohang}}" mode="aspectFit"/>
      <view class="crayon-border"></view>
    </view>

  </view>

  <!-- 底部导航栏 -->
  <view class="page-tab-bar">
    <view class="page-tab-bar-container">
      <view class="page-tab-bar-item" data-index="0" bindtap="switchTab">
        <view class="page-icon-wrapper">
          <image class="page-tab-icon" src="{{imagePaths.misc.pawHomeIcon}}" mode="aspectFit" />
        </view>
        <text class="page-tab-text">首页</text>
      </view>
      <view class="page-tab-bar-item" data-index="1" bindtap="switchTab">
        <view class="page-icon-wrapper">
          <image class="page-tab-icon" src="{{imagePaths.decorations.catAvatarIcon}}" mode="aspectFit" />
        </view>
        <text class="page-tab-text">喵不喵</text>
      </view>
      <view class="page-tab-bar-item" data-index="2" bindtap="switchTab">
        <view class="page-icon-wrapper">
          <image class="page-tab-icon" src="{{imagePaths.misc.fishIcon}}" mode="aspectFit" />
        </view>
        <text class="page-tab-text">我的</text>
      </view>
    </view>
  </view>
</view>
