<view class="create-page">
  <!-- 顶部渐变区域 -->
  <view class="header-section">
    <view class="header-content">
      <text class="page-title">发起聚餐</text>
      <text class="page-subtitle">选择一种方式开始</text>
    </view>
    
    <!-- 装饰猫爪 -->
    <view class="paw-decoration">
      <view class="paw p1">🐾</view>
      <view class="paw p2">🐾</view>
    </view>
  </view>

  <!-- 波浪分割线 -->
  <view class="wave-divider">
    <view class="wave"></view>
  </view>

  <!-- 模式选择卡片 - 蜡笔风格 -->
  <view class="mode-list">
    <!-- 模式A -->
    <view class="mode-card crayon-card anim-fade-in-up delay-100" bindtap="goModeA">
      <view class="card-bg icon-a"></view>
      <view class="mode-icon">
        <image class="mode-icon-image" src="/assets/images/wotiaohaole1.png" mode="aspectFit" />
      </view>
      <view class="mode-content">
        <text class="mode-title">我挑好了</text>
        <view class="mode-desc">
          <text class="mode-desc-line">已看好2-6家店，</text>
          <text class="mode-desc-line">大家直接投票选</text>
        </view>
      </view>
      <view class="mode-arrow"></view>
      <view class="crayon-border"></view>
    </view>

    <!-- 模式B -->
    <view class="mode-card crayon-card anim-fade-in-up delay-200" bindtap="goModeB">
      <view class="card-bg icon-b"></view>
      <view class="mode-icon">
        <image class="mode-icon-image" src="/assets/images/nimenlaiding2.png" mode="aspectFit" />
      </view>
      <view class="mode-content">
        <text class="mode-title">你们来定</text>
        <view class="mode-desc">
          <text class="mode-desc-line">不确定去哪，</text>
          <text class="mode-desc-line">大家先选口味偏好</text>
        </view>
      </view>
      <view class="mode-arrow"></view>
      <view class="crayon-border"></view>
    </view>

  </view>

  <!-- 模拟投票场景 -->
  <view class="preview-section">
    <view class="preview-title">模拟投票场景</view>
    <view class="preview-buttons">
      <button class="btn-preview btn-mode-a" bindtap="previewVoteModeA">模式A：选饭店</button>
      <button class="btn-preview btn-mode-b" bindtap="previewVoteModeB">模式B：选偏好</button>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decoration">
    <image class="paw-print paw1" src="/assets/images/singleclaw.png" mode="aspectFit" />
    <image class="paw-print paw2" src="/assets/images/singleclaw.png" mode="aspectFit" />
    <image class="paw-print paw3" src="/assets/images/singleclaw.png" mode="aspectFit" />
  </view>
</view>
