/* ==================== 创建页 - 蜡笔像素风 ==================== */
@import "../../styles/variables.wxss";
@import "../../styles/animations.wxss";

.create-page {
  min-height: 100vh;
  background: var(--color-bg);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ---------- 顶部区域 ---------- */
.header-section {
  position: relative;
  background: linear-gradient(180deg, #FF9F43 0%, #FFB347 70%, #FFC875 100%);
  padding: 60rpx 32rpx 80rpx;
  overflow: visible;
}

/* 背景装饰 */
.header-section::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 2;
}

.page-title {
  display: block;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-top: 20rpx;
  text-shadow:
    0 2rpx 0 rgba(0, 0, 0, 0.1),
    0 4rpx 8rpx rgba(0, 0, 0, 0.2),
    0 8rpx 16rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 8rpx;
  transform: rotate(-1deg);
  -webkit-text-stroke: 2rpx rgba(255, 255, 255, 0.3);
}

.page-subtitle {
  display: block;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
  text-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.15),
    0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}


/* 猫尾巴装饰 */
.header-tail {
  width: 120rpx;
  height: 120rpx;
  position: absolute;
  right: -10rpx;
  bottom: 0;
  z-index: 2;
}

/* ---------- 模式列表 ---------- */
.mode-list {
  padding: 40rpx 32rpx 180rpx;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 功能卡片 - 方片样式 */
.crayon-card {
  position: relative;
  border-radius: 32rpx;
  /* 上左细，下右粗 */
  border-top: 4rpx solid #3D3D3D;
  border-left: 4rpx solid #3D3D3D;
  border-bottom: 10rpx solid #3D3D3D;
  border-right: 10rpx solid #3D3D3D;
  box-shadow:
    6rpx 8rpx 0 rgba(61, 61, 61, 0.2),
    12rpx 16rpx 24rpx rgba(61, 61, 61, 0.12);
  padding: 52rpx 40rpx;
  display: flex;
  align-items: center;
  transition: all 0.15s ease;
  overflow: hidden;
}

/* 四个卡片的不同背景色 */
.mode-card:nth-child(1) {
  background: #FFF5F0;
}

.mode-card:nth-child(2) {
  background: #FFF8F0;
}

.mode-card:nth-child(3) {
  background: #E8F8F5;
}

.mode-card:nth-child(4) {
  background: #F0F4FF;
}

.crayon-card:active {
  transform: translateY(8rpx);
  box-shadow: none;
}

/* 移除旧的蜡笔边框 */
.crayon-border {
  display: none;
}

/* 卡片背景图标 */
.card-bg {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 160rpx;
  height: 160rpx;
  opacity: 0.05;
  border-radius: 50%;
}

.card-bg.icon-a {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
}

.card-bg.icon-b {
  background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
}

.card-bg.icon-group {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-bg.icon-schedule {
  background: linear-gradient(135deg, #FF9F43 0%, #FF6B6B 100%);
}

/* 模式图标 */
.mode-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.mode-icon-image {
  width: 88rpx;
  height: 88rpx;
}

.mode-card:nth-child(1) .mode-icon {
  background: #FFF5E9;
}

.mode-card:nth-child(2) .mode-icon {
  background: #E0F2F1;
}

.mode-card:nth-child(3) .mode-icon {
  background: #E8F4FD;
}

.icon-emoji {
  font-size: 48rpx;
}

/* 模式内容 */
.mode-content {
  flex: 1;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.mode-title {
  display: block;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.mode-desc {
  display: flex;
  flex-direction: column;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.mode-desc-line {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* 箭头 - 使用CSS绘制粗边框箭头 */
.mode-arrow {
  width: 64rpx;
  height: 64rpx;
  margin-left: 20rpx;
  transition: all 0.3s;
}

.crayon-card:active .mode-arrow {
  transform: translateX(4rpx);
}

/* ---------- 底部导航栏 ---------- */
.page-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #FFF8F0;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  box-sizing: border-box;
  padding: 0 0 calc(20rpx + constant(safe-area-inset-bottom)) 0;
  padding: 0 0 calc(20rpx + env(safe-area-inset-bottom)) 0;
  z-index: 99999;
}

.page-tab-bar-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: calc(100% - 64rpx);
  height: 120rpx;
  background: #fff;
  border-radius: 24rpx;
  border-top: 4rpx solid #3D3D3D;
  border-left: 4rpx solid #3D3D3D;
  border-bottom: 8rpx solid #3D3D3D;
  border-right: 8rpx solid #3D3D3D;
  box-shadow:
    4rpx 6rpx 0 rgba(61, 61, 61, 0.15),
    8rpx 12rpx 20rpx rgba(61, 61, 61, 0.1);
  padding: 0 20rpx;
  box-sizing: border-box;
}

.page-tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100rpx;
  padding-bottom: 8rpx;
}

.page-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

.page-tab-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  filter: grayscale(100%);
  opacity: 0.5;
}

.page-tab-text {
  font-size: 22rpx;
  color: #999;
  font-weight: 600;
}

/* ---------- 底部提示 ---------- */
.glass-tips {
  margin: 0 32rpx 32rpx;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid rgba(255, 159, 67, 0.1);
}

.tips-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ---------- 预览按钮区域 ---------- */
.preview-section {
  margin: 0 32rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.preview-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-preview {
  background: transparent;
  border: 2rpx solid rgba(255, 159, 67, 0.5);
  color: #FF9F43;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.btn-preview::after {
  border: none;
}

.btn-preview:active {
  background: rgba(255, 159, 67, 0.1);
  transform: scale(0.96);
}

.btn-mode-a {
  border-color: rgba(255, 159, 67, 0.5);
  color: #FF9F43;
}

.btn-mode-b {
  border-color: rgba(78, 205, 196, 0.5);
  color: #4ECDC4;
}

