/* pages/create-mode-a/create-mode-a.wxss */
page {
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100vh;
  background: #F5F0E8;
  padding: 16rpx 24rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8A8A8A;
}

/* 海报上传区 */
.poster-section {
  margin-bottom: 24rpx;
}

.poster-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.poster-item {
  position: relative;
  aspect-ratio: 3/4;
  border-radius: 12rpx;
  overflow: hidden;
  background: #FFFDF7;
  border: 2rpx solid rgba(212, 101, 42, 0.2);
}

.poster-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.poster-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 8rpx;
  background: rgba(0, 0, 0, 0.5);
}

.action-btn {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 10rpx;
}

.action-btn.delete {
  color: #FF6B6B;
}

.add-poster {
  aspect-ratio: 3/4;
  border-radius: 12rpx;
  border: 2rpx dashed #D4652A;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(212, 101, 42, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #D4652A;
  font-weight: 300;
}

.add-text {
  font-size: 24rpx;
  color: #D4652A;
  margin-top: 8rpx;
}

.add-hint {
  font-size: 20rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}

/* 表单 */
.form {
  margin-bottom: 16rpx;
  flex: 1;
  overflow: hidden;
}

.form-item {
  background: #FFFDF7;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
}

.label {
  font-size: 30rpx;
  color: #3D3D3D;
  flex-shrink: 0;
  margin-right: 20rpx;
  width: 120rpx;
  text-align: left;
  display: inline-block;
}

/* 地点选择项 */
.location-item {
  padding: 20rpx 24rpx;
}

.location-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.location-input {
  flex: 1;
  text-align: left;
  font-size: 28rpx;
  height: 56rpx;
  line-height: 56rpx;
  min-width: 200rpx;
}

.location-map-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.location-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 人数输入框样式 */
.people-input {
  width: 100rpx;
  text-align: right;
  font-size: 30rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #3D3D3D;
  text-align: right;
  height: 56rpx;
  line-height: 56rpx;
}

.input.small {
  flex: 0 0 100rpx;
  text-align: center;
  background: #F5F0E8;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  font-size: 28rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.combined-inputs {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.separator {
  font-size: 28rpx;
  color: #8A8A8A;
}

/* 地点和人数 - 同一行 */
.location-people-row {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 6rpx;
  padding: 8rpx 6rpx;
}

.location-people-row .field-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-people-row .section-label {
  font-size: 26rpx;
  color: #3D3D3D;
  font-weight: 500;
}

.location-people-row .divider {
  width: 2rpx;
  background: rgba(61, 61, 61, 0.1);
  margin: 0 8rpx;
}

.location-content-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.location-input-compact {
  flex: 1;
  font-size: 24rpx;
  height: 36rpx;
  background: #F5F0E8;
  border-radius: 6rpx;
  padding: 0 10rpx;
}

.location-map-btn-compact {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.location-map-btn-compact .location-icon {
  width: 28rpx;
  height: 28rpx;
}

.people-input-compact {
  width: 100%;
  font-size: 24rpx;
  height: 36rpx;
  background: #F5F0E8;
  border-radius: 6rpx;
  padding: 0 10rpx;
  text-align: left !important;
}

.separator.gap {
  margin: 0 16rpx;
}

/* 日期行 - 活动和截止在同一行 */
.dates-row {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 8rpx;
  padding: 20rpx 8rpx;
}

.date-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.section-label {
  font-size: 28rpx;
  color: #3D3D3D;
  font-weight: 500;
  white-space: nowrap;
}

.date-inputs {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.date-inputs .input.small {
  flex: 1;
  min-width: 140rpx;
  max-width: 160rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 22rpx;
  padding: 8rpx 2rpx;
  text-align: center;
  overflow: visible;
  white-space: nowrap;
}

.divider {
  width: 1rpx;
  background: #E0E0E0;
  margin: 8rpx 4rpx;
  flex-shrink: 0;
}

.value {
  font-size: 30rpx;
  color: #8A8A8A;
  text-align: right;
  flex: 1;
}

/* 按钮 - 粗边框风格 */
.btn-create {
  display: block;
  width: fit-content;
  height: auto;
  line-height: 1;
  background: #FF9F43;
  color: #fff;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0 auto 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  padding: 20rpx 48rpx;
  flex-shrink: 0;
}

.btn-create.disabled {
  background: #CCC;
  color: #888;
  border-color: #999;
  box-shadow: 4rpx 4rpx 0 #999;
}

/* 弹窗 */
.popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: relative;
  background: #FFFDF7;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx;
  width: 100%;
}

.popup-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 32rpx;
  text-align: center;
}

.platform-options {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.platform-opt {
  flex: 1;
  height: 120rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  color: #3D3D3D;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #D4652A;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}
