<view class="page modea-page anim-page-enter">
  <!-- 顶部橘色背景区域 -->
  <view class="modea-header-bg">
    <!-- 头部：橘仔提示 -->
    <view class="modea-header">
      <view class="cat-hint anim-breathe">
        <image class="cat-img" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFit" />
        <view class="speech-bubble">
          <text class="bubble-text">我选好了</text>
        </view>
      </view>
      <text class="header-sub">上传美团/大众点评海报，让大家投票</text>
    </view>
  </view>

  <!-- 页面内容区域 -->
  <view class="modea-content">

  <!-- 表单卡片 - 使用"你们来定"的字段布局 -->
  <view class="form-card card anim-slide-up" style="animation-delay:0.1s">
    <!-- 聚餐标题和聚餐地点范围 - 同一行 -->
    <view class="form-group combined-fields">
      <view class="field-section">
        <text class="section-label">聚餐标题</text>
        <input class="input field-input" placeholder="如：周五部门聚餐" value="{{title}}" bindinput="onTitleInput" />
      </view>
      <view class="divider"></view>
      <view class="field-section location-section">
        <text class="section-label">聚餐地点范围</text>
        <view class="location-content-compact">
          <input 
            class="input field-input location-input-compact" 
            placeholder="如：朝阳区" 
            value="{{locationText}}"
            bindinput="onLocationInput"
          />
          <view class="location-map-btn-compact" bindtap="onChooseLocation">
            <image class="location-icon" src="{{imagePaths.icons.location}}" mode="aspectFit"/>
          </view>
        </view>
      </view>
    </view>

    <!-- 聚餐时间和投票截止时间 - 同一行 -->
    <view class="form-group combined-dates">
      <view class="date-section">
        <text class="section-label">聚餐时间</text>
        <view class="date-inputs">
          <input class="input small" type="text" maxlength="6" placeholder="月日" bindinput="onDinnerDateInput" bindblur="onDinnerDateBlur" value="{{dinnerDate}}"/>
          <text class="separator">|</text>
          <input class="input small" type="text" maxlength="6" placeholder="时分" bindinput="onDinnerTimeInput" bindblur="onDinnerTimeBlur" value="{{dinnerTime}}"/>
        </view>
      </view>
      <view class="divider"></view>
      <view class="date-section">
        <text class="section-label">投票截止时间</text>
        <view class="date-inputs">
          <input class="input small" type="text" maxlength="6" placeholder="月日" bindinput="onDeadlineDateInput" bindblur="onDeadlineDateBlur" value="{{deadlineDate}}"/>
          <text class="separator">|</text>
          <input class="input small" type="text" maxlength="6" placeholder="时分" bindinput="onDeadlineTimeInput" bindblur="onDeadlineTimeBlur" value="{{deadlineTime}}"/>
        </view>
      </view>
    </view>

    <!-- 打开付款码 - 单独一行 -->
    <view class="form-group">
      <text class="section-label">打开付款码的姿势</text>
      <view class="payment-options-compact">
        <view class="payment-option {{paymentMode === 'AA' ? 'selected' : ''}}" data-mode="AA" bindtap="onPaymentModeChange">
          <text class="option-text">AA平摊</text>
        </view>
        <view class="payment-option {{paymentMode === 'treat' ? 'selected' : ''}}" data-mode="treat" bindtap="onPaymentModeChange">
          <text class="option-text">喵大佬请客</text>
        </view>
      </view>
    </view>

    <!-- 匿名投票和房间密码 - 同一行对齐 -->
    <view class="form-group switch-row-combined">
      <view class="switch-item">
        <text class="switch-label">匿名投票</text>
        <view class="switch-control">
          <switch checked="{{isAnonymous}}" bindchange="onAnonymousChange" color="#D4652A" />
          <text class="switch-status">{{isAnonymous ? '已开启' : '已关闭'}}</text>
        </view>
      </view>
      <view class="switch-divider"></view>
      <view class="switch-item">
        <text class="switch-label">房间密码</text>
        <view class="switch-control">
          <switch checked="{{needPassword}}" bindchange="onPasswordSwitchChange" color="#D4652A" />
          <text class="switch-status">{{needPassword ? '已开启' : '已关闭'}}</text>
        </view>
      </view>
    </view>

    <!-- 房间密码输入框 -->
    <view class="form-group password-input-section" wx:if="{{needPassword}}">
      <input 
        class="input password-input" 
        type="text" 
        maxlength="6"
        placeholder="请输入4-6位密码" 
        value="{{roomPassword}}"
        bindinput="onPasswordInput"
      />
      <text class="password-hint">加入房间时需要输入此密码</text>
    </view>

    <!-- 海报上传区 - 放在卡片底部 -->
    <view class="form-group poster-section">
      <text class="section-label">上传海报（{{posters.length}}/6）</text>
      <view class="poster-grid">
        <view class="poster-item" wx:for="{{posters}}" wx:key="index">
          <image class="poster-img" src="{{item.tempFilePath || item.imageUrl}}" mode="aspectFill"/>
          <view class="poster-actions">
            <text class="action-btn" bindtap="markPlatform" data-index="{{index}}">标记</text>
            <text class="action-btn delete" bindtap="removePoster" data-index="{{index}}">删除</text>
          </view>
        </view>
        <view class="add-poster" bindtap="addPoster" wx:if="{{posters.length < 6}}">
          <text class="add-icon">+</text>
          <text class="add-text">添加</text>
        </view>
      </view>
    </view>
  </view>

  </view>

  <!-- 底部按钮 -->
  <view class="bottom-panel safe-bottom">
    <button class="btn btn-primary submit-btn {{canSubmit ? '' : 'btn-disabled'}}" bindtap="createRoom">
      生成房间
    </button>
  </view>

  <!-- 平台选择弹窗 -->
  <view class="popup" wx:if="{{showPlatformPopup}}">
    <view class="popup-mask" bindtap="closePopup"></view>
    <view class="popup-content">
      <text class="popup-title">选择平台来源</text>
      <view class="platform-options">
        <view class="platform-opt" bindtap="selectPlatform" data-platform="meituan">
          <text>美团</text>
        </view>
        <view class="platform-opt" bindtap="selectPlatform" data-platform="dianping">
          <text>大众点评</text>
        </view>
      </view>
      <button class="btn-confirm" bindtap="confirmPlatform">确定</button>
    </view>
  </view>
</view>
