/* === 填写可用时间页面 - 矩阵选择版 === */

.schedule-fill-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 0 32rpx calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 加载 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 顶部 - 居中 */
.header-section {
  padding: 24rpx 0 16rpx;
  text-align: center;
}

.vote-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10rpx;
  display: block;
}

.vote-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
  display: block;
}

/* 发起人信息 */
.vote-creator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.creator-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #E0E0E0;
  background: #F5F5F5;
}

.creator-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 标签 - 居中 */
.vote-meta {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.meta-tag {
  background: rgba(255, 159, 67, 0.12);
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.meta-tag.tag-anonymous {
  background: rgba(155, 89, 182, 0.12);
  color: var(--purple);
}

/* 矩阵区域 - 像素风外边框 */
.matrix-section {
  margin-top: 16rpx;
  padding: 0;
  background: #fff;
  border-radius: 16rpx;
  border-top: 4rpx solid #8A8A8A;
  border-left: 4rpx solid #8A8A8A;
  border-bottom: 8rpx solid #8A8A8A;
  border-right: 8rpx solid #8A8A8A;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  overflow: hidden;
}

/* 表头 */
.matrix-header {
  display: flex;
  background: #F0F0F0;
  border-bottom: 2rpx solid #E0E0E0;
}

.header-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 18rpx 4rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 700;
  border-right: 1rpx solid #E0E0E0;
}

.header-cell:last-child {
  border-right: none;
}

.header-cell.header-date {
  flex: 1.2;
  font-weight: 700;
  color: var(--text);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.header-main {
  font-size: 30rpx;
  font-weight: 700;
}

.header-sub {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: var(--primary);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

/* 表头级别颜色 */
.header-cell.level-conflict { background: #E8E8E8; color: #666; }
.header-cell.level-uncertain { background: #F5ECD8; color: #8B6914; }
.header-cell.level-ok { background: #D8E8DE; color: #2E7D32; }
.header-cell.level-best { background: #FFE8D0; color: #D35400; }

/* 日期行 */
.matrix-row {
  display: flex;
  border-bottom: 1rpx solid #F0F0F0;
  min-height: 110rpx;
}

.matrix-row:last-child {
  border-bottom: none;
}

/* 单元格 */
.matrix-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #F0F0F0;
  transition: all 0.15s;
}

.matrix-cell:last-child {
  border-right: none;
}

/* 日期列 */
.cell-date {
  flex: 1.2;
  flex-direction: column;
  position: relative;
  padding: 12rpx 4rpx;
  background: #FAFAFA;
}

/* 日期列颜色区分 */
.cell-date.saturday { background: #EDF4F9; }
.cell-date.sunday { background: #F9ECEC; }
.cell-date.holiday { background: #ECF5F0; }
.cell-date.workday { background: #F9ECEC; }

/* 冲突标记 */
.cell-date.has-conflict {
  position: relative;
}

.conflict-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 28rpx;
  height: 28rpx;
  background: #E74C3C;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.date-tag {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  font-size: 18rpx;
  font-weight: 600;
  padding: 0rpx 6rpx;
  border-radius: 4rpx;
  background: #E0E0E0;
  color: #999;
  line-height: 1.4;
}

/* 节假日/调休标签 */
.cell-date.holiday .date-tag { background: #27AE60; color: #fff; }
.cell-date.workday .date-tag { background: #E74C3C; color: #fff; }

.date-weekday {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 2rpx;
}

.date-monthday {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

/* 周末/节假日文字色 */
.cell-date.saturday .date-monthday { color: #5A8BA6; }
.cell-date.sunday .date-monthday { color: #C06C6C; }
.cell-date.holiday .date-monthday { color: #6BA88A; }
.cell-date.workday .date-monthday { color: #C06C6C; }

/* 级别列基础背景 */
.cell-level {
  min-height: 110rpx;
  background: transparent;
}

.cell-level.level-conflict { background: #F8F8F8; }
.cell-level.level-uncertain { background: #FDF9F0; }
.cell-level.level-ok { background: #F5FAF7; }
.cell-level.level-best { background: #FFFAF5; }

.cell-level:active {
  opacity: 0.7;
}

/* 选中态 */
.cell-level.level-conflict.active {
  background: #E8E8E8;
}

.cell-level.level-uncertain.active {
  background: #F5ECD8;
}

.cell-level.level-ok.active {
  background: #D8E8DE;
}

.cell-level.level-best.active {
  background: #FFE8D0;
}

/* 猫爪图标 */
.claw-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}

/* 图例栏 */
.legend-bar {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding: 20rpx 0 8rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
}

.legend-box.level-conflict.active { background: #E8E8E8; border-color: #D0D0D0; }
.legend-box.level-uncertain.active { background: #F5ECD8; border-color: #E0D0B0; }
.legend-box.level-ok.active { background: #D8E8DE; border-color: #B8D0C0; }
.legend-box.level-best.active { background: #FFE8D0; border-color: #F0C8A0; }

.legend-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 提示文字 */
.hint-text {
  text-align: center;
  padding: 16rpx 0 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.hint-num {
  color: var(--primary);
  font-weight: 700;
}

/* 底部装饰背景图 */
.bottom-decoration {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 40rpx 0 20rpx;
  min-height: 240rpx;
}

.deco-bg-img {
  width: 320rpx;
  height: 320rpx;
  opacity: 0.3;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: linear-gradient(to top, var(--bg) 80%, transparent);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bottom-actions .btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 18rpx 48rpx !important;
  margin: 0 auto !important;
}

.bottom-actions .btn.btn-secondary {
  background: transparent !important;
  color: var(--text-secondary) !important;
  border: none !important;
  box-shadow: none !important;
  font-size: 26rpx !important;
  padding: 12rpx 48rpx !important;
}

.bottom-actions .btn.btn-disabled {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

.bottom-actions .btn::after {
  display: none !important;
}
