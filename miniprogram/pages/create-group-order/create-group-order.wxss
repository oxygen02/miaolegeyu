.group-page {
  height: 100vh;
  background: var(--bg);
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

/* 头部 */
.group-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.cat-hint {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cat-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.speech-bubble {
  background: var(--card);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(212, 101, 42, 0.15);
  box-shadow: var(--shadow-card);
  position: relative;
}

.speech-bubble::before {
  content: '';
  position: absolute;
  left: -10rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 6rpx solid transparent;
  border-right-color: var(--card);
}

.bubble-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.header-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  padding: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.form-group {
  margin-bottom: 16rpx;
}

.form-group.half {
  flex: 1;
  margin-bottom: 0;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.form-input {
  height: 72rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--text);
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.currency {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-input {
  flex: 1;
  height: 100%;
  background: transparent;
  padding: 0;
}

.time-picker {
  height: 72rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.picker-value.has-value {
  color: var(--text);
}

.picker-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid var(--soft);
  border-bottom: 3rpx solid var(--soft);
  transform: rotate(-45deg);
}

/* 平台选择 */
.platform-list {
  display: flex;
  gap: 16rpx;
  height: 72rpx;
}

.platform-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
  padding: 8rpx;
}

.platform-item.active {
  border-color: var(--primary);
  background: rgba(212, 101, 42, 0.06);
}

.platform-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
}

/* 店铺图片上传 */
.shop-image-section {
  display: flex;
  align-items: center;
}

.shop-image-upload {
  width: 160rpx;
  height: 120rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 2rpx dashed var(--soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 40rpx;
  color: var(--soft);
  font-weight: 300;
}

.upload-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.shop-image-preview {
  position: relative;
  width: 160rpx;
  height: 120rpx;
}

.shop-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 店铺链接输入 */
.link-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link-input {
  flex: 1;
}

.paste-btn {
  padding: 0 24rpx;
  height: 72rpx;
  background: var(--primary);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 底部按钮 */
.bottom-panel {
  padding-top: 16rpx;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.submit-btn {
  display: block !important;
  width: 100% !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 24rpx 48rpx !important;
}

.submit-btn.btn-disabled {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

/* 自定义时间选择器弹窗 */
.time-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: relative;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.popup-cancel {
  font-size: 32rpx;
  color: #999;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.popup-confirm {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 600;
}

.picker-view-wrapper {
  height: 480rpx;
  padding: 20rpx 0;
}

.picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
  height: 96rpx;
  line-height: 96rpx;
}
