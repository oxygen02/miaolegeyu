.group-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.group-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.cat-hint {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.speech-bubble {
  background: var(--card);
  padding: 20rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(212, 101, 42, 0.15);
  box-shadow: var(--shadow-card);
  position: relative;
}

.speech-bubble::before {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-right-color: var(--card);
}

.bubble-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary);
}

.header-sub {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text);
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.currency {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  height: 100%;
  background: transparent;
  padding: 0;
}

.time-picker {
  height: 88rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.picker-value.has-value {
  color: var(--text);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--soft);
  border-bottom: 3rpx solid var(--soft);
  transform: rotate(-45deg);
}

/* 平台选择 */
.platform-section {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.platform-list {
  display: flex;
  gap: 20rpx;
}

.platform-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--bg);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.platform-item.active {
  border-color: var(--primary);
  background: rgba(212, 101, 42, 0.06);
}

.platform-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.meituan-icon {
  background: #FFD100;
}

.eleme-icon {
  background: #0085FF;
}

.jd-icon {
  background: #E4393C;
}

.platform-name {
  font-size: 24rpx;
  color: var(--text);
}

/* 底部按钮 */
.bottom-panel {
  margin-top: auto;
  padding-top: 32rpx;
}

.submit-btn {
  width: 100%;
}
