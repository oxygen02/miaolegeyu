.group-page {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

/* 头部 */
.group-header {
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

/* 规则提示 */
.rule-hint {
  background: rgba(255, 159, 67, 0.1);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin: 0 20rpx 8rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 24rpx;
  color: #FF9F43;
  font-weight: 500;
}

/* 橘红色背景区域 - 与投票/发现美食页面保持一致 */
.header-bg {
  background: linear-gradient(180deg, #FF9F43 0%, #FFB347 100%);
  padding: 40rpx 32rpx 30rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

/* 左侧内容区域 */
.header-left-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  z-index: 1;
}

.cat-hint {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 1;
}

/* 头像外圈 - 与发现美食页面一致 */
.cat-img-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7B1A 100%);
  padding: 3rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.cat-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
}

.speech-bubble {
  background: transparent;
  padding: 0;
  position: relative;
}

/* 标题字体 - 与发现美食页面一致 */
.bubble-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 2rpx 4rpx 8rpx rgba(0,0,0,0.2);
}

/* 副标题 - 与发现美食页面一致 */
.header-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  z-index: 1;
}

/* 猫尾巴 - 与投票/发现美食页面一致 */
.header-tail {
  width: 100rpx;
  height: 100rpx;
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  z-index: 2;
}

/* 选项卡样式 - 卡片背景 */
.options-tabs {
  display: flex;
  gap: 12rpx;
  margin: 0 20rpx 12rpx;
  padding: 12rpx 16rpx;
  flex-shrink: 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
}

.option-tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E0 100%);
  border-radius: 12rpx;
  border: 2rpx solid #3D3D3D;
  transition: all 0.2s;
}

.option-tab.active {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  border-color: #3D3D3D;
}

.option-tab-text {
  font-size: 26rpx;
  color: #3D3D3D;
  font-weight: 600;
}

.option-tab.active .option-tab-text {
  color: #FFFFFF;
  font-weight: 700;
}

.option-delete {
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #FF6B6B;
}

.option-add {
  padding: 8rpx 16rpx;
  background: rgba(76, 175, 80, 0.15);
  border-radius: 12rpx;
  border: 2rpx dashed #4CAF50;
}

.option-add-text {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 600;
}

/* 表单卡片容器 */
.form-cards-container {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 20rpx;
}

/* 表单卡片 - 交替背景色 - 立体边框效果 */
.form-card {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
  flex-shrink: 0;
}

/* 奇数卡片 - 明显橘色 */
.form-card:nth-child(odd) {
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4B8 100%);
}

/* 偶数卡片 - 明显米色 */
.form-card:nth-child(even) {
  background: linear-gradient(135deg, #E8E0D0 0%, #D8D0C0 100%);
}

/* 卡片头部行：选项编号 + 拼单标题 */
.card-header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(255, 159, 67, 0.3);
}

.card-option-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF9F43;
  flex-shrink: 0;
}

.card-title-input {
  flex: 1;
  height: 52rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  border: 2rpx solid rgba(61, 61, 61, 0.15);
  padding: 0 16rpx;
  font-size: 26rpx;
}

/* 卡片主布局 - 左右分栏 */
.card-main-layout {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

/* 左侧：店铺图片区域 */
.card-left-section {
  flex: 0 0 42%;
  min-width: 200rpx;
  display: flex;
  align-items: stretch;
}

/* 右侧：所有输入内容 */
.card-right-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.right-item {
  display: flex;
  flex-direction: column;
}

/* 右侧行布局 - 截止时间和外卖平台同一行 */
.right-row {
  display: flex;
  gap: 12rpx;
}

.time-item {
  flex: 0 0 48%;
  min-width: 160rpx;
}

.platform-item-row {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  font-weight: 500;
  height: 36rpx;
  line-height: 36rpx;
}

.form-input {
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: var(--text);
  border: 2rpx solid rgba(61, 61, 61, 0.15);
}



.time-picker {
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid rgba(61, 61, 61, 0.15);
}

.picker-value {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.picker-value.has-value {
  color: var(--text);
}

.picker-arrow {
  width: 10rpx;
  height: 10rpx;
  border-right: 2rpx solid var(--soft);
  border-bottom: 2rpx solid var(--soft);
  transform: rotate(-45deg);
}

/* 平台选择 - 紧凑布局 */
.platform-list {
  display: flex;
  gap: 8rpx;
  height: 52rpx;
  align-items: center;
}

.platform-item {
  flex: 0 0 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 50%;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  padding: 2rpx;
}

.platform-item.active {
  background: #FFFFFF;
  border-color: #FF9F43;
  box-shadow: 0 2rpx 8rpx rgba(255, 159, 67, 0.4);
}

.platform-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  filter: grayscale(100%);
  opacity: 0.6;
  transition: all 0.2s;
}

.platform-item.active .platform-icon {
  filter: grayscale(0%);
  opacity: 1;
}

/* 店铺图片区域 - 单张图片适配 */
.shop-image-section {
  width: 100%;
  height: 100%;
}

.shop-image-upload {
  width: 100%;
  height: 100%;
  min-height: 160rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 2rpx dashed rgba(61, 61, 61, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 48rpx;
  color: var(--soft);
  font-weight: 300;
}

.upload-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.shop-image-preview {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 160rpx;
}

.shop-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
}



/* 店铺链接输入 - 修复框套框问题 */
.link-input-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.link-input {
  flex: 1;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  border: 2rpx solid rgba(61, 61, 61, 0.15);
  padding: 0 16rpx;
  font-size: 26rpx;
}

.paste-btn {
  padding: 0 20rpx;
  height: 56rpx;
  background: var(--primary);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 底部按钮 */
.bottom-panel {
  padding: 32rpx 0;
  flex-shrink: 0;
  margin-top: auto;
  margin-bottom: 0;
}

.submit-btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 20rpx 56rpx !important;
  margin: 0 auto !important;
}

.submit-btn.btn-disabled {
  background: #CCC !important;
  color: #888 !important;
  border-color: #999 !important;
  box-shadow: 4rpx 4rpx 0 #999 !important;
}

.submit-btn::after {
  display: none !important;
}

/* 自定义时间选择器弹窗 */
.time-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: relative;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.popup-cancel {
  font-size: 28rpx;
  color: #999;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.popup-confirm {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
}

.picker-view-wrapper {
  height: 400rpx;
  padding: 16rpx 0;
}

.picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
}
