@import "../../styles/variables.wxss";

/* ==================== 结果页样式 ==================== */

page {
  background: linear-gradient(180deg, #FFF8F0 0%, #FFF5E9 100%);
  font-family: var(--font-family);
}

.result-page {
  min-height: 100vh;
  padding: 40rpx 32rpx 60rpx;
}

/* ---------- 加载状态 ---------- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

/* 睡觉猫咪图标 */
.loading-icon {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  animation: catBounce 2s ease-in-out infinite;
}

.cat-sleeping {
  background: radial-gradient(circle at 30% 30%, #FFB347 0%, #FF9F43 100%);
  border-radius: 50%;
}

.cat-sleeping::before {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 40rpx solid #FF9F43;
  top: 10rpx;
  left: 30rpx;
  transform: rotate(-20deg);
}

.cat-sleeping::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 40rpx solid #FF9F43;
  top: 10rpx;
  right: 30rpx;
  transform: rotate(20deg);
}

@keyframes catBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* ---------- 结果头部 ---------- */
.result-header {
  text-align: center;
  margin-bottom: 48rpx;
  padding-top: 20rpx;
}

/* 开心猫咪图标 */
.result-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  position: relative;
  animation: emojiPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.cat-happy {
  background: radial-gradient(circle at 30% 30%, #FFB347 0%, #FF9F43 100%);
  border-radius: 50%;
}

.cat-happy::before {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 32rpx solid #FF9F43;
  top: 8rpx;
  left: 24rpx;
  transform: rotate(-15deg);
}

.cat-happy::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 32rpx solid #FF9F43;
  top: 8rpx;
  right: 24rpx;
  transform: rotate(15deg);
}

@keyframes emojiPop {
  0% { transform: scale(0) rotate(-20deg); opacity: 0; }
  100% { transform: scale(1) rotate(0); opacity: 1; }
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* ---------- 最终海报 ---------- */
.final-poster-section {
  margin-bottom: 48rpx;
}

.poster-card {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 4rpx solid #3D3D3D;
  box-shadow: 6rpx 6rpx 0 #3D3D3D;
}

.poster-image {
  width: 100%;
  height: 100%;
}

.platform-badge {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  border: 3rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
}

.platform-badge.meituan {
  background: #FFC300;
  color: #333;
}

.platform-badge.dianping {
  background: #FF6633;
  color: #fff;
}

.platform-badge.jd {
  background: #E4393C;
  color: #fff;
}

/* ---------- 聚餐信息 ---------- */
.dinner-info {
  margin-top: 32rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-divider);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  width: 100rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.copy-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  background: rgba(255, 159, 67, 0.1);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--color-primary);
  font-weight: 600;
  transition: all 0.2s ease;
}

.copy-btn:active {
  background: rgba(255, 159, 67, 0.2);
  transform: scale(0.95);
}

/* ---------- 无结果状态 ---------- */
.no-result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  margin-bottom: 48rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 6rpx 6rpx 0 #3D3D3D;
}

/* 难过猫咪图标 */
.no-result-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  position: relative;
  animation: catSway 3s ease-in-out infinite;
}

.cat-sad {
  background: linear-gradient(135deg, #B0B0B0 0%, #D0D0D0 100%);
  border-radius: 50%;
}

.cat-sad::before {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 36rpx solid #B0B0B0;
  top: 6rpx;
  left: 28rpx;
  transform: rotate(-15deg);
}

.cat-sad::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 36rpx solid #B0B0B0;
  top: 6rpx;
  right: 28rpx;
  transform: rotate(15deg);
}

@keyframes catSway {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}

.no-result-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.no-result-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ---------- 操作按钮 ---------- */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.action-section button {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 600;
  border: 4rpx solid #3D3D3D;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  transition: all 0.15s ease;
}

.action-section button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.btn-primary {
  background: var(--gradient-primary);
  color: #fff;
}

.btn-secondary {
  background: var(--color-card);
  color: var(--color-primary);
}

/* 按钮图标 */
.btn-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

/* 餐具图标 */
.icon-fork {
  background: #fff;
  width: 4rpx;
  height: 28rpx;
  border-radius: 2rpx;
  margin-left: 12rpx;
}

.icon-fork::before {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 16rpx;
  border: 4rpx solid #fff;
  border-radius: 0 0 50% 50%;
  border-top: none;
  right: 0;
  top: 0;
}

/* 定位图标 */
.icon-location {
  background: #fff;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.icon-location::before {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: var(--color-primary);
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 金钱图标 */
.icon-money {
  background: #fff;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  position: relative;
}

.icon-money::before {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 20rpx;
  background: var(--color-primary);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.icon-money::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 4rpx;
  background: var(--color-primary);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* ---------- 分享区域 ---------- */
.share-section {
  text-align: center;
  margin-bottom: 48rpx;
  padding: 32rpx;
  background: rgba(255, 159, 67, 0.05);
  border-radius: var(--radius-md);
  border: 3rpx dashed var(--color-primary);
}

.share-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.btn-share {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB0 100%);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  border: 3rpx solid #3D3D3D;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 0 auto;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  transition: all 0.15s ease;
}

.btn-share:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

/* 分享爱心图标 */
.share-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-heart {
  background: #fff;
  width: 20rpx;
  height: 20rpx;
  transform: rotate(45deg);
  margin-top: -4rpx;
}

.icon-heart::before,
.icon-heart::after {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #fff;
  border-radius: 50%;
}

.icon-heart::before {
  left: -10rpx;
}

.icon-heart::after {
  top: -10rpx;
}

/* ---------- 返回首页 ---------- */
.back-section {
  text-align: center;
}

.back-link {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 16rpx 32rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--color-text-secondary);
  background: var(--color-card);
  font-weight: 600;
  transition: all 0.2s ease;
}

.back-link:active {
  color: var(--color-primary);
  border-color: var(--color-primary);
  background: rgba(255, 159, 67, 0.1);
}

/* ---------- 装饰元素 ---------- */
.result-page::before {
  content: '';
  position: fixed;
  top: 10%;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 159, 67, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  transform: rotate(30deg);
  pointer-events: none;
}

.result-page::after {
  content: '';
  position: fixed;
  bottom: 20%;
  left: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 179, 71, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  transform: rotate(-20deg);
  pointer-events: none;
}
