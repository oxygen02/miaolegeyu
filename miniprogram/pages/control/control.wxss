@import "../../styles/variables.wxss";

/* ==================== 控制页 - 蜡笔像素风 ==================== */

page {
  background: var(--color-bg);
  font-family: var(--font-family);
}

.control-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* ---------- 加载状态 ---------- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-primary);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ---------- 顶部信息 ---------- */
.header-section {
  background: var(--gradient-primary);
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 4rpx solid #3D3D3D;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.1);
}

.room-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.room-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: #fff;
  display: block;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.2);
}

.room-meta {
  display: flex;
  gap: 16rpx;
}

.room-id {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.95);
  background: rgba(0,0,0,0.2);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* 右侧状态和信息 */
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.status-badge {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  font-weight: 600;
  border: 3rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
}

.status-badge.voting {
  background: #4CAF50;
  color: #fff;
}

.status-badge.locked {
  background: #8A8A8A;
  color: #fff;
}

.status-badge.cancelled {
  background: #E74C3C;
  color: #fff;
}

.vote-count {
  font-size: var(--font-size-sm);
  color: #fff;
  background: rgba(255,255,255,0.25);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(255,255,255,0.3);
  white-space: nowrap;
}

/* ---------- 统计区域 ---------- */
.stats-section {
  padding: 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title text:first-child {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

.section-title .subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ---------- 海报排行 ---------- */
.poster-ranking {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  transition: all 0.2s;
}

.rank-item.selected {
  border-color: var(--color-primary);
  background: rgba(255, 159, 67, 0.1);
  box-shadow: 4rpx 4rpx 0 var(--color-primary);
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  font-weight: 700;
  margin-right: 20rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.rank-item:nth-child(2) .rank-num { 
  background: #C0C0C0; 
}
.rank-item:nth-child(3) .rank-num { 
  background: #CD7F32; 
}

.rank-poster {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  margin-right: 20rpx;
  border: 3rpx solid #3D3D3D;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-info .vote-count {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.platform-tag {
  font-size: var(--font-size-sm);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  display: inline-block;
  width: fit-content;
  border: 2rpx solid #3D3D3D;
  font-weight: 600;
}

.platform-tag.meituan {
  background: #FFC300;
  color: #333;
}

.platform-tag.dianping {
  background: #FF6633;
  color: #fff;
}

.platform-tag.jd {
  background: #E4393C;
  color: #fff;
}

/* 口味排行图标样式 */
.cuisine-rank-icon {
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cuisine-icon-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.select-icon {
  width: 56rpx;
  height: 56rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

/* ---------- 空状态 ---------- */
.empty-stats {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-size-lg);
}

/* ---------- 被否决的海报 ---------- */
.vetoed-section {
  margin-top: 40rpx;
}

.vetoed-title text {
  color: #E74C3C;
}

.vetoed-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.vetoed-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 3rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
}

.vetoed-poster {
  width: 100%;
  height: 100%;
}

.vetoed-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(231, 76, 60, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.vetoed-text {
  color: #fff;
  font-size: var(--font-size-sm);
  font-weight: 600;
}

/* ========== Mode B: 口味偏好样式 ========== */

/* 口味排行 */
.cuisine-ranking {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cuisine-ranking .rank-item {
  padding: 24rpx;
}

.cuisine-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cuisine-name {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

.cuisine-info .vote-count {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 可选品类 */
.cuisine-options-section {
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--color-divider);
}

.cuisine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cuisine-tag {
  padding: 12rpx 24rpx;
  background: var(--color-bg-warm);
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  color: var(--color-text);
  border: 2rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  font-weight: 600;
}

/* 选中的口味 */
.selected-cuisine {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: rgba(255, 159, 67, 0.15);
  border-radius: var(--radius-md);
  border: 3rpx solid var(--color-primary);
  box-shadow: 4rpx 4rpx 0 var(--color-primary);
}

.cuisine-label {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.cuisine-value {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

/* ---------- 参与者列表 ---------- */
.participants-section {
  padding: 0 32rpx 32rpx;
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--color-card);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-full);
  min-width: 160rpx;
  border: 2rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: 600;
  border: 2rpx solid #3D3D3D;
}

.participant-status {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: 600;
}

.participant-status.voted {
  color: #4CAF50;
}

.participant-status.waived {
  color: #8A8A8A;
}

.participant-status.leave {
  color: #E74C3C;
}

/* ---------- 底部操作栏 ---------- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  padding: 20rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  border-top: 4rpx solid #3D3D3D;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
}

.bottom-bar button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: 600;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  transition: all 0.15s;
}

.bottom-bar button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.btn-share {
  background: var(--color-primary);
  color: #fff;
}

.btn-edit {
  background: #2196F3;
  color: #fff;
}

.btn-lock {
  background: #4CAF50;
  color: #fff;
}

/* ---------- 弹窗 ---------- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 4rpx solid #3D3D3D;
  box-shadow: 8rpx 8rpx 0 #3D3D3D;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 3rpx solid var(--color-divider);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

.modal-close {
  font-size: 44rpx;
  color: var(--color-text-secondary);
  padding: 0 16rpx;
}

.modal-body {
  padding: 32rpx;
}

.confirm-text {
  font-size: var(--font-size-md);
  color: var(--color-text);
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
  font-weight: 600;
}

.selected-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.preview-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.preview-votes {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
  font-weight: 700;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: var(--font-size-md);
  color: var(--color-text);
  margin-bottom: 12rpx;
  font-weight: 600;
}

.picker-value {
  padding: 24rpx;
  background: var(--color-bg-warm);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-md);
  color: var(--color-text);
  border: 2rpx solid #3D3D3D;
}

.form-item input {
  width: 100%;
  padding: 24rpx;
  background: var(--color-bg-warm);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-md);
  box-sizing: border-box;
  border: 2rpx solid #3D3D3D;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-size-md);
  font-weight: 600;
  border: 3rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  transition: all 0.15s;
}

.modal-footer button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.btn-cancel {
  background: var(--color-bg-warm);
  color: var(--color-text-secondary);
}

.btn-confirm {
  background: var(--color-primary);
  color: #fff;
}
