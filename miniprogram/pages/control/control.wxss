/* pages/control/control.wxss */
page {
  background-color: #F5F0E8;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.control-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8913A;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #8A8A8A;
}

/* 顶部信息 */
.header-section {
  background: linear-gradient(135deg, #D4652A 0%, #E8913A 100%);
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.room-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.room-meta {
  display: flex;
  gap: 24rpx;
}

.room-id {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(0,0,0,0.15);
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
}

/* 右侧状态和信息 */
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.status-badge {
  padding: 16rpx 28rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.status-badge.voting {
  background: #4CAF50;
  color: #fff;
}

.status-badge.locked {
  background: #8A8A8A;
  color: #fff;
}

.status-badge.cancelled {
  background: #C84B31;
  color: #fff;
}

.vote-count {
  font-size: 28rpx;
  color: #fff;
  background: rgba(255,255,255,0.25);
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 统计区域 */
.stats-section {
  padding: 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title text:first-child {
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.section-title .subtitle {
  font-size: 26rpx;
  color: #8A8A8A;
}

/* 海报排行 */
.poster-ranking {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #FFFDF7;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.rank-item.selected {
  border-color: #D4652A;
  background: rgba(212, 101, 42, 0.05);
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  background: #D4652A;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.rank-item:nth-child(2) .rank-num { background: #C0C0C0; }
.rank-item:nth-child(3) .rank-num { background: #CD7F32; }

.rank-poster {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-info .vote-count {
  font-size: 40rpx;
  font-weight: 600;
  color: #D4652A;
}

.platform-tag {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
}

.platform-tag.meituan {
  background: #FFC300;
  color: #333;
}

.platform-tag.dianping {
  background: #FF6633;
  color: #fff;
}

.platform-tag.jd {
  background: #E4393C;
  color: #fff;
}

/* 口味排行图标样式 */
.cuisine-rank-icon {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cuisine-icon-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
}

.select-icon {
  width: 56rpx;
  height: 56rpx;
  background: #D4652A;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 空状态 */
.empty-stats {
  text-align: center;
  padding: 80rpx;
  color: #8A8A8A;
  font-size: 32rpx;
}

/* 被否决的海报 */
.vetoed-section {
  margin-top: 40rpx;
}

.vetoed-title text {
  color: #C84B31;
}

.vetoed-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.vetoed-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.vetoed-poster {
  width: 100%;
  height: 100%;
}

.vetoed-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(200, 75, 49, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.vetoed-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== Mode B: 口味偏好样式 ========== */

/* 口味排行 */
.cuisine-ranking {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cuisine-ranking .rank-item {
  padding: 24rpx;
}

.cuisine-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cuisine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.cuisine-info .vote-count {
  font-size: 28rpx;
  color: #8A8A8A;
}

/* 可选品类 */
.cuisine-options-section {
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #F5F0E8;
}

.cuisine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cuisine-tag {
  padding: 12rpx 24rpx;
  background: #F5F0E8;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #3D3D3D;
}

/* 选中的口味 */
.selected-cuisine {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: rgba(212, 101, 42, 0.1);
  border-radius: 16rpx;
}

.cuisine-label {
  font-size: 28rpx;
  color: #8A8A8A;
  margin-bottom: 12rpx;
}

.cuisine-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #D4652A;
}

/* 参与者列表 */
.participants-section {
  padding: 0 32rpx 32rpx;
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFDF7;
  padding: 20rpx 28rpx;
  border-radius: 40rpx;
  min-width: 160rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  background: #D4652A;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.participant-status {
  font-size: 28rpx;
  color: #8A8A8A;
}

.participant-status.voted {
  color: #4CAF50;
}

.participant-status.waived {
  color: #8A8A8A;
}

.participant-status.leave {
  color: #C84B31;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFDF7;
  padding: 20rpx 32rpx 40rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.bottom-bar button {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
}

.btn-share {
  background: #D4652A;
  color: #fff;
}

.btn-edit {
  background: #2196F3;
  color: #fff;
}

.btn-lock {
  background: #4CAF50;
  color: #fff;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: #FFFDF7;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F0E8;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.modal-close {
  font-size: 44rpx;
  color: #8A8A8A;
  padding: 0 16rpx;
}

.modal-body {
  padding: 32rpx;
}

.confirm-text {
  font-size: 30rpx;
  color: #3D3D3D;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}

.selected-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.preview-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.preview-votes {
  font-size: 36rpx;
  color: #D4652A;
  font-weight: 600;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 30rpx;
  color: #3D3D3D;
  margin-bottom: 12rpx;
}

.picker-value {
  padding: 24rpx;
  background: #F5F0E8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #3D3D3D;
}

.form-item input {
  width: 100%;
  padding: 24rpx;
  background: #F5F0E8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-cancel {
  background: #F5F0E8;
  color: #8A8A8A;
}

.btn-confirm {
  background: #D4652A;
  color: #fff;
}
