/* 测试页面 */
.test-page {
  min-height: 100vh;
  background: #F5F0E8;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-item.active .step-dot {
  background: #fff;
  color: #FF9F43;
}

.step-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.step-item.active .step-text {
  color: #fff;
  font-weight: 500;
}

.step-line {
  width: 60rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 16rpx;
  margin-bottom: 20rpx;
}

.step-line.active {
  background: #fff;
}

/* 步骤内容 */
.step-content {
  padding: 32rpx;
}

/* 演示卡片 */
.demo-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 6rpx 6rpx 0 #3D3D3D;
}

.demo-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.demo-cat {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.demo-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.demo-info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #3D3D3D;
  font-weight: 500;
}

.switch-status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.switch-status.on {
  background: #E8F5E9;
  color: #4CAF50;
}

.switch-status.off {
  background: #FFEBEE;
  color: #F44336;
}

.demo-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 16rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
}

.hint-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.hint-text {
  font-size: 26rpx;
  color: #F57C00;
}

/* 结果头部 */
.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.result-cat {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.result-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.title-sub {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 匹配列表 */
.matches-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 16rpx;
  display: block;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.match-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.match-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF9F43;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.match-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.match-name {
  font-size: 28rpx;
  color: #3D3D3D;
  font-weight: 500;
}

.match-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.match-badge {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.match-badge.perfect {
  background: #FFEBEE;
  color: #E53935;
}

.match-badge.strong {
  background: #FFF3E0;
  color: #F57C00;
}

.match-badge.good {
  background: #E8F5E9;
  color: #43A047;
}

/* 忌口 */
.taboo-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.taboo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.taboo-tag {
  padding: 8rpx 20rpx;
  background: #FFEBEE;
  color: #E53935;
  border-radius: 12rpx;
  font-size: 24rpx;
}

/* 推荐入口 */
.recommend-entry {
  margin-bottom: 24rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  border-radius: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 6rpx 6rpx 0 #3D3D3D;
}

.entry-icon {
  font-size: 48rpx;
}

.entry-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.entry-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
}

.entry-arrow {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

/* 推荐头部 */
.recommend-header {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  padding: 32rpx;
  margin: -32rpx -32rpx 24rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.cat-hint {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cat-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.speech-bubble {
  background: #fff;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(212, 101, 42, 0.15);
}

.bubble-text {
  font-size: 28rpx;
  color: #FF9F43;
  font-weight: 500;
}

.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.location-icon {
  width: 28rpx;
  height: 28rpx;
}

.location-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

/* 口味偏好 */
.preference-section {
  margin-bottom: 24rpx;
}

.preference-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.preference-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.preference-tag.top {
  background: #FFF3E0;
  border: 2rpx solid #FF9F43;
}

.tag-name {
  font-size: 26rpx;
  color: #3D3D3D;
  font-weight: 500;
}

.tag-count {
  font-size: 22rpx;
  color: #FF9F43;
}

/* 刷新栏 */
.refresh-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.refresh-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.refresh-icon {
  font-size: 24rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-icon {
  width: 200rpx;
  height: 200rpx;
  animation: fishBounce 2s ease-in-out infinite;
}

@keyframes fishBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 餐厅列表 */
.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.restaurant-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.card-main {
  display: flex;
  gap: 16rpx;
}

.restaurant-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.restaurant-info {
  flex: 1;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.restaurant-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.distance-tag {
  padding: 4rpx 12rpx;
  background: #E8F5E9;
  color: #43A047;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating-text {
  font-size: 26rpx;
  color: #FF9F43;
  font-weight: 500;
}

.price-text {
  font-size: 24rpx;
  color: #E53935;
}

.cuisine-text {
  font-size: 24rpx;
  color: #666;
  background: #f8f8f8;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag-item {
  font-size: 22rpx;
  color: #666;
  background: #f8f8f8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.address-text {
  font-size: 24rpx;
  color: #999;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
}

.btn-primary {
  background: #FF9F43;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #3D3D3D;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.detail-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

.detail-image {
  width: calc(100% + 64rpx);
  height: 320rpx;
  margin: -32rpx -32rpx 24rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #f0f0f0;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.detail-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.detail-rating-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.detail-rating {
  font-size: 30rpx;
  color: #FF9F43;
  font-weight: 600;
}

.detail-price {
  font-size: 28rpx;
  color: #E53935;
}

.detail-distance {
  font-size: 26rpx;
  color: #666;
}

.detail-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #3D3D3D;
}

.detail-highlight {
  font-size: 28rpx;
  color: #FF9F43;
  font-weight: 500;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 4rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
}

.navigate-btn {
  background: #E3F2FD;
  color: #1976D2;
}

.call-btn {
  background: #E8F5E9;
  color: #388E3C;
}

.select-btn {
  background: #FF9F43;
  color: #fff;
}

/* 图标样式 */
.hint-icon {
  width: 32rpx;
  height: 32rpx;
}

.entry-icon {
  width: 48rpx;
  height: 48rpx;
}

.star-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 4rpx;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  padding: 8rpx;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

/* 带图标的标题 */
.section-title-with-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.section-icon {
  width: 32rpx;
  height: 32rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
}

/* 刷新图标 */
.refresh-icon-img {
  width: 24rpx;
  height: 24rpx;
}
