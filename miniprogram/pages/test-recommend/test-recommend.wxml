<view class="test-page">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step-item {{step >= 1 ? 'active' : ''}}" bindtap="goToStep" data-step="1">
      <view class="step-dot">1</view>
      <text class="step-text">创建房间</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step-item {{step >= 2 ? 'active' : ''}}" bindtap="goToStep" data-step="2">
      <view class="step-dot">2</view>
      <text class="step-text">投票结果</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step-item {{step >= 3 ? 'active' : ''}}" bindtap="goToStep" data-step="3">
      <view class="step-dot">3</view>
      <text class="step-text">餐厅推荐</text>
    </view>
  </view>

  <!-- 步骤1：创建房间模拟 -->
  <view class="step-content" wx:if="{{step === 1}}">
    <view class="demo-card">
      <view class="demo-header">
        <image class="demo-cat" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFit"/>
        <text class="demo-title">模拟房间信息</text>
      </view>
      
      <view class="demo-info-list">
        <view class="info-row">
          <text class="info-label">聚餐标题</text>
          <text class="info-value">{{room.title}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">聚餐地点</text>
          <text class="info-value">{{room.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">聚餐时间</text>
          <text class="info-value">{{room.activityDate}} {{room.activityTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">投票截止</text>
          <text class="info-value">{{room.voteDeadline}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">餐厅推荐</text>
          <view class="switch-status {{room.enableRestaurantRecommend ? 'on' : 'off'}}">
            {{room.enableRestaurantRecommend ? '已开启' : '已关闭'}}
          </view>
        </view>
      </view>

      <view class="demo-hint">
        <image class="hint-icon" src="{{imagePaths.icons.hint}}" mode="aspectFit"/>
        <text class="hint-text">创建房间时开启了「投票后推荐餐厅」功能</text>
      </view>
    </view>

    <view class="nav-buttons">
      <button class="btn btn-primary" bindtap="nextStep">下一步：查看投票结果 →</button>
    </view>
  </view>

  <!-- 步骤2：投票结果 -->
  <view class="step-content" wx:if="{{step === 2}}">
    <view class="demo-card">
      <view class="result-header">
        <image class="result-cat" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFit"/>
        <view class="result-title">
          <text class="title-main">橘仔宣布</text>
          <text class="title-sub">投票结果统计完成</text>
        </view>
      </view>

      <!-- 最佳匹配 -->
      <view class="matches-section">
        <view class="section-title-with-icon">
          <image class="section-icon" src="{{imagePaths.icons.target}}" mode="aspectFit"/>
          <text class="section-title-text">最佳匹配</text>
        </view>
        <view class="match-list">
          <view class="match-item {{item.matchType}}" wx:for="{{voteStats.bestMatches}}" wx:key="index">
            <view class="match-rank">{{index + 1}}</view>
            <view class="match-info">
              <text class="match-name">{{item.categoryName}} · {{item.subCategoryName}}</text>
              <text class="match-count">{{item.voterCount}}人选</text>
            </view>
            <view class="match-badge {{item.matchType}}">
              {{item.matchType === 'perfect' ? '绝配' : item.matchType === 'strong' ? '强推' : '不错'}}
            </view>
          </view>
        </view>
      </view>

      <!-- 忌口统计 -->
      <view class="taboo-section" wx:if="{{voteStats.tabooStats.length > 0}}">
        <view class="section-title-with-icon">
          <image class="section-icon" src="{{imagePaths.icons.forbidden}}" mode="aspectFit"/>
          <text class="section-title-text">忌口提醒</text>
        </view>
        <view class="taboo-list">
          <view class="taboo-tag" wx:for="{{voteStats.tabooStats}}" wx:key="index">
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- 推荐餐厅入口 -->
    <view class="recommend-entry" wx:if="{{room.enableRestaurantRecommend}}">
      <view class="entry-card" bindtap="nextStep">
        <image class="entry-icon" src="{{imagePaths.icons.restaurant}}" mode="aspectFit"/>
        <view class="entry-info">
          <text class="entry-title">推荐附近餐厅</text>
          <text class="entry-desc">根据「{{voteStats.bestMatches[0].subCategoryName}}」口味，为你推荐周边好店</text>
        </view>
        <view class="entry-arrow">›</view>
      </view>
    </view>

    <view class="nav-buttons">
      <button class="btn btn-secondary" bindtap="prevStep">← 上一步</button>
      <button class="btn btn-primary" bindtap="nextStep">查看推荐 →</button>
    </view>
  </view>

  <!-- 步骤3：餐厅推荐 -->
  <view class="step-content" wx:if="{{step === 3}}">
    <!-- 顶部提示 -->
    <view class="recommend-header">
      <view class="cat-hint">
        <image class="cat-img" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFit"/>
        <view class="speech-bubble">
          <text class="bubble-text">根据大家的口味，为你推荐这些店</text>
        </view>
      </view>
      <view class="location-info">
        <image class="location-icon" src="{{imagePaths.icons.location}}" mode="aspectFit"/>
        <text class="location-text">{{room.location}}</text>
      </view>
    </view>

    <!-- 口味偏好 -->
    <view class="preference-section">
      <text class="section-label">大家最爱的口味</text>
      <view class="preference-list">
        <view class="preference-tag {{index === 0 ? 'top' : ''}}" wx:for="{{voteStats.bestMatches}}" wx:key="index">
          <text class="tag-name">{{item.categoryName}}·{{item.subCategoryName}}</text>
          <text class="tag-count">{{item.voterCount}}人选</text>
        </view>
      </view>
    </view>

    <!-- 刷新按钮 -->
    <view class="refresh-bar">
      <text class="refresh-text">附近推荐</text>
      <view class="refresh-btn" bindtap="refreshSearch">
        <image class="refresh-icon-img" src="{{imagePaths.icons.refresh}}" mode="aspectFit"/>
        <text>换一批</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loading}}">
      <image class="loading-icon" src="{{imagePaths.misc.fishIcon}}" mode="aspectFit"/>
      <text class="loading-text">正在寻找附近好店...</text>
    </view>

    <!-- 餐厅列表 -->
    <view class="restaurant-list" wx:else>
      <view class="restaurant-card" wx:for="{{restaurants}}" wx:key="index" bindtap="showDetail" data-index="{{index}}">
        <view class="card-main">
          <image class="restaurant-image" src="{{item.image}}" mode="aspectFill" lazy-load/>
          <view class="restaurant-info">
            <view class="info-header">
              <text class="restaurant-name">{{item.name}}</text>
              <view class="distance-tag">
                <text>{{item.distanceText}}</text>
              </view>
            </view>
            <view class="rating-row">
              <view class="rating-text" wx:if="{{item.rating}}">
                <image class="star-icon" src="{{imagePaths.icons.star}}" mode="aspectFit"/>
                <text>{{item.rating}}分</text>
              </view>
              <text class="price-text" wx:if="{{item.avgPrice}}">¥{{item.avgPrice}}/人</text>
              <text class="cuisine-text">{{item.cuisineType}}</text>
            </view>
            <view class="tag-row">
              <text class="tag-item" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</text>
            </view>
            <text class="address-text">{{item.address}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="nav-buttons">
      <button class="btn btn-secondary" bindtap="prevStep">← 上一步</button>
      <button class="btn btn-primary" bindtap="goToRealRecommend">跳转真实页面</button>
    </view>
  </view>

  <!-- 餐厅详情弹窗 -->
  <view class="detail-modal" wx:if="{{showRestaurantDetail}}" bindtap="closeDetail">
  <view class="detail-content" catchtap="preventClose">
    <image class="detail-image" src="{{selectedRestaurant.image}}" mode="aspectFill"/>
    <view class="detail-header">
      <text class="detail-name">{{selectedRestaurant.name}}</text>
      <image class="detail-close" src="{{imagePaths.icons.close}}" mode="aspectFit" bindtap="closeDetail"/>
    </view>
    
    <view class="detail-body">
        <view class="detail-rating-row">
          <view class="detail-rating">
            <image class="star-icon" src="{{imagePaths.icons.star}}" mode="aspectFit"/>
            <text>{{selectedRestaurant.rating}}分</text>
          </view>
          <text class="detail-price">¥{{selectedRestaurant.avgPrice}}/人</text>
          <text class="detail-distance">{{selectedRestaurant.distanceText}}</text>
        </view>
        
        <view class="detail-section">
          <text class="detail-label">特色</text>
          <text class="detail-highlight">{{selectedRestaurant.highlight}}</text>
        </view>
        
        <view class="detail-section">
          <text class="detail-label">营业时间</text>
          <text class="detail-value">{{selectedRestaurant.openTime}}</text>
        </view>
        
        <view class="detail-section">
          <text class="detail-label">地址</text>
          <text class="detail-value">{{selectedRestaurant.address}}</text>
        </view>
        
        <view class="detail-section" wx:if="{{selectedRestaurant.phone}}">
          <text class="detail-label">电话</text>
          <text class="detail-value">{{selectedRestaurant.phone}}</text>
        </view>
      </view>
      
      <view class="detail-actions">
        <view class="action-btn navigate-btn" bindtap="navigateToRestaurant">
          <image class="btn-icon" src="{{imagePaths.icons.location}}" mode="aspectFit"/>
          <text>导航</text>
        </view>
        <view class="action-btn call-btn" bindtap="callRestaurant">
          <image class="btn-icon" src="{{imagePaths.icons.phone}}" mode="aspectFit"/>
          <text>电话</text>
        </view>
        <view class="action-btn select-btn" bindtap="selectRestaurant">
          <image class="btn-icon" src="{{imagePaths.icons.check}}" mode="aspectFit"/>
          <text>选这家</text>
        </view>
      </view>
    </view>
  </view>
</view>
