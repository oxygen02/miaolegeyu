/* 新店探索页面 */
.food-discovery-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5E9 0%, #FFECD2 100%);
  padding-bottom: 40rpx;
}

/* 顶部固定区域 - 使用 sticky 定位 */
.sticky-header {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(180deg, #FF9F43 0%, #FFB347 100%);
}

/* 顶部标题区 */
.header-section {
  padding: 40rpx 32rpx 24rpx;
  position: relative;
  overflow: hidden;
}

/* 猫尾巴 - 歪歪的在右下角 */
.header-tail {
  width: 100rpx;
  height: 100rpx;
  position: absolute;
  right: -10rpx;
  bottom: -20rpx;
  z-index: 2;
  transform: rotate(-15deg);
}

/* 店铺列表顶部间距 */
.shop-list {
  padding-top: 0;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  text-shadow: 2rpx 4rpx 8rpx rgba(0,0,0,0.2);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 12rpx;
  display: block;
}

/* 菜系筛选 - 两行高频标签 + 展开/收起 */
.cuisine-filter {
  background: rgba(255,255,255,0.95);
  padding: 16rpx 20rpx;
  border-bottom: 2rpx solid rgba(255,159,67,0.1);
}

.cuisine-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-start;
}

.cuisine-item {
  padding: 10rpx 20rpx;
  background: #f8f8f8;
  border-radius: 28rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
  border: 1rpx solid transparent;
  flex-shrink: 0;
}

.cuisine-item.active {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 159, 67, 0.3);
}

/* 展开/收起按钮 */
.cuisine-item.expand-btn {
  background: transparent;
  border: none;
}

.cuisine-item.expand-btn .cuisine-name {
  color: #666666;
  font-weight: 600;
}

.cuisine-name {
  font-size: 24rpx;
  color: #666;
  transition: color 0.2s ease;
}

.cuisine-item.active .cuisine-name {
  color: #fff;
  font-weight: 600;
}

/* 店铺列表 */
.shop-list {
  padding: 20rpx;
  position: relative;
  z-index: 1;
}

/* 店铺卡片 - 紧凑布局 */
.shop-item {
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
  position: relative;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.shop-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 底部渐变遮罩 - 让底部区域卡片视觉上变浅 */
.bottom-fade-mask {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(255, 250, 245, 0.95) 0%, rgba(255, 250, 245, 0.7) 50%, transparent 100%);
  pointer-events: none;
  z-index: 10;
}

/* 右上角：付费模式 */
.payment-badge-top {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3);
}

/* 左侧：店铺信息 */
.shop-left-section {
  flex: 1;
  display: flex;
  gap: 16rpx;
  min-width: 0;
}

/* 店铺图片 - 放大 */
.shop-thumb {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f5f5f5;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.thumb-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-count {
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
}

/* 店铺详情 - 顶部对齐，紧凑 */
.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
  gap: 6rpx;
}

/* 店名行：店名+菜系标签+推荐人(右侧) */
.name-row {
  gap: 8rpx;
}

.uploader-avatar {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.uploader-name {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
}

/* 推荐理由 - 填充空白 */
.recommend-reason {
  margin-top: 4rpx;
  width: 100%;
}

.reason-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cuisine-tag {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.shop-address {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 地址行：导航图标 + 地址（单独一行） */
.address-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 小导航按钮 */
.nav-btn-small {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 159, 67, 0.1);
  border-radius: 50%;
  flex-shrink: 0;
}

.nav-btn-small:active {
  background: rgba(255, 159, 67, 0.2);
}

.nav-icon-small {
  width: 28rpx;
  height: 28rpx;
}

/* 紧凑行布局 - 评分+人均不换行 */
.compact-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  white-space: nowrap;
}

.compact-row .shop-rating {
  flex-shrink: 0;
}

.compact-row .shop-price {
  flex-shrink: 0;
}

/* 推荐人行（店名下方独立行） */
.uploader-row {
  gap: 8rpx;
}

.shop-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.paw-rating {
  display: flex;
  gap: 2rpx;
}

.paw-icon {
  width: 22rpx;
  height: 22rpx;
}

.rating-score {
  font-size: 22rpx;
  color: #FF9F43;
  font-weight: 600;
}

.shop-price-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  padding: 8rpx 12rpx;
  background: rgba(255, 159, 67, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 159, 67, 0.3);
}

.price-icon {
  width: 32rpx;
  height: 32rpx;
}

.location-icon-wrapper {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-icon.location-icon {
  opacity: 1;
  width: 100%;
  height: 100%;
}

.location-fallback {
  position: absolute;
  font-size: 28rpx;
  line-height: 1;
}

.price-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.shop-price {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.shop-distance {
  font-size: 18rpx;
  color: #999;
  margin-top: 2rpx;
}

.uploader-row {
  gap: 8rpx;
}

/* 中间分隔线 */
.divider {
  width: 2rpx;
  background: rgba(0,0,0,0.1);
  margin: 0 8rpx;
}

/* 右侧：约饭活动 */
.shop-right-section {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  position: relative;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  box-shadow:
    /* 外阴影 - 营造2D立体感 */
    4rpx 4rpx 8rpx rgba(0, 0, 0, 0.1),
    2rpx 2px 4rpx rgba(0, 0, 0, 0.08),
    /* 内阴影 - 增加层次感 */
    inset -1rpx -1rpx 2rpx rgba(255, 255, 255, 0.8),
    inset 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

/* 约饭活动翻页容器 */
.appointments-swiper {
  width: 100%;
  height: 200rpx;
}

/* swiper-item 样式 */
.appointment-swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 右侧竖线红点标记 */
.flip-indicator {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.indicator-line {
  width: 3rpx;
  height: 40rpx;
  background: linear-gradient(180deg, 
    rgba(255, 107, 107, 0.2) 0%,
    rgba(255, 107, 107, 0.6) 50%,
    rgba(255, 107, 107, 0.2) 100%
  );
  border-radius: 2rpx;
}

.indicator-dots {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: center;
}

.indicator-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 8rpx;
  height: 8rpx;
  background: #FF6B6B;
  box-shadow: 0 0 4rpx rgba(255, 107, 107, 0.6);
}

.appointment-card {
  background: rgba(255,107,107,0.08);
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid rgba(255,107,107,0.15);
}

.appointment-card:last-child {
  margin-bottom: 0;
}

.app-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.app-row:last-child {
  margin-bottom: 0;
}

.initiator-row {
  gap: 8rpx;
}

.initiator-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #FF6B6B;
  flex-shrink: 0;
}

.initiator-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 130rpx;
}

.time-row {
  justify-content: center;
}

.app-time {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.countdown-row {
  justify-content: center;
}

.countdown-text {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.action-row {
  justify-content: space-between;
}

.participant-count {
  font-size: 20rpx;
  color: #FF6B6B;
  font-weight: 700;
}

.join-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(255,107,107,0.3);
}

.join-btn.joined {
  background: #ccc;
  box-shadow: none;
}

/* 右侧：约饭操作区 - 紧凑 */
.shop-right-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-shrink: 0;
  padding: 0 12rpx;
}

/* 我想被约按钮 - 缩小版 */
.interest-btn {
  display: block;
  width: fit-content;
  background: #E8F8F5;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  text-align: center;
  transition: all 0.2s ease;
}

.interest-btn .interest-text {
  font-size: 22rpx;
  color: #4ECDC4;
  font-weight: 600;
}

/* 已标记状态 */
.interest-btn.interested {
  background: #4ECDC4;
  border-color: #3D3D3D;
}

.interest-btn.interested .interest-text {
  color: #fff;
}

.interest-btn:active {
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateY(2rpx);
}

/* 发起约饭按钮 - 缩小版 */
.create-btn-wide {
  display: block;
  width: fit-content;
  background: #FF9F43;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  text-align: center;
}

.create-btn-wide .btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.create-btn-wide:active {
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateY(2rpx);
}

/* 加载状态 */
.loading-state,
.no-more {
  text-align: center;
  padding: 40rpx;
  padding-bottom: 160rpx;
}

.loading-text,
.no-more-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-state .empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-state .empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 底部浮动推荐按钮 */
.floating-recommend-bar {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: fit-content;
  height: auto;
  background: #FF9F43;
  border-radius: 36rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  z-index: 100;
  padding: 20rpx 48rpx;
  box-sizing: border-box;
  transition: all 0.15s ease;
}

.floating-recommend-bar:active {
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateX(-50%) translateY(2rpx);
}

.floating-recommend-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-recommend-icon {
  width: 100%;
  height: 100%;
}

.floating-recommend-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
  animation: floatText 2s ease-in-out 3;
}

@keyframes floatText {
  0% {
    transform: rotate(-2deg) translateY(0);
  }
  25% {
    transform: rotate(-2deg) translateY(-4rpx);
  }
  50% {
    transform: rotate(-2deg) translateY(2rpx);
  }
  75% {
    transform: rotate(-2deg) translateY(-2rpx);
  }
  100% {
    transform: rotate(0deg) translateY(0);
  }
}

/* 图片预览弹窗 */
.image-preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-swiper {
  width: 100%;
  height: 80vh;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-indicator {
  position: absolute;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 28rpx;
  background: rgba(0,0,0,0.5);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 56rpx;
  text-align: center;
  color: #fff;
  font-size: 48rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
}
