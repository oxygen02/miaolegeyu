<view class="profile-page">
  <!-- 用户信息 -->
  <view class="user-header">
    <view class="user-avatar" bindtap="wxLogin">
      <image src="{{userInfo.avatarUrl || imagePaths.decorations.catAvatarIcon}}" mode="aspectFit"/>
      <view class="avatar-edit" wx:if="{{userInfo.isLogin}}">更换头像</view>
      <view class="avatar-edit" wx:else>点击登录</view>
    </view>
    <view class="user-info" bindtap="wxLogin">
      <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
      <text class="user-id" wx:if="{{userInfo.isLogin}}">ID: {{userInfo.userId}}</text>
    </view>
    <!-- 积分等级信息（已登录时显示） -->
    <view class="user-points-section" wx:if="{{userInfo.isLogin}}">
      <view class="level-badge">
        <text class="level-name">{{userPoints.levelName}}</text>
      </view>
      <view class="points-row">
        <view class="points-item">
          <image class="points-icon" src="{{imagePaths.misc.fishIcon}}" mode="aspectFit"/>
          <text class="points-value">{{userPoints.fishCoins}}</text>
        </view>
        <view class="points-item">
          <text class="points-label">总积分</text>
          <text class="points-value">{{userPoints.total}}</text>
        </view>
      </view>
      <view class="level-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{(userPoints.total / userPoints.nextLevelNeed) * 100}}%;"></view>
        </view>
        <text class="progress-text">{{userPoints.total}}/{{userPoints.nextLevelNeed}} 升级进度</text>
      </view>
    </view>
    <!-- 登录方式选择（未登录时，嵌入橙色背景内） -->
    <view class="login-section" wx:if="{{!userInfo.isLogin}}" catchtap="preventBubble">
      <view class="login-btn-group">
        <view class="login-btn wechat" bindtap="wechatLoginDirect" hover-class="login-btn-hover">
          <text class="btn-label">微信登录</text>
          <text class="btn-desc">一键快速登录</text>
        </view>
        <view class="login-btn quick" bindtap="quickLoginDirect" hover-class="login-btn-hover">
          <text class="btn-label">快速体验</text>
          <text class="btn-desc">游客模式浏览</text>
        </view>
        <view class="login-btn custom" bindtap="customLogin" hover-class="login-btn-hover">
          <text class="btn-label">自定义</text>
          <text class="btn-desc">设置昵称头像</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据统计 - 五个并列一排 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stat-item" bindtap="showMyRooms">
        <text class="stat-num">{{stats.myRooms}}</text>
        <text class="stat-label">我发起的</text>
        <text class="stat-sublabel">聚餐/拼单</text>
      </view>
      <view class="stat-item" bindtap="showMyParticipated">
        <text class="stat-num">{{stats.myParticipated || 0}}</text>
        <text class="stat-label">我参与的</text>
        <text class="stat-sublabel">加入的聚餐</text>
      </view>
      <view class="stat-item" bindtap="showMyShops">
        <text class="stat-num">{{stats.myShops}}</text>
        <text class="stat-label">我的店铺</text>
        <text class="stat-sublabel">推荐店铺</text>
      </view>
      <view class="stat-item" bindtap="showMyAppointments">
        <text class="stat-num">{{stats.myAppointments}}</text>
        <text class="stat-label">我的约饭</text>
        <text class="stat-sublabel">发起的约饭</text>
      </view>
      <view class="stat-item" bindtap="showMyScheduleVotes">
        <text class="stat-num">{{stats.myScheduleVotes || 0}}</text>
        <text class="stat-label">时间投票</text>
        <text class="stat-sublabel">发起/参与</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="showFavorites">
      <image class="menu-icon-image" src="{{imagePaths.icons.favorite || imagePaths.icons.about}}" mode="aspectFit"/>
      <text class="menu-text">我的收藏</text>
      <view class="menu-badge" wx:if="{{stats.favorites > 0}}">{{stats.favorites}}</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <image class="menu-icon-image" src="{{imagePaths.icons.setting}}" mode="aspectFit"/>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <image class="menu-icon-image" src="{{imagePaths.icons.about}}" mode="aspectFit"/>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 列表弹窗 -->
  <view class="list-modal" wx:if="{{currentList}}" bindtap="closeList">
    <view class="modal-content" catchtap="preventBubble">
      <!-- 标题栏 -->
      <view class="modal-header">
        <text class="modal-title">
          {{currentList === 'favorites' ? '我的收藏' :
            currentList === 'myShops' ? '我的店铺' :
            currentList === 'myAppointments' ? '我的约饭' :
            currentList === 'myRooms' ? '我发起的聚餐' :
            currentList === 'myParticipated' ? '我参与的聚餐' :
            currentList === 'myScheduleVotes' ? '我的时间投票' : ''}}
        </text>
        <view class="close-btn" bindtap="closeList">×</view>
      </view>

      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text>加载中...</text>
      </view>

      <!-- 我参与的聚餐列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'myParticipated'}}">
        <view class="room-list">
          <view class="room-card" wx:for="{{myParticipated}}" wx:key="roomId" bindtap="goToRoomDetail" data-roomid="{{item.roomId}}">
            <!-- 左侧图片区域 -->
            <view class="room-poster">
              <image src="{{item.finalPoster || (item.candidatePosters && item.candidatePosters[0] && item.candidatePosters[0].imageUrl) || imagePaths.banners.taiyakiIcon}}" mode="aspectFill"/>
              <!-- 状态标签（毛玻璃效果） -->
              <view class="room-status {{item.status}}">
                {{item.status === 'voting' ? '进行中' : (item.status === 'locked' ? '已锁定' : '已结束')}}
              </view>
              <view class="room-role-badge" wx:if="{{item.isCreator}}">房主</view>
            </view>

            <!-- 右侧信息区 -->
            <view class="room-info">
              <!-- 第一行：标题 -->
              <view class="info-row title-row">
                <text class="room-title">{{item.title}}</text>
              </view>

              <!-- 第二行：日期+时间+地点 -->
              <view class="info-row meta-row">
                <view class="meta-item" wx:if="{{item.activityDate}}">
                  <image class="meta-icon" src="{{imagePaths.icons.calendar || '/assets/images/calendar-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.activityDate}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.activityTime}}">
                  <image class="meta-icon" src="{{imagePaths.icons.time || '/assets/images/time-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.activityTime}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.location}}">
                  <image class="meta-icon" src="{{imagePaths.icons.location || '/assets/images/location.png'}}" mode="aspectFit" />
                  <text>{{item.location}}</text>
                </view>
              </view>

              <!-- 第三行：截止+房间号 -->
              <view class="info-row deadline-row">
                <view class="meta-item deadline {{item.deadlineUrgent ? 'urgent' : ''}}" wx:if="{{item.voteDeadlineStr}}">
                  <image class="meta-icon" src="{{imagePaths.icons.deadline || '/assets/images/deadline-icon.svg'}}" mode="aspectFit" />
                  <text>截止: {{item.voteDeadlineStr}}{{item.deadlineCountdown ? (' (' + item.deadlineCountdown + ')') : ''}}</text>
                </view>
                <view class="room-id" wx:if="{{item.roomId}}">房间号: {{item.roomId}}</view>
              </view>

              <!-- 第四行：发起人信息 -->
              <view class="info-row creator-row">
                <view class="creator-info">
                  <image class="creator-avatar" src="{{item.creatorAvatar || imagePaths.decorations.catAvatarIcon}}" mode="aspectFit"/>
                  <text class="creator-name">{{item.creatorName || '发起人'}}</text>
                </view>
                <view class="action-group" wx:if="{{!item.isCreator}}">
                  <text class="participant-badge">参与者</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{myParticipated.length === 0}}">
          <text>还没有参与任何聚餐</text>
        </view>
      </scroll-view>

      <!-- 我发起的聚餐列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'myRooms'}}">
        <view class="room-list">
          <view class="room-card" wx:for="{{myRooms}}" wx:key="roomId" bindtap="goToRoomDetail" data-roomid="{{item.roomId}}" bindlongpress="onRoomLongPress" data-iscreator="{{item.isCreator}}">
            <!-- 左侧图片区域 -->
            <view class="room-poster">
              <image src="{{item.finalPoster || (item.candidatePosters[0] && item.candidatePosters[0].imageUrl) || imagePaths.banners.taiyakiIcon}}" mode="aspectFill"/>
              <!-- 状态标签（毛玻璃效果） -->
              <view class="room-status {{item.status}}">
                {{item.status === 'voting' ? '进行中' : (item.status === 'locked' ? '已锁定' : '已结束')}}
              </view>
              <view class="room-role-badge" wx:if="{{item.isCreator}}">房主</view>
            </view>

            <!-- 右侧信息区 -->
            <view class="room-info">
              <!-- 第一行：标题 -->
              <view class="info-row title-row">
                <text class="room-title">{{item.title}}</text>
              </view>

              <!-- 第二行：日期+时间+地点 -->
              <view class="info-row meta-row">
                <view class="meta-item" wx:if="{{item.activityDate}}">
                  <image class="meta-icon" src="{{imagePaths.icons.calendar || '/assets/images/calendar-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.activityDate}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.activityTime}}">
                  <image class="meta-icon" src="{{imagePaths.icons.time || '/assets/images/time-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.activityTime}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.location}}">
                  <image class="meta-icon" src="{{imagePaths.icons.location || '/assets/images/location.png'}}" mode="aspectFit" />
                  <text>{{item.location}}</text>
                </view>
              </view>

              <!-- 第三行：截止+房间号 -->
              <view class="info-row deadline-row">
                <view class="meta-item deadline {{item.deadlineUrgent ? 'urgent' : ''}}" wx:if="{{item.voteDeadlineStr}}">
                  <image class="meta-icon" src="{{imagePaths.icons.deadline || '/assets/images/deadline-icon.svg'}}" mode="aspectFit" />
                  <text>截止: {{item.voteDeadlineStr}}{{item.deadlineCountdown ? (' (' + item.deadlineCountdown + ')') : ''}}</text>
                </view>
                <view class="room-id">房间号: {{item.roomId}}</view>
              </view>

              <!-- 第四行：发起人头像昵称 + 几人参与 + 管理按钮 -->
              <view class="info-row creator-row">
                <view class="creator-info">
                  <image class="creator-avatar" src="{{item.creatorAvatarUrl || imagePaths.decorations.catAvatarIcon}}" mode="aspectFit"/>
                  <text class="creator-name">{{item.creatorNickName || '发起人'}}</text>
                </view>
                <view class="action-group">
                  <text class="participant-count">{{item.participantCount || 0}}人参与</text>
                  <text class="manage-btn" catchtap="onManageTap" data-roomid="{{item.roomId}}">管理</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{myRooms.length === 0}}">
          <text>还没有发起过聚餐</text>
        </view>
      </scroll-view>

      <!-- 我的店铺列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'myShops'}}">
        <view class="shop-list">
          <view class="shop-card" wx:for="{{myShops}}" wx:key="_id">
            <image class="shop-image" src="{{item.images[0] || imagePaths.banners.taiyakiIcon}}" mode="aspectFill" bindtap="goToShopDetail" data-id="{{item._id}}"/>
            <view class="shop-info">
              <text class="shop-name">{{item.name}}</text>
              <text class="shop-location">{{item.location}}</text>
            </view>
            <view class="shop-actions">
              <text class="action-btn delete" bindtap="deleteShop" data-id="{{item._id}}">删除</text>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{myShops.length === 0}}">
          <text>还没有推荐过店铺</text>
        </view>
      </scroll-view>

      <!-- 我的活动列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'myAppointments'}}">
        <view class="room-list">
          <view class="room-card" wx:for="{{myAppointments}}" wx:key="_id" bindtap="goToAppointmentDetail" data-shopid="{{item.shopId}}">
            <!-- 左侧图片区域 -->
            <view class="room-poster">
              <image src="{{item.shopImage || item.imageUrl || imagePaths.banners.taiyakiIcon}}" mode="aspectFill"/>
              <!-- 状态标签（毛玻璃效果） -->
              <view class="room-status {{item.status}}">
                {{item.status === 'active' ? '进行中' : (item.status === 'ended' ? '已结束' : '进行中')}}
              </view>
            </view>

            <!-- 右侧信息区 -->
            <view class="room-info">
              <!-- 第一行：标题 -->
              <view class="info-row title-row">
                <text class="room-title">{{item.shopName}}</text>
              </view>

              <!-- 第二行：日期+时间+地点 -->
              <view class="info-row meta-row">
                <view class="meta-item" wx:if="{{item.appointmentDate}}">
                  <image class="meta-icon" src="{{imagePaths.icons.calendar || '/assets/images/calendar-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.appointmentDate}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.appointmentTime}}">
                  <image class="meta-icon" src="{{imagePaths.icons.time || '/assets/images/time-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.appointmentTime}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.location}}">
                  <image class="meta-icon" src="{{imagePaths.icons.location || '/assets/images/location.png'}}" mode="aspectFit" />
                  <text>{{item.location}}</text>
                </view>
              </view>

              <!-- 第三行：截止 -->
              <view class="info-row deadline-row">
                <view class="meta-item deadline" wx:if="{{item.deadlineStr}}">
                  <image class="meta-icon" src="{{imagePaths.icons.deadline || '/assets/images/deadline-icon.svg'}}" mode="aspectFit" />
                  <text>截止: {{item.deadlineStr}}</text>
                </view>
              </view>

              <!-- 第四行：发起人头像昵称 + 几人参与 + 管理按钮 -->
              <view class="info-row creator-row">
                <view class="creator-info">
                  <image class="creator-avatar" src="{{item.creatorAvatarUrl || imagePaths.decorations.catAvatarIcon}}" mode="aspectFit"/>
                  <text class="creator-name">{{item.creatorNickName || '发起人'}}</text>
                </view>
                <view class="action-group">
                  <text class="participant-count">{{item.participantCount || 0}}人参与</text>
                  <text class="manage-btn" catchtap="onManageAppointmentTap" data-id="{{item._id}}">管理</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{myAppointments.length === 0}}">
          <text>还没有发起过活动</text>
        </view>
      </scroll-view>

      <!-- 我的时间投票列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'myScheduleVotes'}}">
        <view class="room-list">
          <view class="room-card" wx:for="{{myScheduleVotes}}" wx:key="_id" bindtap="goToScheduleVoteDetail" data-id="{{item._id}}">
            <!-- 左侧图片区域 -->
            <view class="room-poster">
              <image src="{{imagePaths.banners.taiyakiIcon}}" mode="aspectFill"/>
              <!-- 状态标签 -->
              <view class="room-status {{item.isExpired ? 'ended' : 'voting'}}">
                {{item.isExpired ? '已截止' : '进行中'}}
              </view>
              <view class="room-role-badge">{{item.isCreator ? '发起人' : '参与者'}}</view>
            </view>

            <!-- 右侧信息区 -->
            <view class="room-info">
              <!-- 第一行：标题 -->
              <view class="info-row title-row">
                <text class="room-title">{{item.title}}</text>
              </view>

              <!-- 第二行：候选日期 -->
              <view class="info-row meta-row">
                <view class="meta-item">
                  <image class="meta-icon" src="{{imagePaths.icons.calendar || '/assets/images/calendar-icon.svg'}}" mode="aspectFit" />
                  <text>{{item.dateStr}}</text>
                </view>
                <view class="meta-item" wx:if="{{item.timePeriod}}">
                  <text>{{item.timePeriod === 'lunch' ? '中午' : '晚上'}}</text>
                </view>
              </view>

              <!-- 第三行：截止 -->
              <view class="info-row deadline-row">
                <view class="meta-item deadline" wx:if="{{item.deadlineStr}}">
                  <image class="meta-icon" src="{{imagePaths.icons.deadline || '/assets/images/deadline-icon.svg'}}" mode="aspectFit" />
                  <text>截止: {{item.deadlineStr}}</text>
                </view>
              </view>

              <!-- 第四行：参与人数 -->
              <view class="info-row creator-row">
                <view class="creator-info">
                  <text class="participant-count">{{item.participantCount || 0}}人参与</text>
                </view>
                <view class="action-group" wx:if="{{item.isCreator && !item.isExpired}}">
                  <text class="manage-btn">管理</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{myScheduleVotes.length === 0}}">
          <text>还没有时间投票</text>
        </view>
      </scroll-view>

      <!-- 我的收藏列表 -->
      <scroll-view class="list-content" scroll-y wx:elif="{{currentList === 'favorites'}}">
        <view class="room-list">
          <!-- 店铺收藏卡片 -->
          <view class="room-card favorite-card" wx:for="{{favorites}}" wx:key="_id" bindtap="goToFavoriteDetail" data-item="{{item}}">
            <!-- 左侧图片区域 -->
            <view class="room-poster">
              <image src="{{item.displayImage || imagePaths.banners.taiyakiIcon}}" mode="aspectFill"/>
              <!-- 类型标签 -->
              <view class="favorite-type-tag {{item.type}}">
                {{item.type === 'shop' ? '店铺' : '活动'}}
              </view>
            </view>

            <!-- 右侧信息区 -->
            <view class="room-info">
              <!-- 第一行：标题 -->
              <view class="info-row title-row">
                <text class="room-title">{{item.displayName}}</text>
              </view>

              <!-- 第二行：描述/地址 -->
              <view class="info-row desc-row" wx:if="{{item.displayDesc}}">
                <image class="meta-icon" src="{{imagePaths.icons.location || '/assets/images/location.png'}}" mode="aspectFit" />
                <text class="desc-text">{{item.displayDesc}}</text>
              </view>

              <!-- 第三行：评分和人均 -->
              <view class="info-row rating-row" wx:if="{{item.type === 'shop'}}">
                <view class="rating-stars" wx:if="{{item.displayRating}}">
                  <text class="star-icon">★</text>
                  <text class="rating-score">{{item.displayRating}}</text>
                </view>
                <text class="price-tag" wx:if="{{item.displayPrice}}">¥{{item.displayPrice}}/人</text>
              </view>

              <!-- 第四行：收藏时间和操作 -->
              <view class="info-row favorite-footer">
                <text class="favorite-time">{{item.createTimeStr}}</text>
                <view class="action-group">
                  <text class="manage-btn cancel-btn" catchtap="onCancelFavoriteTap" data-id="{{item.targetId}}" data-type="{{item.type}}">取消收藏</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{favorites.length === 0}}">
          <text>还没有收藏</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
