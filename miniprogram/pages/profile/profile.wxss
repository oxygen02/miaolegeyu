.profile-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
}

/* 用户信息头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 0 8rpx 0 rgba(61, 61, 61, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #3D3D3D;
  overflow: hidden;
  margin-right: 24rpx;
  position: relative;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 数据统计 */
.stats-section {
  margin-bottom: 32rpx;
}

.stats-grid {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 0 8rpx 0 rgba(61, 61, 61, 0.1);
  padding: 32rpx 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 0 8rpx 0 rgba(61, 61, 61, 0.1);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--bg);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-icon-image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
}

/* 列表弹窗 */
.list-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  width: 100%;
  height: 80vh;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FF9F43;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.list-content {
  flex: 1;
  padding: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 聚餐房间卡片 */
.room-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.room-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.room-poster {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.room-poster image {
  width: 100%;
  height: 100%;
}

.room-status {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.room-status.voting {
  background: #4CAF50;
  color: #fff;
}

.room-status.locked {
  background: #8A8A8A;
  color: #fff;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.room-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
  background: rgba(255,255,255,0.8);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.room-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-id {
  font-size: 24rpx;
  color: #FF9F43;
  background: rgba(255,159,67,0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.participant-count {
  font-size: 24rpx;
  color: #666;
}

/* 店铺列表 */
.shop-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.shop-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.shop-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.shop-info {
  flex: 1;
  min-width: 0;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-location {
  font-size: 24rpx;
  color: #666;
}

.shop-actions .action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.shop-actions .action-btn.delete {
  color: #FF6B6B;
  background: rgba(255,107,107,0.1);
}

/* 活动列表 */
.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.appointment-card {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.appointment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.appointment-header .shop-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.appointment-time {
  font-size: 24rpx;
  color: #FF9F43;
}

.appointment-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.appointment-info .participant-count {
  font-size: 24rpx;
  color: #4CAF50;
  background: rgba(76,175,80,0.1);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.appointment-info .deadline {
  font-size: 24rpx;
  color: #666;
}

.appointment-actions {
  display: flex;
  gap: 16rpx;
}

.appointment-actions .action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.appointment-actions .action-btn.view {
  color: #FF9F43;
  background: rgba(255,159,67,0.1);
}

.appointment-actions .action-btn.delete {
  color: #FF6B6B;
  background: rgba(255,107,107,0.1);
}

/* 收藏列表 */
.favorite-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.favorite-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.favorite-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.favorite-info {
  flex: 1;
  min-width: 0;
}

.favorite-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-type {
  font-size: 24rpx;
  color: #FF9F43;
  background: rgba(255,159,67,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.favorite-actions .action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.favorite-actions .action-btn.cancel {
  color: #8A8A8A;
  background: rgba(138,138,138,0.1);
}
