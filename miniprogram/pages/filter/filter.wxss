.filter-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.filter-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.cat-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.cat-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.filter-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.filter-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 筛选区块 */
.filter-section {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.header-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.hard-icon {
  background: var(--hard);
  position: relative;
}

.hard-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 4rpx;
  background: #fff;
}

.soft-icon {
  background: var(--soft);
  position: relative;
}

.soft-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
}

.header-text {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 底部按钮 */
.bottom-panel {
  padding: 32rpx 0;
  flex-shrink: 0;
  margin-top: auto;
}

.submit-btn {
  display: block !important;
  width: fit-content !important;
  height: auto !important;
  line-height: 1 !important;
  border-radius: 36rpx !important;
  background: #FF9F43 !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border: 4rpx solid #3D3D3D !important;
  box-shadow: 4rpx 4rpx 0 #3D3D3D !important;
  padding: 20rpx 56rpx !important;
  margin: 0 auto !important;
}

.submit-btn::after {
  display: none !important;
}
