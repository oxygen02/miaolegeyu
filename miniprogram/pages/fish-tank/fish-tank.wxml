<view class="fish-tank-page">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-content">
      <image class="header-avatar" src="/assets/images/cat-avatar-icon.png" mode="aspectFit" />
      <view class="header-text">
        <text class="header-title">喵不喵</text>
        <text class="header-subtitle">拼美食 · 拼奶茶 · 拼生活</text>
      </view>
    </view>
  </view>

  <!-- 视图模式切换 -->
  <view class="view-mode-bar">
    <view class="mode-item {{viewMode === 'all' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="all">
      <text>全部</text>
    </view>
    <view class="mode-item {{viewMode === 'group' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="group">
      <text>拼单</text>
    </view>
    <view class="mode-item {{viewMode === 'dining' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="dining">
      <text>聚餐</text>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'ongoing' ? 'active' : ''}}" bindtap="switchTab" data-tab="ongoing">
      <text>正在进行</text>
      <text class="tab-badge" wx:if="{{ongoingCount > 0}}">{{ongoingCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'my' ? 'active' : ''}}" bindtap="switchTab" data-tab="my">
      <text>我发起的</text>
      <text class="tab-badge" wx:if="{{myCount > 0}}">{{myCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'participated' ? 'active' : ''}}" bindtap="switchTab" data-tab="participated">
      <text>我参与的</text>
      <text class="tab-badge" wx:if="{{participatedCount > 0}}">{{participatedCount}}</text>
    </view>
  </view>

  <!-- 外卖平台入口 -->
  <view class="platform-section card">
    <text class="section-title">外卖平台</text>
    <view class="platform-grid">
      <view class="platform-item" bindtap="goToPlatform" data-type="lunch">
        <view class="platform-icon lunch">🍱</view>
        <text class="platform-name">午餐</text>
      </view>
      <view class="platform-item" bindtap="goToPlatform" data-type="dinner">
        <view class="platform-icon dinner">🍜</view>
        <text class="platform-name">晚餐</text>
      </view>
      <view class="platform-item" bindtap="goToPlatform" data-type="milktea">
        <view class="platform-icon milktea">🧋</view>
        <text class="platform-name">奶茶</text>
      </view>
      <view class="platform-item" bindtap="goToFoodDiscovery">
        <view class="platform-icon discover">🔍</view>
        <text class="platform-name">发现美食</text>
      </view>
    </view>
  </view>

  <!-- 活动列表 -->
  <scroll-view class="activity-list" scroll-y="true" enhanced="true" show-scrollbar="false">
    <!-- 正在进行的活动 -->
    <block wx:if="{{activeTab === 'ongoing'}}">
      <view class="swipe-item" wx:for="{{ongoingActivities}}" wx:key="id" data-index="{{index}}" data-type="ongoing">
        <view class="swipe-delete-btn" catchtap="deleteActivity" data-id="{{item.id}}" data-type="ongoing" data-iscreator="{{item.isCreator}}">
          <text class="delete-text">{{item.isCreator ? '删除' : '退出'}}</text>
        </view>
        <view class="activity-card card anim-slide-up {{item.swiping ? 'swiping' : ''}}" style="transform: translateX({{item.translateX || 0}}px)" bindtouchstart="onSwipeTouchStart" bindtouchmove="onSwipeTouchMove" bindtouchend="onSwipeTouchEnd" data-index="{{index}}" data-type="ongoing">
          <view class="activity-main" bindtap="goToActivityDetail" data-id="{{item.id}}">
            <image class="activity-image" src="{{item.image}}" mode="aspectFill" />
            <view class="activity-info">
              <view class="activity-header-row">
                <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              </view>
              <text class="activity-title">{{item.title}}</text>
              <text class="activity-shop">{{item.shopName}}</text>
              <view class="activity-meta">
                <text class="activity-time">{{item.time}}</text>
                <text class="activity-participants">{{item.participantCount}}人参与</text>
              </view>
            </view>
            <view class="activity-right" catchtap="onRightAreaTap">
              <text class="activity-status {{item.status}}">{{item.statusName}}</text>
              <view class="activity-stats" wx:if="{{item.type === 'group'}}">
                <text class="stats-text">已凑 ¥{{item.currentAmount}}/¥{{item.targetAmount}}</text>
              </view>
              <view class="spacer" wx:else></view>
              <button class="btn btn-primary btn-small" catchtap="goToActivityDetail" data-id="{{item.id}}">立即参加</button>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 我发起的活动 -->
    <block wx:if="{{activeTab === 'my'}}">
      <view class="swipe-item" wx:for="{{myActivities}}" wx:key="id" data-index="{{index}}" data-type="my">
        <view class="swipe-delete-btn" catchtap="deleteActivity" data-id="{{item.id}}" data-type="my" data-iscreator="true">
          <text class="delete-text">删除</text>
        </view>
        <view class="activity-card card anim-slide-up {{item.swiping ? 'swiping' : ''}}" style="transform: translateX({{item.translateX || 0}}px)" bindtouchstart="onSwipeTouchStart" bindtouchmove="onSwipeTouchMove" bindtouchend="onSwipeTouchEnd" data-index="{{index}}" data-type="my">
          <view class="activity-main" bindtap="goToActivityDetail" data-id="{{item.id}}">
            <image class="activity-image" src="{{item.image}}" mode="aspectFill" />
            <view class="activity-info">
              <view class="activity-header-row">
                <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              </view>
              <text class="activity-title">{{item.title}}</text>
              <text class="activity-shop">{{item.shopName}}</text>
              <view class="activity-meta">
                <text class="activity-time">{{item.time}}</text>
                <text class="activity-participants">{{item.participantCount}}人参与</text>
              </view>
            </view>
            <view class="activity-right" catchtap="onRightAreaTap">
              <text class="activity-status {{item.status}}">{{item.statusName}}</text>
              <view class="spacer"></view>
              <button class="btn btn-secondary btn-small" catchtap="goToManage" data-id="{{item.id}}">管理</button>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 我参与的活动 -->
    <block wx:if="{{activeTab === 'participated'}}">
      <view class="swipe-item" wx:for="{{participatedActivities}}" wx:key="id" data-index="{{index}}" data-type="participated">
        <view class="swipe-delete-btn" catchtap="deleteActivity" data-id="{{item.id}}" data-type="participated" data-iscreator="{{item.isCreator}}">
          <text class="delete-text">{{item.isCreator ? '删除' : '退出'}}</text>
        </view>
        <view class="activity-card card anim-slide-up {{item.swiping ? 'swiping' : ''}}" style="transform: translateX({{item.translateX || 0}}px)" bindtouchstart="onSwipeTouchStart" bindtouchmove="onSwipeTouchMove" bindtouchend="onSwipeTouchEnd" data-index="{{index}}" data-type="participated">
          <view class="activity-main" bindtap="goToActivityDetail" data-id="{{item.id}}">
            <image class="activity-image" src="{{item.image}}" mode="aspectFill" />
            <view class="activity-info">
              <view class="activity-header-row">
                <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              </view>
              <text class="activity-title">{{item.title}}</text>
              <text class="activity-shop">{{item.shopName}}</text>
              <view class="activity-meta">
                <text class="activity-time">{{item.time}}</text>
                <text class="activity-participants">{{item.participantCount}}人参与</text>
              </view>
            </view>
            <view class="activity-right">
              <text class="activity-status {{item.status}}">{{item.statusName}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{(activeTab === 'ongoing' && ongoingActivities.length === 0) || (activeTab === 'my' && myActivities.length === 0) || (activeTab === 'participated' && participatedActivities.length === 0)}}">
      <image class="empty-icon" src="/assets/images/sleeping-cat-icon.png" mode="aspectFit" />
      <text class="empty-text">暂无相关活动</text>
      <text class="empty-subtext">去发现美食或发起拼单吧</text>
    </view>

    <!-- 底部渐变遮罩 -->
    <view class="bottom-fade-mask" wx:if="{{(activeTab === 'ongoing' && ongoingActivities.length > 0) || (activeTab === 'my' && myActivities.length > 0) || (activeTab === 'participated' && participatedActivities.length > 0)}}"></view>
  </scroll-view>

  <!-- 发起拼单按钮 -->
  <view class="create-btn-wrapper">
    <button class="btn btn-primary btn-large" bindtap="showCreateOptions">
      <text class="btn-icon">+</text>
      <text>发起拼单</text>
    </button>
  </view>

  <!-- 创建选项弹窗 -->
  <view class="create-modal" wx:if="{{showCreateModal}}" bindtap="closeCreateModal">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">发起拼单</text>
        <text class="modal-close" bindtap="closeCreateModal">×</text>
      </view>
      <view class="modal-body">
        <view class="create-option" bindtap="createGroupOrder" data-type="meal">
          <view class="option-icon">🍱</view>
          <view class="option-info">
            <text class="option-title">拼饭</text>
            <text class="option-desc">一起点外卖，省配送费</text>
          </view>
        </view>
        <view class="create-option" bindtap="createGroupOrder" data-type="milktea">
          <view class="option-icon">🧋</view>
          <view class="option-info">
            <text class="option-title">拼奶茶</text>
            <text class="option-desc">下午茶一起喝</text>
          </view>
        </view>
        <view class="create-option" bindtap="createDining">
          <view class="option-icon">🍽️</view>
          <view class="option-info">
            <text class="option-title">聚餐</text>
            <text class="option-desc">发起聚餐投票</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
