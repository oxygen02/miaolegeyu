<view class="fish-tank-page">
  <!-- 顶部橘红色区域 -->
  <view class="header-section">
    <view class="header-content">
      <view class="header-avatar-wrapper">
        <image class="header-avatar" src="{{imagePaths.decorations.catAvatarIcon}}" mode="aspectFit" />
      </view>
      <text class="header-title">喵不喵</text>
      <text class="header-subtitle">拼美食 · 拼奶茶 · 拼生活</text>
    </view>
    <image class="header-tail" src="{{imagePaths.banners.maoweiba}}" mode="aspectFit" />
  </view>

  <!-- 视图模式切换 -->
  <view class="view-mode-bar">
    <view class="mode-item {{viewMode === 'all' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="all">
      <text>全部</text>
    </view>
    <view class="mode-item {{viewMode === 'dining' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="dining">
      <text>聚餐</text>
    </view>
    <view class="mode-item {{viewMode === 'meal' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="meal">
      <text>约饭</text>
    </view>
    <view class="mode-item {{viewMode === 'group' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="group">
      <text>拼单</text>
    </view>
    <view class="mode-item {{viewMode === 'scheduleVote' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="scheduleVote">
      <text>时间投票</text>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'ongoing' ? 'active' : ''}}" bindtap="switchTab" data-tab="ongoing">
      <text>正在进行</text>
      <text class="tab-badge" wx:if="{{ongoingCount > 0}}">{{ongoingCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'my' ? 'active' : ''}}" bindtap="switchTab" data-tab="my">
      <text>我发起的</text>
      <text class="tab-badge" wx:if="{{myCount > 0}}">{{myCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'participated' ? 'active' : ''}}" bindtap="switchTab" data-tab="participated">
      <text>我参与的</text>
      <text class="tab-badge" wx:if="{{participatedCount > 0}}">{{participatedCount}}</text>
    </view>
    <!-- 编辑按钮 -->
    <view class="edit-btn" bindtap="toggleEditMode" wx:if="{{!isEditMode}}">
      <text>编辑</text>
    </view>
    <view class="edit-btn cancel" bindtap="toggleEditMode" wx:if="{{isEditMode}}">
      <text>取消</text>
    </view>
  </view>

  <!-- 顶部批量操作栏 -->
  <view class="top-action-bar" wx:if="{{isEditMode}}">
    <view class="top-select-all" bindtap="selectAll">
      <view class="checkbox {{isAllSelected ? 'checked' : ''}}">
        <text wx:if="{{isAllSelected}}">✓</text>
      </view>
      <text class="select-all-text">全选</text>
    </view>
    <view class="top-info">
      <text>已选 {{selectedCount}} 项</text>
    </view>
    <view class="top-actions">
      <button class="btn btn-danger btn-small {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="batchDelete">{{batchDeleteText}}</button>
    </view>
  </view>

  <!-- 活动列表 -->
  <scroll-view class="activity-list" scroll-y="true" enhanced="true" show-scrollbar="false">
    <!-- 正在进行的活动 -->
    <block wx:if="{{activeTab === 'ongoing'}}">
      <view class="activity-card card anim-slide-up {{item.selected ? 'selected' : ''}} {{item.type === 'scheduleVote' ? 'schedule-vote-card' : ''}}" wx:for="{{ongoingActivities}}" wx:key="id" data-index="{{index}}" data-type="ongoing" bindtap="onCardTap" data-id="{{item.id}}">
        <!-- 左上角复选框 -->
        <view class="checkbox-top-left" wx:if="{{isEditMode}}" catchtap="toggleSelect" data-index="{{index}}" data-type="ongoing">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>
        <view class="activity-main">
          <!-- 时间投票左侧图标区域 -->
          <view class="activity-image schedule-vote-image" wx:if="{{item.type === 'scheduleVote'}}">
            <image class="sv-taiyaki-icon" src="/images/taiyaki-icon.png" mode="aspectFit" />
          </view>
          <image class="activity-image" src="{{item.image}}" mode="aspectFill" catchtap="previewImage" data-src="{{item.image}}" binderror="onImageError" data-index="{{index}}" data-type="ongoing" wx:else/>
          <view class="activity-info">
            <view class="activity-header-row">
              <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              <view class="creator-info" wx:if="{{item.type !== 'scheduleVote'}}">
                <image class="creator-avatar" src="{{item.creatorAvatarUrl}}" mode="aspectFill" />
                <text class="creator-name">{{item.creatorNickName}}</text>
              </view>
              <view class="schedule-vote-dates" wx:if="{{item.type === 'scheduleVote'}}">
                <text class="sv-date-text">{{item.shopName}}</text>
              </view>
            </view>
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-shop" wx:if="{{item.type !== 'scheduleVote'}}">{{item.shopNameStr || item.shopName}}</text>
            <view class="activity-meta">
              <text class="activity-time {{item.deadlineUrgent ? 'urgent' : ''}}">截止: {{item.time}}{{item.deadlineCountdown ? (' (' + item.deadlineCountdown + ')') : ''}}</text>
            </view>
            <!-- 参与用户头像 -->
            <view class="participant-avatars" wx:if="{{item.participantAvatars.length > 0 && item.type !== 'scheduleVote'}}">
              <view class="avatar-list">
                <image
                  wx:for="{{item.participantAvatars}}"
                  wx:key="index"
                  class="participant-avatar {{index > 0 ? 'avatar-overlap' : ''}}"
                  src="{{item.avatarUrl}}"
                  mode="aspectFill"
                  style="z-index: {{item.participantAvatars.length - index}};"
                />
              </view>
              <text class="participant-count">{{item.participantCount}}人参与</text>
            </view>
            <view class="schedule-vote-participants" wx:if="{{item.type === 'scheduleVote'}}">
              <text class="sv-participant-count">{{item.participantCount}}人已填写</text>
            </view>
          </view>
          <view class="activity-right" catchtap="onRightAreaTap">
            <text class="activity-status {{item.status}}">{{item.statusName}}</text>
            <view class="activity-stats" wx:if="{{item.type === 'group'}}">
              <text class="stats-text">已凑 ¥{{item.currentAmount}}/¥{{item.targetAmount}}</text>
            </view>
            <view class="spacer" wx:else></view>
            <button class="btn btn-primary btn-small" catchtap="_lockedJoinActivity" data-id="{{item.id}}" data-type="{{item.type}}" wx:if="{{!isEditMode && item.type !== 'scheduleVote'}}">立即参加</button>
            <button class="btn btn-schedule btn-small" catchtap="_lockedJoinActivity" data-id="{{item.id}}" data-type="{{item.type}}" wx:if="{{!isEditMode && item.type === 'scheduleVote'}}">去填写</button>
          </view>
        </view>
      </view>
    </block>

    <!-- 我发起的活动 -->
    <block wx:if="{{activeTab === 'my'}}">
      <view class="activity-card card anim-slide-up {{item.selected ? 'selected' : ''}} {{item.type === 'scheduleVote' ? 'schedule-vote-card' : ''}}" wx:for="{{myActivities}}" wx:key="id" data-index="{{index}}" data-type="my" bindtap="onCardTap" data-id="{{item.id}}">
        <!-- 左上角复选框 -->
        <view class="checkbox-top-left" wx:if="{{isEditMode}}" catchtap="toggleSelect" data-index="{{index}}" data-type="my">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>
        <view class="activity-main">
          <!-- 时间投票左侧图标区域 -->
          <view class="activity-image schedule-vote-image" wx:if="{{item.type === 'scheduleVote'}}">
            <image class="sv-taiyaki-icon" src="/images/taiyaki-icon.png" mode="aspectFit" />
          </view>
          <image class="activity-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" data-type="my" wx:else/>
          <view class="activity-info">
            <view class="activity-header-row">
              <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              <view class="schedule-vote-dates" wx:if="{{item.type === 'scheduleVote'}}">
                <text class="sv-date-text">{{item.shopName}}</text>
              </view>
            </view>
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-shop" wx:if="{{item.type !== 'scheduleVote'}}">{{item.shopName}}</text>
            <view class="activity-meta">
              <text class="activity-time {{item.deadlineUrgent ? 'urgent' : ''}}">截止: {{item.time}}{{item.deadlineCountdown ? (' (' + item.deadlineCountdown + ')') : ''}}</text>
              <text class="activity-participants" wx:if="{{item.type !== 'scheduleVote'}}">{{item.participantCount}}人参与</text>
              <text class="activity-participants sv-participant-count" wx:if="{{item.type === 'scheduleVote'}}">{{item.participantCount}}人已填写</text>
            </view>
          </view>
          <view class="activity-right" catchtap="onRightAreaTap">
            <text class="activity-status {{item.status}}">{{item.statusName}}</text>
            <view class="spacer"></view>
            <button class="btn btn-secondary btn-small" catchtap="goToManage" data-id="{{item.id}}" wx:if="{{!isEditMode && item.type !== 'scheduleVote'}}">管理</button>
            <button class="btn btn-schedule btn-small" catchtap="goToManage" data-id="{{item.id}}" wx:if="{{!isEditMode && item.type === 'scheduleVote'}}">查看结果</button>
          </view>
        </view>
      </view>
    </block>

    <!-- 我参与的活动 -->
    <block wx:if="{{activeTab === 'participated'}}">
      <view class="activity-card card anim-slide-up {{item.selected ? 'selected' : ''}} {{item.type === 'scheduleVote' ? 'schedule-vote-card' : ''}}" wx:for="{{participatedActivities}}" wx:key="id" data-index="{{index}}" data-type="participated" bindtap="onCardTap" data-id="{{item.id}}">
        <!-- 左上角复选框 -->
        <view class="checkbox-top-left" wx:if="{{isEditMode}}" catchtap="toggleSelect" data-index="{{index}}" data-type="participated">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>
        <view class="activity-main">
          <!-- 时间投票左侧图标区域 -->
          <view class="activity-image schedule-vote-image" wx:if="{{item.type === 'scheduleVote'}}">
            <image class="sv-taiyaki-icon" src="/images/taiyaki-icon.png" mode="aspectFit" />
          </view>
          <image class="activity-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" data-type="participated" wx:else/>
          <view class="activity-info">
            <view class="activity-header-row">
              <view class="activity-type-tag {{item.type}}">{{item.typeName}}</view>
              <view class="schedule-vote-dates" wx:if="{{item.type === 'scheduleVote'}}">
                <text class="sv-date-text">{{item.shopName}}</text>
              </view>
            </view>
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-shop" wx:if="{{item.type !== 'scheduleVote'}}">{{item.shopName}}</text>
            <view class="activity-meta">
              <text class="activity-time {{item.deadlineUrgent ? 'urgent' : ''}}">截止: {{item.time}}{{item.deadlineCountdown ? (' (' + item.deadlineCountdown + ')') : ''}}</text>
              <text class="activity-participants" wx:if="{{item.type !== 'scheduleVote'}}">{{item.participantCount}}人参与</text>
              <text class="activity-participants sv-participant-count" wx:if="{{item.type === 'scheduleVote'}}">{{item.participantCount}}人已填写</text>
            </view>
          </view>
          <view class="activity-right">
            <text class="activity-status {{item.status}}">{{item.statusName}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{(activeTab === 'ongoing' && ongoingActivities.length === 0) || (activeTab === 'my' && myActivities.length === 0) || (activeTab === 'participated' && participatedActivities.length === 0)}}">
      <image class="empty-icon" src="{{imagePaths.decorations.sleepingCatIcon}}" mode="aspectFit" />
      <text class="empty-text">暂无相关活动</text>
      <text class="empty-subtext">去新店探索或发起拼单吧</text>
    </view>

    </scroll-view>

  <!-- 底部浮动发起按钮 - 编辑模式下隐藏 -->
  <view class="floating-create-bar" bindtap="showCreateOptions" wx:if="{{!isEditMode}}">
    <view class="create-icon-wrapper">
      <image class="create-icon" src="{{imagePaths.misc.catPawIcon}}" mode="aspectFit" />
      <image class="create-icon" src="{{imagePaths.misc.catPawIcon}}" mode="aspectFit" />
    </view>
    <text class="create-text">发起拼单</text>
  </view>

  <!-- 创建选项弹窗 -->
  <view class="create-modal" wx:if="{{showCreateModal}}" bindtap="closeCreateModal">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">发起拼单</text>
        <text class="modal-close" bindtap="closeCreateModal">×</text>
      </view>
      <view class="modal-body">
        <view class="create-option" bindtap="createGroupOrder" data-type="meal">
          <view class="option-icon">🍱</view>
          <view class="option-info">
            <text class="option-title">拼饭</text>
            <text class="option-desc">一起点外卖，省配送费</text>
          </view>
        </view>
        <view class="create-option" bindtap="createGroupOrder" data-type="milktea">
          <view class="option-icon">🧋</view>
          <view class="option-info">
            <text class="option-title">拼奶茶</text>
            <text class="option-desc">下午茶一起喝</text>
          </view>
        </view>
        <view class="create-option" bindtap="createDining">
          <view class="option-icon">🍽️</view>
          <view class="option-info">
            <text class="option-title">聚餐</text>
            <text class="option-desc">聚餐发起投票</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
