.fish-tank-page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
}

/* 头部 */
.page-header {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  padding: 40rpx 32rpx;
  flex-shrink: 0;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.header-text {
  flex: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

/* 视图模式切换 */
.view-mode-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.mode-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.mode-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #f5f5f5;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #FF9F43;
}

.tab-item text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

.tab-item.active text {
  color: #fff;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #FF6B6B;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-badge {
  background: #fff;
  color: #FF9F43;
}

/* 外卖平台 */
.platform-section {
  background: #fff;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.platform-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.platform-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: linear-gradient(135deg, #FFF5E9 0%, #FFECD2 100%);
}

.platform-name {
  font-size: 24rpx;
  color: #333;
}

/* 活动列表 */
.activity-list {
  flex: 1;
  padding: 0 24rpx;
  overflow-y: auto;
}

.activity-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

/* 左滑删除 */
.swipe-item {
  position: relative;
  overflow: hidden;
}

.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF4757 0%, #FF6B81 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 16rpx 16rpx 0;
}

.swipe-delete-btn .delete-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.activity-card.swiping {
  transition: none;
}

.activity-card:last-child {
  margin-bottom: 0;
}

.activity-main {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.activity-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.activity-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  margin-left: 12rpx;
  min-width: 100rpx;
  flex-shrink: 0;
}

.activity-right .activity-status {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

.activity-right .activity-status.voting {
  color: #4CAF50;
}

.activity-right .spacer {
  flex: 1;
  min-height: 20rpx;
}

.activity-right .activity-stats {
  flex: 1;
  display: flex;
  align-items: center;
}

.activity-right .stats-text {
  font-size: 20rpx;
  color: #666;
  white-space: nowrap;
}

.activity-right .btn {
  margin-top: auto;
  flex-shrink: 0;
}

.activity-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.activity-type-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-type-tag.dining {
  background: #E8F5E9;
  color: #4CAF50;
}

.activity-type-tag.group {
  background: #FFF3E0;
  color: #FF9800;
}

.activity-status {
  font-size: 22rpx;
  color: #999;
}

.activity-status.voting {
  color: #4CAF50;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-shop {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
}

.activity-time {
  font-size: 22rpx;
  color: #666;
}

.activity-participants {
  font-size: 22rpx;
  color: #FF9F43;
}

/* 按钮 */
.btn {
  border: none;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  color: #fff;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
  min-width: 120rpx;
}

.btn-large {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  font-weight: 600;
}

/* 底部浮动发起按钮 - 双脚印+飘带动画 */
.floating-create-bar {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: fit-content;
  height: auto;
  background: #FF9F43;
  border-radius: 36rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  z-index: 100;
  padding: 16rpx 40rpx;
  box-sizing: border-box;
  transition: all 0.15s ease;
}

.floating-create-bar:active {
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateX(-50%) translateY(2rpx);
}

.create-icon-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.create-icon {
  width: 40rpx;
  height: 40rpx;
}

.create-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
  animation: floatText 2s ease-in-out 3;
}

@keyframes floatText {
  0% {
    transform: rotate(-2deg) translateY(0);
  }
  25% {
    transform: rotate(-2deg) translateY(-4rpx);
  }
  50% {
    transform: rotate(-2deg) translateY(2rpx);
  }
  75% {
    transform: rotate(-2deg) translateY(-2rpx);
  }
  100% {
    transform: rotate(0deg) translateY(0);
  }
}

/* 弹窗 */
.create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.create-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFF5E9 0%, #FFECD2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.option-info {
  flex: 1;
}

.option-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 历史卡片 */
.history-card {
  opacity: 0.8;
}

/* 底部渐变遮罩 */
.bottom-fade-mask {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(255, 250, 245, 0.95) 0%, rgba(255, 250, 245, 0.7) 50%, transparent 100%);
  pointer-events: none;
  z-index: 10;
}
