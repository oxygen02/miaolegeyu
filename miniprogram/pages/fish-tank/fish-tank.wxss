.fish-tank-page {
  min-height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
}

/* 顶部橘红色区域 */
.header-section {
  background: linear-gradient(180deg, #FF9F43 0%, #FFB347 100%);
  padding: 30rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10;
  flex-shrink: 0;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-content {
  flex: 1;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像外圈 */
.header-avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7B1A 100%);
  padding: 6rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.header-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

/* 猫尾巴 - 歪歪的在右下角 */
.header-tail {
  width: 120rpx;
  height: 120rpx;
  position: absolute;
  right: -20rpx;
  bottom: -30rpx;
  z-index: 2;
  transform: rotate(-15deg);
}

/* 视图模式切换 */
.view-mode-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #F5F0E8;
}

.mode-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.mode-item.active {
  background: #FF9F43;
  color: #fff;
  font-weight: 600;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #F5F0E8;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: #F5F0E8;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #FF9F43;
}

.tab-item text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

.tab-item.active text {
  color: #fff;
  font-weight: 600;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #FF6B6B;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-badge {
  background: #fff;
  color: #FF9F43;
}

/* 外卖平台 */
.platform-section {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E0 100%);
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border-top: 2rpx solid #3D3D3D;
  border-left: 2rpx solid #3D3D3D;
  border-bottom: 4rpx solid #3D3D3D;
  border-right: 4rpx solid #3D3D3D;
  box-shadow: 2rpx 3rpx 0 rgba(61, 61, 61, 0.15);
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.platform-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.platform-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: linear-gradient(135deg, #FFF5E9 0%, #FFECD2 100%);
  border: 2rpx solid #3D3D3D;
}

.platform-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 活动列表 */
.activity-list {
  flex: 1;
  padding: 0 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* 活动卡片 - 统一风格 */
.activity-card {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E0 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-top: 3rpx solid #3D3D3D;
  border-left: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
  box-shadow: 3rpx 4rpx 0 rgba(61, 61, 61, 0.15);
  transition: all 0.2s ease;
  box-sizing: border-box;
  width: 100%;
}

.activity-card:active {
  transform: translateY(2rpx);
  box-shadow: 1rpx 2rpx 0 rgba(61, 61, 61, 0.15);
}

/* 左滑删除 */
.swipe-item {
  position: relative;
  overflow: hidden;
}

.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF4757 0%, #FF6B81 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  border-top: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
}

.swipe-delete-btn .delete-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.activity-card.swiping {
  transition: none;
}

.activity-card:last-child {
  margin-bottom: 0;
}

.activity-main {
  display: flex;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.activity-image {
  width: 172rpx;
  height: 172rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  flex-shrink: 0;
  border: 4rpx solid #3D3D3D;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.activity-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  margin-left: 12rpx;
  min-width: 100rpx;
  flex-shrink: 0;
}

.activity-right .activity-status {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  font-weight: 600;
}

.activity-right .activity-status.voting {
  color: #4CAF50;
}

.activity-right .spacer {
  flex: 1;
  min-height: 20rpx;
}

.activity-right .activity-stats {
  flex: 1;
  display: flex;
  align-items: center;
}

.activity-right .stats-text {
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
}

.activity-right .btn {
  margin-top: auto;
  flex-shrink: 0;
}

.activity-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

/* 发起人信息 */
.creator-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.creator-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #3D3D3D;
}

.creator-name {
  font-size: 22rpx;
  color: #666;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-type-tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid #3D3D3D;
}

.activity-type-tag.dining {
  background: #E8F5E9;
  color: #4CAF50;
}

.activity-type-tag.group {
  background: #FFF3E0;
  color: #FF9800;
}

.activity-type-tag.meal {
  background: #E3F2FD;
  color: #2196F3;
}

.activity-status {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

.activity-status.voting {
  color: #4CAF50;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3D3D;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-shop {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.activity-participants {
  font-size: 24rpx;
  color: #FF9F43;
  font-weight: 600;
}

/* 参与用户头像 */
.participant-avatars {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.avatar-list {
  display: flex;
  align-items: center;
  height: 48rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  background: #f5f5f5;
}

.avatar-overlap {
  margin-left: -16rpx;
}

.participant-count {
  font-size: 24rpx;
  color: #999;
}

/* 按钮 - 统一风格 */
.btn {
  border: none;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #FF9F43;
  color: #fff;
  border: 3rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #3D3D3D;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
  min-width: 120rpx;
  font-weight: 600;
}

.btn-large {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border-radius: 40rpx;
  font-weight: 600;
  border: 4rpx solid #3D3D3D;
  box-shadow: 3rpx 3rpx 0 #3D3D3D;
}

.btn-primary:active {
  box-shadow: 1rpx 1rpx 0 #3D3D3D;
  transform: translateY(1rpx);
}

/* 底部浮动发起按钮 - 统一风格 */
.floating-create-bar {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: fit-content;
  height: auto;
  background: #FF9F43;
  border-radius: 40rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 4rpx solid #3D3D3D;
  box-shadow: 4rpx 4rpx 0 #3D3D3D;
  z-index: 100;
  padding: 20rpx 48rpx;
  box-sizing: border-box;
  transition: all 0.15s ease;
}

.floating-create-bar:active {
  box-shadow: 2rpx 2rpx 0 #3D3D3D;
  transform: translateX(-50%) translateY(2rpx);
}

.create-icon-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.create-icon {
  width: 40rpx;
  height: 40rpx;
}

.create-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
  animation: floatText 2s ease-in-out 3;
}

@keyframes floatText {
  0% {
    transform: rotate(-2deg) translateY(0);
  }
  25% {
    transform: rotate(-2deg) translateY(-4rpx);
  }
  50% {
    transform: rotate(-2deg) translateY(2rpx);
  }
  75% {
    transform: rotate(-2deg) translateY(-2rpx);
  }
  100% {
    transform: rotate(0deg) translateY(0);
  }
}

/* 弹窗 */
.create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #F5F0E8;
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D3D3D;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.create-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E0 100%);
  border-radius: 16rpx;
  border-top: 2rpx solid #3D3D3D;
  border-left: 2rpx solid #3D3D3D;
  border-bottom: 4rpx solid #3D3D3D;
  border-right: 4rpx solid #3D3D3D;
  box-shadow: 2rpx 3rpx 0 rgba(61, 61, 61, 0.15);
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF5E9 0%, #FFECD2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 3rpx solid #3D3D3D;
}

.option-info {
  flex: 1;
}

.option-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3D3D;
  display: block;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}

/* 历史卡片 */
.history-card {
  opacity: 0.8;
}

/* 底部渐变遮罩 */
.bottom-fade-mask {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(245, 240, 232, 0.95) 0%, rgba(245, 240, 232, 0.7) 50%, transparent 100%);
  pointer-events: none;
  z-index: 10;
}
