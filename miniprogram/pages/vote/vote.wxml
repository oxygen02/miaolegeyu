<view class="vote-page">
  <!-- 密码输入弹窗 -->
  <view class="password-modal" wx:if="{{showPasswordModal}}">
    <view class="password-mask"></view>
    <view class="password-content">
      <image class="password-cat" src="{{imagePaths.decorations.juzeAvatar}}" mode="aspectFit"/>
      <text class="password-title">该房间需要密码</text>
      <text class="password-subtitle">请输入房间密码加入</text>
      <input 
        class="password-input" 
        type="text" 
        maxlength="6"
        placeholder="请输入4-6位密码"
        value="{{inputPassword}}"
        bindinput="onPasswordInput"
      />
      <view class="password-btn {{inputPassword.length >= 4 ? 'active' : ''}}" bindtap="submitPassword">
        <text>确认加入</text>
      </view>
    </view>
  </view>

  <!-- 顶部渐变区域 -->
  <view class="header-section">
    <view class="header-content">
      <text class="room-title">{{room.title || '投票中'}}</text>
      <text class="progress-text" wx:if="{{mode === 'a'}}">{{currentIndex + 1}} / {{posters.length}}</text>
      <block wx:if="{{mode === 'b'}}">
        <text class="progress-text" wx:if="{{currentStep === 'category'}}">选大类 {{categoryCurrentIndex + 1}} / {{categoryCards.length}} (已选{{selectedCategoryIds.length}}/3)</text>
        <text class="progress-text" wx:if="{{currentStep === 'subcategory'}}">{{subCategoryCurrentIndex + 1}} / {{subCategoryCards.length}} (每个大类选1个)</text>
      </block>
    </view>
    <image class="header-tail" src="{{imagePaths.banners.maoweiba}}" mode="aspectFit" />
  </view>

  <!-- ========== Mode A: 海报投票（抖音式上下滑动） ========== -->
  <block wx:if="{{mode === 'a'}}">
    <view class="swiper-wrapper-a">
      <swiper 
        class="full-swiper" 
        vertical
        bindchange="onCardChange"
        current="{{currentIndex}}"
      >
        <swiper-item wx:for="{{posters}}" wx:key="index">
          <view class="full-card {{index < posters.length - 1 ? 'has-next' : ''}}">
            <!-- 叠层效果 -->
            <view class="card-stack-layer" wx:if="{{index < posters.length - 1}}"></view>
            
            <image class="full-img" src="{{item.imageUrl}}" mode="aspectFill" bindtap="onTapCard" data-index="{{index}}"/>
            
            <!-- 否决印章 - 只在非喜欢状态下显示 -->
            <view class="veto-stamp" wx:if="{{item.isVetoed && !item.isLiked}}">
              <image class="stamp-cat" src="{{imagePaths.decorations.angryCat}}" mode="aspectFit"/>
              <text class="stamp-text">不想喵</text>
            </view>

            <!-- 爱心猫咪特效 -->
            <view class="love-cat-effect {{showLoveCat && loveCatIndex === index ? 'show' : ''}}">
              <image class="love-cat-img" src="{{imagePaths.decorations.loveCatIcon}}" mode="aspectFit"/>
              <text class="love-cat-text">想要喵</text>
            </view>

            <!-- 底部文字遮罩 -->
            <view class="card-overlay">
              <text class="card-title">{{item.shopName || '推荐餐厅'}}</text>
              <text class="card-desc">上滑跳过 · 双击选择</text>
            </view>
          </view>
        </swiper-item>
      </swiper>

      <!-- 操作栏 - 固定在 swiper 右侧，不随卡片切换移动 -->
      <view class="action-bar">
        <view class="action-btn action-prev" catchtap="onPrev" data-index="{{currentIndex}}">
          <text class="btn-icon">↑</text>
          <text class="btn-label">上张</text>
        </view>
        <view class="action-btn action-like {{posters[currentIndex].isLiked ? 'active' : ''}}" catchtap="toggleLike" data-index="{{currentIndex}}">
          <text class="btn-icon">♥</text>
          <text class="btn-label">想要</text>
        </view>
        <view class="action-btn action-next" catchtap="onNext" data-index="{{currentIndex}}">
          <text class="btn-icon">↓</text>
          <text class="btn-label">下张</text>
        </view>
        <view class="action-btn action-fav {{posters[currentIndex].isFav ? 'active' : ''}}" catchtap="toggleFav" data-index="{{currentIndex}}">
          <text class="btn-icon">★</text>
          <text class="btn-label">收藏</text>
        </view>
        <view class="action-btn action-reset {{posters[currentIndex].isLiked || posters[currentIndex].isVetoed ? '' : 'disabled'}}" catchtap="resetChoice" data-index="{{currentIndex}}">
          <text class="btn-icon">↺</text>
          <text class="btn-label">重选</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{currentIndex >= posters.length}}">
      <image class="empty-cat-image" src="{{imagePaths.decorations.winkCatIcon}}" mode="aspectFit" />
      <text class="empty-text">都筛完了，去提交吧</text>
    </view>
  </block>

  <!-- ========== Mode B: 两级餐饮分类选择（网格快速选择） ========== -->
  <block wx:if="{{mode === 'b'}}">
    <!-- 第一级：大类选择 - 4×5网格 -->
    <block wx:if="{{currentStep === 'category'}}">
      <view class="category-grid-container">
        <view class="category-grid-header">
          <text class="grid-title">选择你喜欢的大类（最多3个）</text>
          <text class="grid-count">已选：{{selectedCategoryIds.length}}/3</text>
        </view>
        
        <view class="category-grid">
          <view 
            class="category-grid-item {{item.isSelected ? 'selected' : ''}}" 
            wx:for="{{categoryCards}}" 
            wx:key="index"
            bindtap="toggleCategoryGridSelect"
            data-index="{{index}}"
            style="background: {{item.isSelected ? item.darkColor || item.color : item.color}};"
          >
            <text class="grid-item-pinyin">{{item.pinyin}}</text>
            <text class="grid-item-icon">{{item.icon}}</text>
            <text class="grid-item-name">{{item.name}}</text>
            <view class="grid-item-check" wx:if="{{item.isSelected}}">✓</view>
          </view>
        </view>
        
        <!-- 已选大类展示 -->
        <view class="selected-categories-bar" wx:if="{{selectedCategoryIds.length > 0}}">
          <view class="selected-tags-row">
            <view class="selected-tag-bar" wx:for="{{selectedCategoryIds}}" wx:key="*this" style="background: {{item.darkColor || item.color}};">
              {{item.name}}
            </view>
          </view>
          <button class="btn-next-grid" bindtap="goToSubCategory">下一步</button>
        </view>
        <!-- 未选大类时的提示 -->
        <view class="selected-categories-bar empty" wx:if="{{selectedCategoryIds.length === 0}}">
          <text class="empty-hint">请选择至少一个大类</text>
          <button class="btn-next-grid disabled" disabled>下一步</button>
        </view>
      </view>
    </block>

    <!-- 第二级：细类选择 -->
    <block wx:if="{{currentStep === 'subcategory'}}">
      <!-- 已选细类展示 -->
      <view class="selected-subcategories-bar" wx:if="{{selectedSubCategoryNames.length > 0}}">
        <text class="selected-sub-title">已选：</text>
        <view class="selected-sub-tags">
          <text class="selected-sub-tag" wx:for="{{selectedSubCategoryNames}}" wx:key="index">{{item}}</text>
        </view>
      </view>
      
      <!-- 单图片swiper展示 -->
      <view class="swiper-wrapper-b">
        <swiper
          class="subcategory-swiper"
          vertical
          bindchange="onSubCategoryChange"
          current="{{subCategorySwiperCurrent}}"
        >
          <swiper-item wx:for="{{visibleSubCategoryCards}}" wx:key="index">
            <view class="subcategory-card">
              <image
                class="subcategory-full-img"
                src="{{item.image}}"
                mode="aspectFill"
                bindtap="onSubCategoryTap"
                data-index="{{index}}"
                lazy-load
              />
              
              <!-- 底部文字遮罩 -->
              <view class="subcategory-overlay">
                <text class="subcategory-title">{{item.name}}</text>
                <text class="subcategory-desc">{{item.categoryName}}</text>
              </view>
              
              <!-- 选中标记 -->
              <view class="subcategory-selected-mark" wx:if="{{item.isSelected}}">
                <text class="mark-icon">✓</text>
                <text class="mark-text">已选</text>
              </view>
            </view>
          </swiper-item>
        </swiper>

        <!-- 操作栏 - 固定在 swiper 右侧，不随卡片切换移动 -->
        <view class="subcategory-action-bar">
          <view class="action-btn action-prev" catchtap="onSubCategoryPrev">
            <text class="btn-icon">↑</text>
            <text class="btn-label">上张</text>
          </view>
          <view class="action-btn action-like {{visibleSubCategoryCards[subCategorySwiperCurrent].isSelected ? 'active' : ''}}" catchtap="toggleCurrentSubCategoryLike">
            <text class="btn-icon">♥</text>
            <text class="btn-label">想吃</text>
          </view>
          <view class="action-btn action-next" catchtap="onSubCategoryNext">
            <text class="btn-icon">↓</text>
            <text class="btn-label">下张</text>
          </view>
          <view class="action-btn action-fav {{visibleSubCategoryCards[subCategorySwiperCurrent].isFav ? 'active' : ''}}" catchtap="toggleCurrentSubCategoryFav">
            <text class="btn-icon">★</text>
            <text class="btn-label">收藏</text>
          </view>
          <view class="action-btn action-finish" catchtap="resetCurrentSubCategory">
            <text class="btn-icon">↺</text>
            <text class="btn-label">重选</text>
          </view>
        </view>
      </view>
    </block>
  </block>

  <!-- 底部操作区 -->
  <view class="bottom-section">
    <!-- 禁忌快速选择 -->
    <view class="taboo-section">
      <view class="taboo-header">
        <text class="taboo-title">口味有壁垒，自带小禁区</text>
        <text class="taboo-count" wx:if="{{selectedHardTaboos.length > 0}}">{{selectedHardTaboos.length}}项</text>
      </view>
      <view class="taboo-list">
        <view class="taboo-group">
          <view class="tag-list">
            <!-- 第一行标签 -->
            <view class="taboo-row">
              <view 
                class="taboo-tag {{item.selected ? 'selected' : ''}}" 
                wx:for="{{hardTaboos}}" 
                wx:for-index="index"
                wx:key="name"
                wx:if="{{index < 7}}"
                bindtap="toggleHardTaboo"
                data-name="{{item.name}}"
              >{{item.label}}</view>
            </view>
            <!-- 第二行标签 -->
            <view class="taboo-row">
              <view 
                class="taboo-tag {{item.selected ? 'selected' : ''}}" 
                wx:for="{{hardTaboos}}" 
                wx:for-index="index"
                wx:key="name"
                wx:if="{{index >= 7}}"
                bindtap="toggleHardTaboo"
                data-name="{{item.name}}"
              >{{item.label}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 时间选择 -->
    <view class="time-section">
      <view class="time-row">
        <view class="time-tabs">
          <view class="time-tab {{timeType === 'departure' ? 'active' : ''}}" bindtap="switchTimeType" data-type="departure">我能出发</view>
          <view class="time-tab {{timeType === 'arrival' ? 'active' : ''}}" bindtap="switchTimeType" data-type="arrival">我能到达</view>
          <view class="time-tab {{timeType === 'leave' ? 'active' : ''}}" bindtap="switchTimeType" data-type="leave">想喵不能喵</view>
        </view>
        
        <block wx:if="{{timeType !== 'leave'}}">
          <view class="time-picker-wrapper-inline">
            <time-picker selectedTime="{{selectedTime}}" bindchange="onTimeChange"></time-picker>
          </view>
        </block>
        
        <block wx:if="{{timeType === 'leave'}}">
          <input 
            class="leave-input-inline" 
            placeholder="请输入原因" 
            value="{{leaveReason}}"
            bindinput="onLeaveReasonInput"
          />
        </block>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="btn-waive" bindtap="waiveVote">弃权</button>
      <button class="btn-submit {{canSubmit ? 'active' : ''}}" bindtap="submitVote">提交</button>
    </view>
  </view>
</view>
