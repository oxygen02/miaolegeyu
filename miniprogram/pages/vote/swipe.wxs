// pages/vote/swipe.wxs
var startX = 0;
var screenW = 375;
var startY = 0;

module.exports = {
  // 初始化屏幕宽度（从页面传入）
  init: function(sW) {
    screenW = sW;
  },

  touchstart: function(event, ownerInstance) {
    var touch = event.changedTouches[0];
    startX = touch.clientX;
    startY = touch.clientY;
    return false;
  },

  touchmove: function(event, ownerInstance) {
    var touch = event.changedTouches[0];
    var dx = touch.clientX - startX;
    var dy = touch.clientY - startY;

    // 忽略纵向为主的手势（防止页面滚动冲突）
    if (Math.abs(dy) > Math.abs(dx) * 0.8) return false;

    var rotate = dx * 0.08;
    var ratio = Math.min(Math.abs(dx) / (screenW * 0.45), 1);
    var nextScale = 0.92 + ratio * 0.08;

    // 直接操作 DOM，不经过 setData
    var card = ownerInstance.selectComponent('.card-front');
    var nextCard = ownerInstance.selectComponent('.card-behind');

    card.setStyle({
      transform: 'translateX(' + dx + 'px) rotate(' + rotate + 'deg)'
    });

    if (nextCard) {
      nextCard.setStyle({
        transform: 'scale(' + nextScale + ')'
      });
    }

    return false;
  },

  touchend: function(event, ownerInstance) {
    var touch = event.changedTouches[0];
    var dx = touch.clientX - startX;
    var threshold = screenW * 0.25;

    if (dx > threshold) {
      ownerInstance.callMethod('wxsSwipeOut', { direction: 1, dx: dx });
    } else if (dx < -threshold) {
      ownerInstance.callMethod('wxsSwipeOut', { direction: -1, dx: dx });
    } else {
      // 回弹
      var card = ownerInstance.selectComponent('.card-front');
      var nextCard = ownerInstance.selectComponent('.card-behind');

      card.setStyle({
        transform: 'translateX(0px) rotate(0deg)',
        transition: 'transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1)'
      });
      if (nextCard) nextCard.setStyle({
        transform: 'scale(0.92)',
        transition: 'transform 0.35s ease'
      });

      // 0.35s 后清除 transition
      setTimeout(function() {
        card.setStyle({ transition: '' });
      }, 350);
    }

    return false;
  }
};
