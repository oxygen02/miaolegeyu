.container {
  padding: 30rpx;
  background: #F5F0E8;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
}

.progress-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.progress-text {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.upload-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 30rpx;
}

.upload-btn.disabled {
  background: #ccc;
}

.status-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  max-height: 800rpx;
  overflow-y: auto;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #f0f0f0;
  color: #666;
}

.status-item.uploading .status-badge {
  background: #FFE4B5;
  color: #FF9F43;
}

.status-item.success .status-badge {
  background: #D4EDDA;
  color: #28a745;
}

.status-item.error .status-badge {
  background: #F8D7DA;
  color: #dc3545;
}
