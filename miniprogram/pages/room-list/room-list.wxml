<view class="room-list-page">
  <!-- 页面标题和房间号输入合并 -->
  <view class="page-header">
    <view class="header-left">
      <text class="page-title">聚餐列表</text>
      <text class="page-subtitle">点击卡片参与投票</text>
    </view>
    <view class="header-right">
      <view class="input-wrapper-inline {{inputFocused ? 'focused' : ''}}">
        <input 
          class="room-input-inline" 
          type="text" 
          placeholder="输入房间号" 
          value="{{inputRoomId}}"
          bindinput="onRoomIdInput"
          bindfocus="onInputFocus"
          bindblur="onInputBlur"
          maxlength="20"
        />
        <view class="enter-btn-inline" bindtap="enterRoomById">
          <text>进入</text>
        </view>
      </view>
    </view>
    <image class="header-tail" src="/assets/images/maoweiba.png" mode="aspectFit" />
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="tab-item {{currentFilter === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">
      <text>全部</text>
    </view>
    <view class="tab-item {{currentFilter === 'active' ? 'active' : ''}}" bindtap="switchFilter" data-filter="active">
      <text>进行中</text>
    </view>
    <view class="tab-item {{currentFilter === 'locked' ? 'active' : ''}}" bindtap="switchFilter" data-filter="locked">
      <text>已结束</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && allRooms.length === 0}}">
    <image class="empty-icon" src="/assets/images/sleeping-cat-icon.png" mode="aspectFit" />
    <text class="empty-text">暂无聚餐活动</text>
    <text class="empty-subtext">输入房间号或等待邀请</text>
  </view>

  <!-- 活动列表 - 横条样式 -->
  <view class="room-list" wx:else>
    <view 
      class="room-item {{cardColors[index % cardColors.length]}}" 
      wx:for="{{allRooms}}" 
      wx:for-index="index"
      wx:key="roomId"
      bindtap="goToRoom"
      data-roomid="{{item.roomId}}"
    >
      <!-- 左侧海报 -->
      <view class="item-poster">
        <image 
          src="{{item.finalPoster || (item.candidatePosters[0] && item.candidatePosters[0].imageUrl) || '/assets/images/taiyaki-icon.png'}}" 
          mode="aspectFill"
        />
      </view>

      <!-- 中间信息 -->
      <view class="item-info">
        <view class="info-header">
          <text class="item-title">{{item.title}}</text>
          <view class="status-badge {{item.status}}">
            {{item.status === 'voting' ? '进行中' : '已结束'}}
          </view>
        </view>
        
        <view class="info-detail">
          <view class="detail-row" wx:if="{{item.activityDate}}">
            <image class="detail-icon" src="/assets/images/calendar-icon.svg" mode="aspectFit" />
            <text class="detail-text">{{item.activityDate}} {{item.activityTime}}</text>
          </view>
          <view class="detail-row" wx:if="{{item.location}}">
            <image class="detail-icon" src="/assets/images/location-icon.svg" mode="aspectFit" />
            <text class="detail-text">{{item.location}}</text>
          </view>
        </view>
        
        <view class="info-footer">
          <image class="creator-avatar-mini" src="{{item.creatorAvatar || '/assets/images/cat-avatar-icon.png'}}" mode="aspectFit" />
          <text class="creator-name-mini">{{item.creatorName}}</text>
          <text class="room-id">房间号: {{item.roomId}}</text>
        </view>
      </view>

    </view>

    <!-- 底部留白 -->
    <view class="bottom-space"></view>
  </view>
</view>
