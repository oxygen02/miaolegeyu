/* pages/room-list/room-list.wxss */
page {
  background-color: #F5F0E8;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.room-list-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  padding: 60rpx 32rpx 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
  display: block;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #F5F0E8;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 32rpx;
  background: #F5F0E8;
  transition: all 0.3s;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active {
  background: #FF9F43;
}

.tab-item.active text {
  color: #fff;
  font-weight: 600;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F5F0E8;
  border-top-color: #FF9F43;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 32rpx;
  font-weight: 500;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 发起人列表 */
.creator-list {
  padding: 20rpx;
  position: relative;
}

/* 发起人卡片 */
.creator-card {
  border-radius: 24rpx;
  border-top: 4rpx solid #3D3D3D;
  border-left: 4rpx solid #3D3D3D;
  border-bottom: 8rpx solid #3D3D3D;
  border-right: 8rpx solid #3D3D3D;
  box-shadow: 4rpx 6rpx 0 rgba(61, 61, 61, 0.15), 8rpx 12rpx 20rpx rgba(61, 61, 61, 0.1);
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: all 0.2s ease;
}

.creator-card.orange {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFE4CC 100%);
}

.creator-card.blue {
  background: linear-gradient(135deg, #F0F8FF 0%, #E6F3FF 100%);
}

.creator-card.green {
  background: linear-gradient(135deg, #F5FFF5 0%, #E6FFE6 100%);
}

.creator-card.pink {
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE6F0 100%);
}

.creator-card.yellow {
  background: linear-gradient(135deg, #FFFAF0 0%, #FFF5E6 100%);
}

.creator-card.purple {
  background: linear-gradient(135deg, #F8F0FF 0%, #F0E6FF 100%);
}

.creator-card:active {
  transform: translateY(4rpx);
  box-shadow: 2rpx 3rpx 0 rgba(61, 61, 61, 0.15), 4rpx 6rpx 10rpx rgba(61, 61, 61, 0.1);
}

/* 发起人头部 */
.creator-header {
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #3D3D3D;
  background: #fff;
}

.creator-meta {
  display: flex;
  flex-direction: column;
}

.creator-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.creator-count {
  font-size: 24rpx;
  color: #8A8A8A;
  margin-top: 4rpx;
}

.creator-arrow {
  font-size: 32rpx;
  color: #8A8A8A;
  transition: transform 0.3s;
}

.creator-arrow.expanded {
  transform: rotate(90deg);
}

/* 房间列表 */
.room-list {
  padding: 0 24rpx;
}

.room-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.05);
}

.room-item:last-child {
  border-bottom: none;
}

.room-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 4rpx solid #3D3D3D;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.room-info {
  flex: 1;
  min-width: 0;
}

.room-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.room-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.room-status.active {
  background: #E8F5E9;
  color: #2E7D32;
}

.room-status.locked {
  background: #FFEBEE;
  color: #C62828;
}

.room-participants {
  font-size: 24rpx;
  color: #8A8A8A;
}

.room-arrow {
  font-size: 32rpx;
  color: #8A8A8A;
  margin-left: 16rpx;
}

/* 折叠时的预览 */
.room-preview {
  padding: 20rpx 24rpx;
}

.preview-list {
  display: flex;
  align-items: center;
}

.preview-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 4rpx solid #3D3D3D;
  margin-right: -20rpx;
  position: relative;
  z-index: 1;
}

.preview-thumb.overlap {
  z-index: 0;
}

.more-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F5F0E8;
  border: 4rpx solid #3D3D3D;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.more-badge text {
  font-size: 24rpx;
  color: #8A8A8A;
  font-weight: 600;
}

/* 底部渐变遮罩 */
.bottom-fade-mask {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(to top, rgba(245, 240, 232, 0.95) 0%, rgba(245, 240, 232, 0.7) 50%, transparent 100%);
  pointer-events: none;
  z-index: 10;
}
