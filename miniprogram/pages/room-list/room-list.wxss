/* pages/room-list/room-list.wxss */
page {
  background-color: #F5F0E8;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.room-list-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题和输入合并 */
.page-header {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

/* 猫尾巴 - 贴靠右下角 */
.header-tail {
  width: 80rpx;
  height: 80rpx;
  position: absolute;
  right: 0;
  bottom: 0;
  z-index: 2;
  transform: rotate(-10deg);
}

.header-left {
  flex: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  display: block;
}

.header-right {
  flex-shrink: 0;
}

/* 内联输入框 */
.input-wrapper-inline {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 6rpx 6rpx 6rpx 16rpx;
  border: 2rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 rgba(61, 61, 61, 0.2);
  transition: all 0.3s ease;
}

.input-wrapper-inline.focused {
  padding-right: 20rpx;
}

.input-wrapper-inline.focused .room-input-inline {
  width: 220rpx;
}

.room-input-inline {
  width: 160rpx;
  height: 56rpx;
  font-size: 24rpx;
  color: #3D3D3D;
  transition: all 0.3s ease;
}

.room-input-inline::placeholder {
  color: #999;
  font-size: 22rpx;
}

.enter-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  background: #FF9F43;
  border-radius: 8rpx;
  border-top: 2rpx solid #3D3D3D;
  border-left: 2rpx solid #3D3D3D;
  border-bottom: 4rpx solid #3D3D3D;
  border-right: 4rpx solid #3D3D3D;
  box-shadow: 2rpx 2rpx 0 rgba(61, 61, 61, 0.2);
}

.enter-btn-inline text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.enter-btn-inline:active {
  box-shadow: 1rpx 1rpx 0 rgba(61, 61, 61, 0.2);
  transform: translateY(1rpx);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #F5F0E8;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 28rpx;
  background: #F5F0E8;
  transition: all 0.3s;
}

.tab-item text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active {
  background: #FF9F43;
}

.tab-item.active text {
  color: #fff;
  font-weight: 600;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F5F0E8;
  border-top-color: #FF9F43;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 32rpx;
  font-weight: 500;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 活动列表 */
.room-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 活动横条 */
.room-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 20rpx;
  border-top: 3rpx solid #3D3D3D;
  border-left: 3rpx solid #3D3D3D;
  border-bottom: 6rpx solid #3D3D3D;
  border-right: 6rpx solid #3D3D3D;
  box-shadow: 3rpx 4rpx 0 rgba(61, 61, 61, 0.15);
  transition: all 0.2s ease;
}

.room-item.orange {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFE4CC 100%);
}

.room-item.blue {
  background: linear-gradient(135deg, #F0F8FF 0%, #E6F3FF 100%);
}

.room-item.green {
  background: linear-gradient(135deg, #F5FFF5 0%, #E6FFE6 100%);
}

.room-item.pink {
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE6F0 100%);
}

.room-item.purple {
  background: linear-gradient(135deg, #F8F0FF 0%, #F0E6FF 100%);
}

.room-item:active {
  transform: translateY(2rpx);
  box-shadow: 1rpx 2rpx 0 rgba(61, 61, 61, 0.15);
}

/* 左侧海报 */
.item-poster {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  border: 4rpx solid #3D3D3D;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-poster image {
  width: 100%;
  height: 100%;
}

/* 中间信息 */
.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.item-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3D3D;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-badge.voting {
  background: #4CAF50;
  color: #fff;
}

.status-badge.locked {
  background: #9E9E9E;
  color: #fff;
}

.info-detail {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.detail-text {
  font-size: 26rpx;
  color: #666;
}

.info-footer {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.creator-avatar-mini {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #3D3D3D;
}

.creator-name-mini {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.room-id {
  margin-left: auto;
  font-size: 24rpx;
  color: #FF9F43;
  font-weight: 600;
  font-family: monospace;
  background: rgba(255, 159, 67, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 右侧箭头 */
.item-arrow {
  padding-left: 16rpx;
  flex-shrink: 0;
}

.item-arrow text {
  font-size: 40rpx;
  color: #FF9F43;
  font-weight: 700;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}

/* ==================== 新卡片样式 ==================== */

/* 房间列表容器 */
.room-list-container {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片整体 */
.room-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  /* 上左细，下右粗 */
  border-top: 4rpx solid #3D3D3D;
  border-left: 4rpx solid #3D3D3D;
  border-bottom: 8rpx solid #3D3D3D;
  border-right: 8rpx solid #3D3D3D;
  /* 阴影效果 */
  box-shadow:
    4rpx 6rpx 0 rgba(61, 61, 61, 0.15),
    8rpx 12rpx 20rpx rgba(61, 61, 61, 0.1);
  transition: all 0.2s ease;
}

.room-card:active {
  transform: translateY(4rpx);
  box-shadow:
    2rpx 3rpx 0 rgba(61, 61, 61, 0.15),
    4rpx 6rpx 10rpx rgba(61, 61, 61, 0.1);
}

/* 左侧图片区域 */
.card-image-wrap {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 状态标签（毛玻璃效果） */
.status-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.status-tag text {
  font-size: 20rpx;
  font-weight: 600;
}

/* 状态颜色 */
.status-tag.voting text {
  color: #34C759;
}

.status-tag.locked text {
  color: #FF8C42;
}

.status-tag.ended text {
  color: #999999;
}

/* 右侧信息区 */
.card-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 176rpx;
}

/* 信息行通用 */
.info-row {
  display: flex;
  align-items: center;
}

/* 第一行：标题 */
.title-row {
  margin-bottom: 4rpx;
}

.room-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 第二行：元信息（日期+时间+地点） */
.meta-row {
  gap: 24rpx;
  margin-bottom: 4rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item text {
  font-size: 24rpx;
  color: #999999;
}

.meta-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 第三行：截止+房间号 */
.deadline-row {
  gap: 24rpx;
  margin-bottom: 4rpx;
}

.deadline-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.deadline-item text {
  font-size: 24rpx;
  color: #999999;
}

.room-code {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.room-code text {
  font-size: 24rpx;
  color: #FF8C42;
  font-family: 'Courier New', monospace;
  font-weight: 600;
}

/* 第四行：底部锚点（右对齐） */
.action-row {
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.participant-count {
  font-size: 24rpx;
  color: #999999;
}

.dot {
  font-size: 24rpx;
  color: #CCCCCC;
}

.manage-btn {
  font-size: 24rpx;
  color: #FF8C42;
  font-weight: 600;
  padding: 4rpx 12rpx;
}

/* 管理菜单弹窗 */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.action-sheet.show {
  opacity: 1;
  visibility: visible;
}

.action-sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.action-sheet-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.action-sheet.show .action-sheet-content {
  transform: translateY(0);
}

.action-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 32rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
}

.action-item text {
  font-size: 28rpx;
  color: #1A1A1A;
}

.action-item.delete text {
  color: #FF3B30;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
}

.action-cancel {
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #999999;
  background: #F5F5F5;
  border-radius: 16rpx;
}
