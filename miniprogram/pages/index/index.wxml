<view class="index-page anim-page-enter">
  <!-- Hero 区域 -->
  <view class="hero-section">
    <view class="stripe-background"></view>
    <view class="hero-content">
      <view class="title-area anim-slide-up delay-1">
        <text class="app-title">喵了个鱼</text>
        <text class="app-subtitle">今天吃什么？让橘仔来决定</text>
      </view>
      <view class="cat-container anim-pop delay-2">
        <view class="cat-glow anim-pulse"></view>
        <view class="cat-ring"></view>
        <image class="cat-avatar anim-float" src="{{imagePaths.icons.juzeAvatar}}" mode="aspectFill" />
      </view>
    </view>
    <view class="fence-decoration"></view>
  </view>

  <!-- Banner轮播 -->
  <view class="middle-section" wx:if="{{appointmentBanners.length > 0 || pageReady}}">
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="4000" duration="600">
      <swiper-item wx:for="{{appointmentBanners}}" wx:key="_id">
        <view class="banner-card appointment-banner" bindtap="onBannerTap" data-appointment-id="{{item._id}}">
          <view class="banner-left-brand">
            <view class="brand-vertical">
              <view class="brand-title-art">
                <text class="title-char">喵</text>
                <text class="title-char">不</text>
                <text class="title-char">喵</text>
              </view>
              <image class="brand-icon-large" src="{{imagePaths.decorations.catAvatarIcon}}" mode="aspectFill" />
            </view>
          </view>
          <view class="banner-middle-content">
            <view class="content-row">
              <view class="info-tag tag-nickname">
                <text class="info-label">发起人</text>
                <text class="info-value">{{item.initiatorName || '神秘喵友'}}</text>
              </view>
              <view class="info-tag tag-shop">
                <text class="info-value">{{item.shopName || '约饭活动'}}</text>
              </view>
            </view>
            <view class="content-row">
              <view class="info-tag tag-cuisine">
                <text class="info-value">{{item.cuisineName || '美食'}}</text>
              </view>
              <view class="info-tag tag-time">
                <text class="info-label">约饭开始时间</text>
                <text class="info-value">{{item.appointmentTimeStr}}</text>
              </view>
            </view>
            <view class="content-row">
              <view class="info-tag tag-countdown">
                <text class="info-label">倒计时</text>
                <text class="info-value red-text">{{item.countdownText}}</text>
              </view>
              <view class="info-tag tag-address">
                <text class="info-value">{{item.location || '地址待定'}}</text>
              </view>
            </view>
          </view>
          <view class="banner-right-action">
            <image class="action-paw" src="{{imagePaths.misc.singleclaw}}" mode="aspectFit" />
            <view class="action-btn {{item.isJoined ? 'joined' : ''}}" catchtap="onJoinTap" data-appointment-id="{{item._id}}">
              <text class="action-text">{{item.isJoined ? '已喵' : '报名'}}</text>
              <image wx:if="{{item.isJoined}}" class="paw-stamp" src="{{imagePaths.icons.gaizhang}}" mode="aspectFit" />
            </view>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-card ad-banner" bindtap="onBannerTap" data-type="ad">
          <image class="ad-image" src="{{imagePaths.banners.lunbozhanwei}}" mode="aspectFit" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 功能卡片 -->
  <view class="feature-section" wx:if="{{pageReady}}">
    <view class="feature-grid">
      <view class="feature-card anim-slide-up delay-3" bindtap="goCreate" data-index="0">
        <view class="card-top-bar" style="background: #FF9F43;"></view>
        <view class="card-inner">
          <view class="feature-left">
            <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #FFF5E9 0%, #FFECD2 100%);">
              <image class="feature-icon-image" src="{{imagePaths.banners.faqijucan}}" mode="aspectFit" />
            </view>
            <view class="feature-text-wrapper">
              <text class="feature-title">聚餐发起</text>
              <text class="feature-desc">投票房间创建</text>
            </view>
          </view>
          <view class="feature-arrow">›</view>
        </view>
      </view>
      <view class="feature-card anim-slide-up delay-4" bindtap="goJoin" data-index="1">
        <view class="card-top-bar" style="background: #4ECDC4;"></view>
        <view class="card-inner">
          <view class="feature-left">
            <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #E8F8F5 0%, #D0F0E8 100%);">
              <image class="feature-icon-image" src="{{imagePaths.misc.catPawIcon}}" mode="aspectFit" />
            </view>
            <view class="feature-text-wrapper">
              <text class="feature-title">投票参与</text>
              <text class="feature-desc">已有房间加入</text>
            </view>
          </view>
          <view class="feature-arrow">›</view>
        </view>
      </view>
      <view class="feature-card anim-slide-up delay-5" bindtap="goFishTank">
        <view class="card-top-bar" style="background: #45B7D1;"></view>
        <view class="card-inner">
          <view class="feature-left">
            <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #E8F4FD 0%, #D0E8F8 100%);">
              <image class="feature-icon-image large-icon" src="{{imagePaths.banners.yutangpindan}}" mode="aspectFit" />
            </view>
            <view class="feature-text-wrapper">
              <text class="feature-title">鱼塘拼单</text>
              <text class="feature-desc">吃喝外卖凑单</text>
            </view>
          </view>
          <view class="feature-arrow">›</view>
        </view>
      </view>
      <view class="feature-card anim-slide-up delay-6" bindtap="goFoodDiscovery">
        <view class="card-top-bar" style="background: #FF6B6B;"></view>
        <view class="card-inner">
          <view class="feature-left">
            <view class="feature-icon-wrapper" style="background: linear-gradient(135deg, #FFF0F0 0%, #FFE0E0 100%);">
              <image class="feature-icon-image" src="{{imagePaths.decorations.loveCatIcon}}" mode="aspectFit" />
            </view>
            <view class="feature-text-wrapper">
              <text class="feature-title">新店探索</text>
              <text class="feature-desc">好店美味推荐</text>
            </view>
          </view>
          <view class="feature-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 游动的小鱼区域 - JS 驱动 -->
  <view class="fish-tank" wx:if="{{pageReady}}">
    <view
      wx:for="{{fishes}}"
      wx:key="index"
      id="fish-{{index + 1}}"
      class="fish"
      style="top: {{item.top}}; --tail-color: {{item.tail}}; --fin-color: {{item.fin}}; --body-gradient: {{item.body}};"
      animation="{{item.animation}}"
      catchtap="onFishTap"
      data-fish="{{index + 1}}"
    >
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="custom-tab-bar">
    <view class="tab-bar-border"></view>
    <view class="tab-bar-container">
      <view class="tab-bar-item active" data-index="0" bindtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon" src="{{imagePaths.misc.pawHomeIcon}}" mode="aspectFit" />
        </view>
        <text class="tab-text">首页</text>
      </view>
      <view class="tab-bar-item" data-index="1" catchtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon fish-icon" src="{{imagePaths.decorations.catAvatarIcon}}" mode="aspectFit" />
        </view>
        <text class="tab-text">喵不喵</text>
      </view>
      <view class="tab-bar-item" data-index="2" bindtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon" src="{{imagePaths.misc.fishIcon}}" mode="aspectFit" />
        </view>
        <text class="tab-text">我的</text>
      </view>
    </view>
  </view>
</view>
