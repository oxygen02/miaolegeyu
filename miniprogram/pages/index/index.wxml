<view class="index-page">
  <!-- Hero 区域 -->
  <view class="hero-section">
    <view class="stripe-background"></view>
    <view class="hero-content">
      <view class="title-area">
        <text class="app-title">喵了个鱼</text>
        <text class="app-subtitle">今天吃什么？让橘仔来决定</text>
      </view>
      <view class="cat-container">
        <view class="cat-glow"></view>
        <view class="cat-ring"></view>
        <image class="cat-avatar" src="/assets/images/juze_avatar.png" mode="aspectFill" />
      </view>
    </view>
    <view class="fence-decoration"></view>
  </view>

  <!-- Banner轮播 -->
  <view class="middle-section" wx:if="{{appointmentBanners.length > 0 || pageReady}}">
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="4000" duration="600">
      <swiper-item wx:for="{{appointmentBanners}}" wx:key="_id">
        <view class="banner-card appointment-banner" bindtap="onBannerTap" data-appointment-id="{{item._id}}">
          <view class="banner-left-brand">
            <view class="brand-vertical">
              <view class="brand-title-art">
                <text class="title-char">喵</text>
                <text class="title-char">不</text>
                <text class="title-char">喵</text>
              </view>
              <image class="brand-icon-large" src="/assets/images/cat-avatar-icon.png" mode="aspectFill" />
            </view>
          </view>
          <view class="banner-middle-content">
            <view class="content-row">
              <view class="info-tag tag-nickname">
                <text class="info-label">发起人</text>
                <text class="info-value">{{item.initiatorName || '神秘喵友'}}</text>
              </view>
              <view class="info-tag tag-shop">
                <text class="info-value">{{item.shopName || '约饭活动'}}</text>
              </view>
            </view>
            <view class="content-row">
              <view class="info-tag tag-cuisine">
                <text class="info-value">{{item.cuisineName || '美食'}}</text>
              </view>
              <view class="info-tag tag-time">
                <text class="info-label">约饭开始时间</text>
                <text class="info-value">{{item.appointmentTimeStr}}</text>
              </view>
            </view>
            <view class="content-row">
              <view class="info-tag tag-countdown">
                <text class="info-label">倒计时</text>
                <text class="info-value red-text">{{item.countdownText}}</text>
              </view>
              <view class="info-tag tag-address">
                <text class="info-value">{{item.shopLocation || item.location || '地址待定'}}</text>
              </view>
            </view>
          </view>
          <view class="banner-right-action">
            <image class="action-paw" src="/assets/images/singleclaw.png" mode="aspectFit" />
            <view class="action-btn {{item.isJoined ? 'joined' : ''}}" catchtap="onJoinTap" data-appointment-id="{{item._id}}">
              <text class="action-text">{{item.isJoined ? '已喵' : '报名'}}</text>
              <image wx:if="{{item.isJoined}}" class="paw-stamp" src="/assets/images/gaizhang.png" mode="aspectFit" />
            </view>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-card ad-banner" bindtap="onBannerTap" data-type="ad">
          <image class="ad-image" src="/assets/images/lunbozhanwei.png" mode="aspectFit" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 功能卡片 -->
  <view class="feature-section" wx:if="{{pageReady}}">
    <view class="feature-grid">
      <view class="feature-card" bindtap="goCreate" data-index="0">
        <view class="card-inner">
          <view class="feature-icon-wrapper" style="background: #FFF5E9;">
            <image class="feature-icon-image" src="/assets/images/faqijucan.png" mode="aspectFit" />
          </view>
          <view class="feature-text-wrapper">
            <text class="feature-title">发起聚餐</text>
            <text class="feature-desc">创建投票房间</text>
          </view>
        </view>
      </view>
      <view class="feature-card" bindtap="goJoin" data-index="1">
        <view class="card-inner">
          <view class="feature-icon-wrapper" style="background: #E8F8F5;">
            <image class="feature-icon-image" src="/assets/images/cat-paw-icon.png" mode="aspectFit" />
          </view>
          <view class="feature-text-wrapper">
            <text class="feature-title">参与投票</text>
            <text class="feature-desc">加入已有房间</text>
          </view>
        </view>
      </view>
      <view class="feature-card" bindtap="goFishTank">
        <view class="card-inner">
          <view class="feature-icon-wrapper" style="background: #E8F4FD;">
            <image class="feature-icon-image large-icon" src="/assets/images/yutangpindan.png" mode="aspectFit" />
          </view>
          <view class="feature-text-wrapper">
            <text class="feature-title">鱼塘拼单</text>
            <text class="feature-desc">一起凑单免运费</text>
          </view>
        </view>
      </view>
      <view class="feature-card" bindtap="goFoodDiscovery">
        <view class="card-inner">
          <view class="feature-icon-wrapper" style="background: #FFF5E9;">
            <image class="feature-icon-image" src="/assets/images/love-cat-icon.png" mode="aspectFit" />
          </view>
          <view class="feature-text-wrapper">
            <text class="feature-title">发现美食</text>
            <text class="feature-desc">橘仔推荐好味道</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 游动的小鱼区域 -->
  <view class="fish-tank" wx:if="{{pageReady}}">
    <view class="fish fish-1 {{scaredFish === '1' ? (scaredFishDirection === 'left' ? 'scared-left' : 'scared-right') : ''}}" catchtap="onFishTap" data-fish="1">
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
    <view class="fish fish-2 {{scaredFish === '2' ? (scaredFishDirection === 'left' ? 'scared-left' : 'scared-right') : ''}}" catchtap="onFishTap" data-fish="2">
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
    <view class="fish fish-3 {{scaredFish === '3' ? (scaredFishDirection === 'left' ? 'scared-left' : 'scared-right') : ''}}" catchtap="onFishTap" data-fish="3">
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
    <view class="fish fish-4 {{scaredFish === '4' ? (scaredFishDirection === 'left' ? 'scared-left' : 'scared-right') : ''}}" catchtap="onFishTap" data-fish="4">
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
    <view class="fish fish-5 {{scaredFish === '5' ? (scaredFishDirection === 'left' ? 'scared-left' : 'scared-right') : ''}}" catchtap="onFishTap" data-fish="5">
      <view class="fish-body"></view>
      <view class="fish-tail"></view>
      <view class="fish-fin"></view>
      <view class="fish-eye"></view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="custom-tab-bar">
    <view class="tab-bar-border"></view>
    <view class="tab-bar-container">
      <view class="tab-bar-item active" data-index="0" bindtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon" src="/assets/images/paw-home-icon.png" mode="aspectFit" />
        </view>
        <text class="tab-text">首页</text>
      </view>
      <view class="tab-bar-item" data-index="1" catchtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon fish-icon" src="/assets/images/cat-avatar-icon.png" mode="aspectFit" />
        </view>
        <text class="tab-text">喵不喵</text>
      </view>
      <view class="tab-bar-item" data-index="2" bindtap="switchTab">
        <view class="icon-wrapper">
          <image class="tab-icon" src="/assets/images/fish-icon.png" mode="aspectFit" />
        </view>
        <text class="tab-text">我的</text>
      </view>
    </view>
  </view>
</view>