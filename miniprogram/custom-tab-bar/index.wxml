<!-- 自定义底部导航栏 -->
<view class="tab-bar">
  <view class="tab-bar-border"></view>

  <view class="tab-bar-container">
    <!-- 首页 -->
    <view class="tab-bar-item {{selected === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">
      <view class="icon-wrapper">
        <image class="tab-icon" src="{{selected === 0 ? imagePaths.misc.pawHomeIcon : imagePaths.misc.pawHomeIcon}}" mode="aspectFit" />
      </view>
      <text class="tab-text">首页</text>
    </view>

    <!-- 喵不喵 -->
    <view class="tab-bar-item {{selected === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">
      <view class="icon-wrapper">
        <image class="tab-icon" src="{{selected === 1 ? imagePaths.decorations.catAvatarIcon : imagePaths.decorations.catAvatarIcon}}" mode="aspectFit" />
      </view>
      <text class="tab-text">喵不喵</text>
    </view>

    <!-- 我的 -->
    <view class="tab-bar-item {{selected === 2 ? 'active' : ''}}" data-index="2" bindtap="switchTab">
      <view class="icon-wrapper">
        <image class="tab-icon" src="{{selected === 2 ? imagePaths.misc.fishIcon : imagePaths.misc.fishIcon}}" mode="aspectFit" />
      </view>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>