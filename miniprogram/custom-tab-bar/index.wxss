/* 自定义底部导航栏 - 中间突出主按钮 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  box-sizing: border-box;
  border: none;
  padding: 0 32rpx calc(20rpx + constant(safe-area-inset-bottom)) 32rpx;
  padding: 0 32rpx calc(20rpx + env(safe-area-inset-bottom)) 32rpx;
  z-index: 9999;
}

/* 隐藏横线元素 */
.tab-bar-border {
  display: none;
}

/* 导航项容器 - 柔和风格 */
.tab-bar-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: 100%;
  height: 120rpx;
  background: #fff;
  border-radius: 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  padding: 0 40rpx;
  box-sizing: border-box;
  position: relative;
}

/* 每个导航项 */
.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100rpx;
  padding-bottom: 8rpx;
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

/* 图标容器 */
.icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

/* 普通标签图标 - 使用图片 */
.tab-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  filter: grayscale(100%);
  opacity: 0.5;
}

/* 中间突出的主按钮 */
.center-item {
  position: relative;
  top: -30rpx;
}

.center-btn-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-btn-bg {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.4);
  border: 4rpx solid #fff;
}

.center-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.center-text {
  margin-top: 8rpx;
  font-size: 20rpx;
}

/* 标签文字 */
.tab-text {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* 激活状态 - 恢复本色，图标变大 */
.tab-bar-item.active .icon-wrapper {
  transform: scale(1.25);
  transition: transform 0.2s ease;
  animation: shake 0.5s ease-in-out;
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: scale(1.25) rotate(0deg); }
  10% { transform: scale(1.25) rotate(-8deg); }
  20% { transform: scale(1.25) rotate(8deg); }
  30% { transform: scale(1.25) rotate(-6deg); }
  40% { transform: scale(1.25) rotate(6deg); }
  50% { transform: scale(1.25) rotate(-4deg); }
  60% { transform: scale(1.25) rotate(4deg); }
  70% { transform: scale(1.25) rotate(-2deg); }
  80% { transform: scale(1.25) rotate(2deg); }
  90% { transform: scale(1.25) rotate(0deg); }
}

.tab-bar-item.active .tab-icon {
  filter: grayscale(0%) !important;
  opacity: 1 !important;
}

.tab-bar-item.active .fish-icon {
  filter: grayscale(0%) !important;
  opacity: 1 !important;
}

.tab-bar-item.active .tab-text {
  color: #FF9F43 !important;
  font-weight: 600;
  font-size: 24rpx;
}
