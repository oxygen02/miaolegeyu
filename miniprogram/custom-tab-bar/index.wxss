/* 自定义底部导航栏 - 蜡笔像素风 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #FFF8F0;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  box-sizing: border-box;
  /* 去掉底部边框 */
  border: none;
  padding: 0 10rpx calc(8rpx + constant(safe-area-inset-bottom)) 10rpx;
  padding: 0 10rpx calc(8rpx + env(safe-area-inset-bottom)) 10rpx;
  z-index: 9999;
}

/* 隐藏横线元素 */
.tab-bar-border {
  display: none;
}

/* 导航项容器 - 整体边框，下右边框更粗 */
.tab-bar-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: 100%;
  height: 120rpx;
  background: #fff;
  /* 上左细，下右粗 */
  border-top: 4rpx solid #3D3D3D;
  border-left: 4rpx solid #3D3D3D;
  border-bottom: 8rpx solid #3D3D3D;
  border-right: 8rpx solid #3D3D3D;
  border-radius: 24rpx;
  /* 阴影效果 */
  box-shadow: 
    4rpx 6rpx 0 rgba(61, 61, 61, 0.15),
    8rpx 12rpx 20rpx rgba(61, 61, 61, 0.1);
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 每个导航项 */
.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100rpx;
  padding-bottom: 8rpx;
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

/* 图标容器 */
.icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

/* 普通标签图标 - 使用图片 */
.tab-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  filter: grayscale(100%);
  opacity: 0.5;
}

/* 炸鱼图标 */
.fish-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 0;
  filter: grayscale(100%);
  opacity: 0.5;
}

/* 标签文字 */
.tab-text {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* 激活状态 - 恢复本色，图标变大 */
.tab-bar-item.active .icon-wrapper {
  transform: scale(1.25);
  transition: transform 0.2s ease;
  animation: shake 0.5s ease-in-out;
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: scale(1.25) rotate(0deg); }
  10% { transform: scale(1.25) rotate(-8deg); }
  20% { transform: scale(1.25) rotate(8deg); }
  30% { transform: scale(1.25) rotate(-6deg); }
  40% { transform: scale(1.25) rotate(6deg); }
  50% { transform: scale(1.25) rotate(-4deg); }
  60% { transform: scale(1.25) rotate(4deg); }
  70% { transform: scale(1.25) rotate(-2deg); }
  80% { transform: scale(1.25) rotate(2deg); }
  90% { transform: scale(1.25) rotate(0deg); }
}

.tab-bar-item.active .tab-icon {
  filter: grayscale(0%) !important;
  opacity: 1 !important;
}

.tab-bar-item.active .fish-icon {
  filter: grayscale(0%) !important;
  opacity: 1 !important;
}

.tab-bar-item.active .tab-text {
  color: #FF9F43 !important;
  font-weight: 600;
  font-size: 24rpx;
}
