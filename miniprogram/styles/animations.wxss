/* ==================== 喵了个鱼 - 动画库 ==================== */

/* ---------- 页面进入动画 ---------- */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeInLeft {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fadeInRight {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* ---------- 悬浮动画 ---------- */
@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
}

@keyframes floatSlow {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-8rpx) rotate(2deg);
  }
}

/* ---------- 呼吸动画 ---------- */
@keyframes breathe {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.9;
  }
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(255, 159, 67, 0.4);
  }
  50% {
    box-shadow: 0 0 0 20rpx rgba(255, 159, 67, 0);
  }
}

/* ---------- 摇摆动画 ---------- */
@keyframes wiggle {
  0%, 100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(-5deg);
  }
  75% {
    transform: rotate(5deg);
  }
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  10%, 30%, 50%, 70%, 90% {
    transform: translateX(-4rpx);
  }
  20%, 40%, 60%, 80% {
    transform: translateX(4rpx);
  }
}

/* ---------- 眨眼动画（橘仔） ---------- */
@keyframes blink {
  0%, 90%, 100% {
    transform: scaleY(1);
  }
  95% {
    transform: scaleY(0.1);
  }
}

@keyframes catWink {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
}

/* ---------- 波浪动画 ---------- */
@keyframes wave {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* ---------- 旋转动画 ---------- */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes spinSlow {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* ---------- 弹跳动画 ---------- */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

/* ---------- 滑动动画 ---------- */
@keyframes slideInUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideInDown {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* ---------- 抓痕动画 ---------- */
@keyframes scratch {
  0% {
    opacity: 0;
    transform: translateX(20rpx) rotate(-10deg) scale(0.8);
  }
  30% {
    opacity: 1;
    transform: translateX(0) rotate(-5deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateX(-30rpx) rotate(0deg) scale(1.1);
  }
}

/* ---------- 掌印动画 ---------- */
@keyframes paw {
  0% {
    opacity: 0;
    transform: scale(0.5) rotate(-10deg);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.2) rotate(5deg);
  }
  100% {
    opacity: 0;
    transform: scale(1) rotate(0deg);
  }
}

/* ---------- 印章动画 ---------- */
@keyframes stamp {
  0% {
    transform: translateY(-200rpx) scale(1.5) rotate(-15deg);
    opacity: 0;
  }
  60% {
    transform: translateY(0) scale(0.9) rotate(5deg);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1) rotate(0deg);
  }
}

/* ---------- 闪光动画 ---------- */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* ---------- 心跳动画 ---------- */
@keyframes heartbeat {
  0%, 100% {
    transform: scale(1);
  }
  14% {
    transform: scale(1.1);
  }
  28% {
    transform: scale(1);
  }
  42% {
    transform: scale(1.1);
  }
  70% {
    transform: scale(1);
  }
}

/* ---------- 加载动画 ---------- */
@keyframes loading {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ---------- 应用类 ---------- */
.anim-fade-in-up {
  animation: fadeInUp 0.6s ease-out forwards;
}

.anim-fade-in-down {
  animation: fadeInDown 0.6s ease-out forwards;
}

.anim-fade-in-scale {
  animation: fadeInScale 0.5s ease-out forwards;
}

.anim-float {
  animation: float 3s ease-in-out infinite;
}

.anim-float-slow {
  animation: floatSlow 4s ease-in-out infinite;
}

.anim-breathe {
  animation: breathe 2s ease-in-out infinite;
}

.anim-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.anim-wiggle {
  animation: wiggle 0.5s ease-in-out;
}

.anim-shake {
  animation: shake 0.5s ease-in-out;
}

.anim-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.anim-bounce-in {
  animation: bounceIn 0.6s ease-out forwards;
}

.anim-spin {
  animation: spin 1s linear infinite;
}

.anim-spin-slow {
  animation: spinSlow 3s linear infinite;
}

.anim-heartbeat {
  animation: heartbeat 1.5s ease-in-out infinite;
}

/* ---------- 延迟类 ---------- */
.delay-100 { animation-delay: 100ms; }
.delay-200 { animation-delay: 200ms; }
.delay-300 { animation-delay: 300ms; }
.delay-400 { animation-delay: 400ms; }
.delay-500 { animation-delay: 500ms; }
.delay-600 { animation-delay: 600ms; }
.delay-700 { animation-delay: 700ms; }
.delay-800 { animation-delay: 800ms; }

/* ---------- 交错动画 ---------- */
.stagger-children > view:nth-child(1) { animation-delay: 0ms; }
.stagger-children > view:nth-child(2) { animation-delay: 100ms; }
.stagger-children > view:nth-child(3) { animation-delay: 200ms; }
.stagger-children > view:nth-child(4) { animation-delay: 300ms; }
.stagger-children > view:nth-child(5) { animation-delay: 400ms; }
.stagger-children > view:nth-child(6) { animation-delay: 500ms; }

/* ---------- 悬停效果 ---------- */
.hover-lift {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.hover-lift:hover {
  transform: translateY(-8rpx);
  box-shadow: 0 16rpx 48rpx rgba(255, 159, 67, 0.2);
}

.hover-scale {
  transition: transform 0.2s ease;
}

.hover-scale:active {
  transform: scale(0.96);
}

/* ---------- 按钮点击效果 ---------- */
.btn-press {
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.btn-press:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.3);
}

/* ---------- 卡片悬停效果 ---------- */
.card-hover {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-hover:hover {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 20rpx 60rpx rgba(255, 159, 67, 0.18);
}

/* ---------- 渐变文字 ---------- */
.text-gradient {
  background: linear-gradient(135deg, #FF9F43 0%, #FFB347 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ---------- 闪光效果 ---------- */
.shimmer {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.4) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}
