.control-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 32rpx 32rpx 240rpx;
}

/* 头部 */
.control-header {
  padding: 0 16rpx 24rpx;
}
.room-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}
.room-role {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}
.stat-item {
  text-align: center;
  flex: 1;
}
.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}
.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.06);
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
  padding: 24rpx 32rpx;
}
.section-header {
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}
.section-count {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
.section-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 请假 */
.leave-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.leave-tag {
  background: rgba(200, 75, 49, 0.08);
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.leave-name {
  font-size: 26rpx;
  color: var(--hard);
  font-weight: 500;
}
.leave-reason {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 雷区 */
.mine-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.mine-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(200, 75, 49, 0.1);
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
}
.mine-label {
  font-size: 26rpx;
  color: var(--hard);
  font-weight: 500;
}
.mine-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.result-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  background: var(--card);
  transition: all 0.2s;
}
.result-item.selected {
  border-color: var(--primary);
  background: rgba(212, 101, 42, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(212, 101, 42, 0.1);
}
.result-item.vetoed {
  opacity: 0.5;
  filter: grayscale(1);
}
.result-img {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #EEE;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.result-body {
  flex: 1;
}
.result-votes {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}
.result-rank {
  display: block;
  font-size: 24rpx;
  color: var(--primary-light);
  margin-top: 8rpx;
}
.result-check {
  margin-left: 16rpx;
}
.check-circle {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary);
  border-radius: 50%;
  position: relative;
}
.check-circle::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 24rpx;
  border-right: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: translate(-70%, -60%) rotate(45deg);
}

/* 否决区 */
.veto-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed rgba(0,0,0,0.08);
}
.veto-header { margin-bottom: 16rpx; }
.veto-title {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.veto-reason {
  font-size: 24rpx;
  color: var(--hard);
}

/* 底部操作 */
.control-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg);
  border-top: 1rpx solid rgba(0,0,0,0.04);
  padding: 24rpx 32rpx 40rpx;
}
.footer-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.footer-btn {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}
.lock-btn {
  width: 100%;
  height: 96rpx;
  font-size: 34rpx;
}
.footer-links {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 20rpx;
}
.footer-link {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-decoration: underline;
  text-decoration-color: rgba(0,0,0,0.1);
}
.footer-link.danger {
  color: var(--hard);
}
