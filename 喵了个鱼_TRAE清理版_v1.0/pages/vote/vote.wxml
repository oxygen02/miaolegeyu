<view class="page vote-page">
  <!-- 顶部进度 -->
  <view class="vote-header flex-between">
    <text class="vote-title">{{roomTitle}}</text>
    <text class="vote-progress">{{currentIndex + 1}} / {{totalCount}}</text>
  </view>

  <!-- 滑动区域 -->
  <view class="swipe-area">
    <block wx:for="{{posters}}" wx:key="index">
      <view 
        class="poster-card {{item.animClass}}" 
        style="{{item.style}}; z-index: {{totalCount - index}};"
        wx:if="{{index >= currentIndex && index < currentIndex + 2}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
        data-index="{{index}}"
      >
        <!-- 海报图 -->
        <image class="poster-img" src="{{item.imageUrl}}" mode="aspectFill" bindtap="previewPoster" />

        <!-- 平台角标 -->
        <view class="platform-badge {{item.platform}}">
          <text>{{item.platform === 'meituan' ? '美团' : '点评'}}</text>
        </view>

        <!-- 左滑抓痕层 -->
        <view class="scratch-layer" wx:if="{{item.showScratch}}">
          <view class="scratch s1"></view>
          <view class="scratch s2"></view>
          <view class="scratch s3"></view>
        </view>

        <!-- 右滑掌印层 -->
        <view class="paw-layer" wx:if="{{item.showPaw}}">
          <view class="paw">
            <view class="pad main"></view>
            <view class="pad toe t1"></view>
            <view class="pad toe t2"></view>
            <view class="pad toe t3"></view>
            <view class="pad toe t4"></view>
          </view>
        </view>

        <!-- 否决印章 -->
        <view class="veto-stamp" wx:if="{{item.isVetoed}}">
          <view class="stamp-circle">
            <text class="stamp-text">禁</text>
            <text class="stamp-sub">有人不吃这个</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 全部完成 -->
    <view class="done-state" wx:if="{{currentIndex >= totalCount}}">
      <image class="done-cat" src="/assets/cat-empty.png" mode="aspectFit" />
      <text class="done-text">都筛完了，去提交吧</text>
    </view>
  </view>

  <!-- 滑动提示 -->
  <view class="swipe-hint flex-between" wx:if="{{currentIndex < totalCount}}">
    <view class="hint-left">
      <view class="hint-arrow"></view>
      <text>排除</text>
    </view>
    <view class="hint-right">
      <text>选择</text>
      <view class="hint-arrow right"></view>
    </view>
  </view>

  <!-- 撤销条 -->
  <view class="undo-bar" wx:if="{{showUndo}}" bindtap="undoAction">
    <text class="undo-text">已{{lastAction === 'left' ? '排除' : '选择'}} {{lastPosterName}}</text>
    <text class="undo-timer">{{undoCountdown}}s</text>
  </view>

  <!-- 底部操作区 -->
  <view class="bottom-panel">
    <!-- 禁忌 -->
    <view class="taboo-section">
      <view class="taboo-header flex-between" bindtap="toggleTaboo">
        <text class="taboo-title">我的禁忌</text>
        <view class="flex-center">
          <text class="taboo-count" wx:if="{{selectedHard.length > 0}}">{{selectedHard.length}}项硬性</text>
          <view class="arrow {{tabooOpen ? 'up' : ''}}"></view>
        </view>
      </view>
      <view class="taboo-body" wx:if="{{tabooOpen}}">
        <view class="taboo-group">
          <text class="group-label">硬性禁忌（一票否决）</text>
          <view class="tag-list">
            <view class="tag tag-hard {{item.selected ? 'active' : ''}}" wx:for="{{hardTaboos}}" wx:key="name" bindtap="toggleHard" data-name="{{item.name}}">{{item.label}}</view>
          </view>
        </view>
        <view class="taboo-group">
          <text class="group-label">软性偏好（仅供参考）</text>
          <view class="tag-list">
            <view class="tag tag-soft {{item.selected ? 'active' : ''}}" wx:for="{{softTaboos}}" wx:key="name" bindtap="toggleSoft" data-name="{{item.name}}">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 时间 / 请假 -->
    <view class="time-section">
      <view class="time-tabs flex-between">
        <view class="time-tab {{timeType === 'departure' ? 'active' : ''}}" bindtap="setTimeType" data-type="departure">我能出发</view>
        <view class="time-tab {{timeType === 'arrival' ? 'active' : ''}}" bindtap="setTimeType" data-type="arrival">我能到达</view>
        <view class="time-tab leave {{timeType === 'leave' ? 'active' : ''}}" bindtap="setTimeType" data-type="leave">我十分想去但是</view>
      </view>
      <picker mode="multiSelector" range="{{timeRange}}" bindchange="onTimeChange" wx:if="{{timeType === 'departure' || timeType === 'arrival'}}">
        <view class="time-picker">{{selectedTime || '选择时间'}}</view>
      </picker>
      <input class="leave-input" wx:if="{{timeType === 'leave'}}" placeholder="说说啥事，别让发起人猜" bindinput="onLeaveInput" value="{{leaveReason}}" />
    </view>

    <!-- 提交栏 -->
    <view class="submit-bar flex-between">
      <button class="btn btn-secondary waive-btn" bindtap="onWaive">弃权</button>
      <button class="btn btn-primary submit-btn {{canSubmit ? '' : 'btn-disabled'}}" bindtap="onSubmit">提交</button>
    </view>
  </view>
</view>