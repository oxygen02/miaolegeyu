.result-page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 60rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.result-label {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 4rpx;
}
.result-line {
  width: 60rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.winner-card {
  width: 80vw;
  height: 50vh;
  position: relative;
  overflow: hidden;
  padding: 0;
}
.winner-img {
  width: 100%;
  height: 100%;
}
.winner-platform {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}
.winner-platform.meituan { background: #FFC300; color: #333; }
.winner-platform.dianping { background: #FF6633; }
.winner-platform.jd { background: #E4393C; }

.info-card {
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx 32rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.info-row:last-child { border-bottom: none; }
.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.info-value {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.action-group {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  gap: 24rpx;
}
.action-btn {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.btn-icon {
  width: 32rpx;
  height: 32rpx;
}
.nav-icon {
  background: var(--secondary);
  clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
}

.group-order-area {
  margin-top: 40rpx;
  text-align: center;
}
.go-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.go-btn {
  width: 60%;
  height: 80rpx;
  font-size: 30rpx;
}

.creator-bar {
  margin-top: 32rpx;
  width: 100%;
}
.settle-btn {
  width: 100%;
  height: 96rpx;
  font-size: 34rpx;
}

.result-bottom {
  margin-top: auto;
  padding-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.bottom-cat {
  width: 180rpx;
  height: 180rpx;
  animation: popIn 0.6s ease-out 0.3s both;
}
.bottom-say {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  animation: slideUp 0.4s ease-out 0.6s both;
}
