/* === 喵了个鱼 全局设计系统 === */
/* 禁止修改以下变量，所有页面必须引用 */

page {
  --primary: #D4652A;
  --primary-light: #E8913A;
  --secondary: #4A7C8C;
  --water: #A8D8EA;
  --bg: #F5F0E8;
  --card: #FFFDF7;
  --hard: #C84B31;
  --soft: #8A8A8A;
  --text: #3D3D3D;
  --text-secondary: #8A8A8A;
  --radius-card: 24rpx;
  --radius-button: 44rpx;
  --shadow-card: 0 8rpx 32rpx rgba(212, 101, 42, 0.08);
  --shadow-button: 0 8rpx 24rpx rgba(212, 101, 42, 0.15);

  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}

/* === 动画库 - 禁止删除 === */

/* 页面进入 */
@keyframes pageEnter {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 底部浮起 */
@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 弹性弹出 */
@keyframes popIn {
  0% { opacity: 0; transform: scale(0.6); }
  70% { transform: scale(1.05); }
  100% { opacity: 1; transform: scale(1); }
}

/* 呼吸 */
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

/* 水波纹 */
@keyframes waveMove {
  0% { transform: translateX(-50%); }
  100% { transform: translateX(0); }
}

/* 鱼游动 */
@keyframes fishSwim {
  0%, 100% { transform: translateX(0) rotate(-5deg); }
  50% { transform: translateX(-20rpx) rotate(5deg); }
}

/* 左滑抓痕 */
@keyframes scratchLine {
  0% { opacity: 0; transform: translateX(20rpx) rotate(-25deg); }
  40% { opacity: 0.9; }
  100% { opacity: 0; transform: translateX(-60rpx) rotate(-25deg); }
}

/* 右滑掌印 */
@keyframes pawPad {
  0% { opacity: 0; transform: scale(0.3); }
  60% { opacity: 0.8; transform: scale(1.2); }
  100% { opacity: 0; transform: scale(1); }
}

/* 橘仔盖章掉落 */
@keyframes stampDrop {
  0% { transform: translateY(-200rpx) scale(1.5) rotate(-15deg); opacity: 0; }
  60% { transform: translateY(0) scale(0.9) rotate(5deg); opacity: 1; }
  100% { transform: translateY(0) scale(1) rotate(0); }
}

/* 墨水扩散 */
@keyframes inkSpread {
  0% { transform: scale(0); opacity: 0.8; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* 撤销条 */
@keyframes undoBarIn {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 摇摆 */
@keyframes wiggle {
  0%, 100% { transform: rotate(0); }
  25% { transform: rotate(-3deg); }
  75% { transform: rotate(3deg); }
}

/* 脉冲 */
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* === 工具类 - 强制使用 === */
.anim-page-enter { animation: pageEnter 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both; }
.anim-slide-up { animation: slideUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.anim-pop { animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; }
.anim-breathe { animation: breathe 4s ease-in-out infinite; }
.anim-wiggle { animation: wiggle 0.4s ease-in-out; }
.anim-pulse { animation: pulse 1.5s ease-in-out infinite; }

/* 布局工具 */
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 文字截断 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* === 按钮基础 - 禁止随意修改 === */
.btn {
  height: 96rpx;
  border-radius: var(--radius-button);
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: transform 0.15s, opacity 0.15s;
}

.btn:active { transform: scale(0.96); }
.btn-primary {
  background: var(--primary);
  color: #fff;
  box-shadow: var(--shadow-button);
}
.btn-secondary {
  background: var(--card);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}
.btn-disabled {
  background: #CCC !important;
  color: #888 !important;
  box-shadow: none !important;
}

/* === 卡片基础 === */
.card {
  background: var(--card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  border: 2rpx solid rgba(212, 101, 42, 0.08);
}

/* === 标签基础 === */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  border: 2rpx solid;
  transition: all 0.15s;
}
.tag-hard {
  border-color: var(--hard);
  color: var(--hard);
  background: rgba(200, 75, 49, 0.06);
}
.tag-hard.active {
  background: var(--hard);
  color: #fff;
}
.tag-soft {
  border-color: var(--soft);
  color: var(--soft);
  background: rgba(138, 138, 138, 0.06);
}
.tag-soft.active {
  background: var(--soft);
  color: #fff;
}

/* === 重置 === */
button { margin: 0; padding: 0; background: none; border: none; line-height: inherit; }
button::after { border: none; }
input, textarea { outline: none; }
image { display: block; }
